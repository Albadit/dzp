@using System.Web

@{
    var isRouted  = HttpContext.Current.Items["RouteActive"] != null;
    var rawUrl    = HttpContext.Current.Request.Url.AbsolutePath;
    var routeKeys = HttpContext.Current.Items["RouteKeys"] as string[];
}

<div class="w-full max-w-md flex flex-col">
    <h2 class="text-2xl font-bold text-foreground-800 mb-4">Route Info</h2>

    @if (isRouted && routeKeys != null)
    {
        <div class="bg-background rounded-xl shadow-card overflow-hidden border border-divider">
            <div class="px-5 py-3 bg-content2 border-b border-divider">
                <p class="text-sm text-foreground-500">URL: <span class="font-mono text-foreground-800">@rawUrl</span></p>
            </div>
            <ul class="divide-y divide-default-100">
                @foreach (var key in routeKeys)
                {
                    var val = HttpContext.Current.Items[key] as string;
                    if (!string.IsNullOrEmpty(val))
                    {
                        <li class="flex items-center justify-between px-5 py-3 hover:bg-default-50 transition-colors">
                            <span class="text-sm font-mono text-foreground-500">[@key]</span>
                            <span class="inline-flex items-center rounded-full bg-primary-50 px-3 py-1 text-sm font-semibold text-primary-700">@val</span>
                        </li>
                    }
                }
                <li class="flex items-center justify-between px-5 py-3 hover:bg-default-50 transition-colors">
                    <span class="text-sm font-medium text-foreground-500">Tab</span>
                    <span class="text-sm text-foreground-700">@Dnn.Tab.TabName <span class="text-foreground-400">(#@Dnn.Tab.TabID)</span></span>
                </li>
            </ul>
        </div>
    }
    else
    {
        <div class="bg-warning-50 border border-warning-200 rounded-xl px-5 py-4">
            <p class="text-sm text-warning-800">This page was <strong>not</strong> loaded via slug routing.</p>
            <p class="text-sm text-warning-600 mt-1 font-mono">@rawUrl</p>
        </div>
    }
</div>

