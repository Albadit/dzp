@*
    Marketing landing page — orchestrates section partials in Shared/Home/.
    Each section is self-contained: it owns its own data + markup, so you
    can edit copy or layout for one section without touching the others.
    Only page-level metadata (SEO) is declared here and passed via PageData.
*@
@{
    Layout = "Shared/_Layout.cshtml";

    /* ── Page-level SEO ── */
    PageData["seoTitle"]       = "DZP Connect – Dé communicatie-app voor winkelgebieden";
    PageData["seoDescription"] = "Nieuws, events, documenten en bedrijfsprofielen in één veilige app. Overzichtelijk en altijd bij de hand voor jouw winkelgebied.";
    PageData["seoUrl"]         = HttpContext.Current.Request.Url;
    PageData["seoOrigin"]      = HttpContext.Current.Request.Url.GetLeftPart(UriPartial.Authority);
}

@RenderPage("Shared/Home/_Seo.cshtml")
@RenderPage("Shared/Home/_Hero.cshtml")
@RenderPage("Shared/Home/_Comparison.cshtml")
@RenderPage("Shared/Home/_Steps.cshtml")
@RenderPage("Shared/Home/_Features.cshtml")
@RenderPage("Shared/Home/_Audiences.cshtml")
@RenderPage("Shared/Home/_Roles.cshtml")
@RenderPage("Shared/Home/_Privacy.cshtml")
@RenderPage("Shared/Home/_Pricing.cshtml")
@RenderPage("Shared/Home/_Roadmap.cshtml")
