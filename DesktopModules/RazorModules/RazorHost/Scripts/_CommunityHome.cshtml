@using DZP.CommunityAuth
@using DotNetNuke.Entities.Users
@using DotNetNuke.Entities.Portals
@using System.Data.SqlClient
@using System.Configuration
@using System.Linq
@*
    Community home page.
    Owns all data fetching (community auth + SQL queries) and exposes the
    result via PageData so the section partials in Shared/CommunityHome/
    stay markup-only and easy to skim.
*@
@{
    var rc       = CommunityAuth.Current;
    var user     = Dnn.User;
    var portalId = PortalSettings.Current != null ? PortalSettings.Current.PortalId : 0;
    var connStr  = ConfigurationManager.ConnectionStrings["SiteSqlServer"] != null
                       ? ConfigurationManager.ConnectionStrings["SiteSqlServer"].ConnectionString
                       : "";

    /* ── Community info from route ── */
    var communityName = rc != null ? rc.CommunityName : "Community";
    var communitySlug = rc != null ? rc.CommunitySlug : "";
    var communityId   = rc != null ? rc.CommunityId   : 0;
    var companyName   = rc != null && !string.IsNullOrEmpty(rc.CompanyName) ? rc.CompanyName : "";

    /* ── Lookup Community.ImageUrl from DB (CommunityAuth doesn't expose it) ── */
    string communityBannerUrl = "";
    if (rc != null && !string.IsNullOrEmpty(connStr)) {
        using (var bc = new SqlConnection(connStr)) {
        using (var bcmd = new SqlCommand("SELECT ImageUrl FROM Community WHERE Id = @cid", bc)) {
            bcmd.Parameters.AddWithValue("@cid", rc.CommunityId);
            bc.Open();
            var br = bcmd.ExecuteScalar();
            if (br != null && br != DBNull.Value) { communityBannerUrl = (string)br; }
        }
        }
    }
    var bannerImage = !string.IsNullOrEmpty(communityBannerUrl)
                          ? communityBannerUrl
                          : "https://picsum.photos/seed/" + communitySlug + "/1200/400";

    /* ── User's groups + visibility (CM/SU sees all, others their own) ── */
    var groups = user != null && user.UserID > 0
                    ? CommunityAuth.GetUserCommunities(user)
                    : new List<CommunityAuth.CommunityInfo>();

    var allCommunityGroups = CommunityAuth.GetAllCommunityGroups(communityId);
    var userGroups = user != null && user.UserID > 0
                        ? CommunityAuth.GetUserGroups(user)
                        : new List<CommunityAuth.GroupInfo>();

    var isSU = user != null && user.IsSuperUser;
    var isCM = rc != null && rc.CommunityRoleNames != null && rc.CommunityRoleNames
                    .Any(rn => string.Equals(rn, "Community Manager", StringComparison.OrdinalIgnoreCase));

    var displayGroups = (isCM || isSU)
                            ? allCommunityGroups
                            : userGroups.Where(g => g.CommunityId == communityId).ToList();

    /* ── Lookup ImageUrl for displayed groups (not exposed by GroupInfo) ── */
    var groupImages = new Dictionary<int, string>();
    if (displayGroups.Count > 0 && !string.IsNullOrEmpty(connStr)) {
        try {
            using (var giConn = new SqlConnection(connStr)) {
            using (var giCmd  = giConn.CreateCommand()) {
                var giSb = new System.Text.StringBuilder("SELECT Id, ImageUrl FROM CommunityGroups WHERE Id IN (");
                for (var i = 0; i < displayGroups.Count; i++) {
                    if (i > 0) { giSb.Append(","); }
                    giSb.Append("@gid").Append(i);
                    giCmd.Parameters.AddWithValue("@gid" + i, displayGroups[i].Id);
                }
                giSb.Append(")");
                giCmd.CommandText = giSb.ToString();
                giConn.Open();
                using (var giR = giCmd.ExecuteReader()) {
                    while (giR.Read()) {
                        var gid = (int)giR["Id"];
                        var gurl = giR["ImageUrl"] as string;
                        if (!string.IsNullOrEmpty(gurl)) { groupImages[gid] = gurl; }
                    }
                }
            }
            }
        } catch { /* swallow — groups still render with picsum fallback */ }
    }

    /* ── Latest 2 posts visible to this user in this community ── */
    var latestPosts = new List<Dictionary<string, object>>();
    if (rc != null && !string.IsNullOrEmpty(connStr)) {
        try {
            var userGroupIds = userGroups.Where(g => g.CommunityId == rc.CommunityId).Select(g => g.Id).ToList();
            var seeAll = isCM || isSU;

            using (var conn = new SqlConnection(connStr)) {
            using (var cmd = conn.CreateCommand()) {
                var sb = new System.Text.StringBuilder();
                sb.Append(@"
                    SELECT TOP 2
                        p.PostId, p.PostType, p.Title, p.Content, p.ImageUrl,
                        p.AuthorUserId, p.PublishOn, p.CommentCount, p.ViewCount
                    FROM Dnn_Modules_Blog_Posts p
                    WHERE p.CommunityId = @cid
                      AND p.IsDeleted   = 0
                      AND p.IsDraft     = 0
                      AND p.PublishOn  <= SYSUTCDATETIME()
                      AND ( NOT EXISTS (SELECT 1 FROM Dnn_Modules_Blog_PostGroups pg WHERE pg.PostId = p.PostId) ");
                if (seeAll) {
                    sb.Append(" OR 1 = 1 ");
                } else if (userGroupIds.Count > 0) {
                    sb.Append(@" OR EXISTS (SELECT 1
                                            FROM Dnn_Modules_Blog_PostGroups pg
                                            WHERE pg.PostId = p.PostId
                                              AND pg.CommunityGroupId IN (");
                    for (var i = 0; i < userGroupIds.Count; i++) {
                        if (i > 0) { sb.Append(","); }
                        sb.Append("@gid" + i);
                    }
                    sb.Append(")) ");
                }
                sb.Append(" ) ORDER BY p.PublishOn DESC");
                cmd.CommandText = sb.ToString();
                cmd.Parameters.AddWithValue("@cid", rc.CommunityId);
                if (!seeAll) {
                    for (var i = 0; i < userGroupIds.Count; i++) {
                        cmd.Parameters.AddWithValue("@gid" + i, userGroupIds[i]);
                    }
                }

                conn.Open();
                using (var reader = cmd.ExecuteReader()) {
                    while (reader.Read()) {
                        var content = reader["Content"] as string ?? "";
                        var excerpt = System.Text.RegularExpressions.Regex.Replace(content, "<[^>]+>", "").Trim();
                        if (excerpt.Length > 300) { excerpt = excerpt.Substring(0, 300) + "..."; }

                        var authorUserId = (int)reader["AuthorUserId"];
                        var au = UserController.Instance.GetUserById(portalId, authorUserId);

                        latestPosts.Add(new Dictionary<string, object> {
                            { "PostId",         (int)reader["PostId"] },
                            { "Title",          reader["Title"] as string ?? "" },
                            { "Teaser",         excerpt },
                            { "Image",          reader["ImageUrl"] as string ?? "" },
                            { "Author",         au != null ? au.DisplayName : "" },
                            { "CommunitySlug",  communitySlug }
                        });
                    }
                }
            }
            }
        } catch { /* swallow — page still renders with empty-state */ }
    }

    /* ── Discovery buttons (visible buttons in visible categories) ── */
    var discoverButtons = new List<Dictionary<string, object>>();
    if (rc != null && !string.IsNullOrEmpty(connStr)) {
        try {
            using (var conn = new SqlConnection(connStr)) {
            using (var cmd = new SqlCommand(@"
                SELECT b.Label, b.Icon, b.Url
                FROM CommunityDiscoverButton b
                INNER JOIN CommunityDiscoverCategory c ON c.Id = b.CommunityDiscoverCategoryId
                WHERE c.CommunityId = @cid
                  AND c.IsVisible   = 1
                  AND b.IsVisible   = 1
                ORDER BY c.SortOrder, c.Id, b.SortOrder, b.Id", conn)) {
                cmd.Parameters.AddWithValue("@cid", rc.CommunityId);
                conn.Open();
                using (var reader = cmd.ExecuteReader()) {
                    while (reader.Read()) {
                        discoverButtons.Add(new Dictionary<string, object> {
                            { "Label", reader.GetString(0) },
                            { "Icon",  reader.IsDBNull(1) ? "" : reader.GetString(1) },
                            { "Url",   reader.GetString(2) }
                        });
                    }
                }
            }
            }
        } catch { /* swallow — Ondekt section just renders empty */ }
    }

    /* ── Team members (Community beheerders for this community) ── */
    var teamMembers = new List<Dictionary<string, object>>();
    if (rc != null && !string.IsNullOrEmpty(connStr)) {
        try {
            var userIds = new List<int>();
            using (var conn = new SqlConnection(connStr)) {
            using (var cmd = new SqlCommand(@"
                SELECT TOP 10 uc.UserId
                FROM UserCommunity uc
                INNER JOIN UserCommunityRole ucr ON ucr.UserCommunityId = uc.Id
                INNER JOIN Roles r ON r.RoleID = ucr.RoleId
                WHERE uc.CommunityId = @cid
                  AND r.RoleName = 'Community beheerder'", conn)) {
                cmd.Parameters.AddWithValue("@cid", rc.CommunityId);
                conn.Open();
                using (var reader = cmd.ExecuteReader()) {
                    while (reader.Read()) { userIds.Add(reader.GetInt32(0)); }
                }
            }
            }
            foreach (var uid in userIds) {
                var u = UserController.Instance.GetUserById(portalId, uid);
                if (u != null) {
                    teamMembers.Add(new Dictionary<string, object> {
                        { "Name",  u.DisplayName },
                        { "Role",  "Community beheerder" },
                        { "Email", u.Email ?? "" },
                        { "Image", "/DnnImageHandler.ashx?mode=profilepic&userId=" + u.UserID + "&w=80&h=80" }
                    });
                }
            }
        } catch { /* swallow — team strip shows empty-state */ }
    }

    /* ── Publish to PageData ── */
    PageData["communityName"] = communityName;
    PageData["communitySlug"] = communitySlug;
    PageData["companyName"]   = companyName;
    PageData["bannerImage"]   = bannerImage;
    PageData["displayGroups"] = displayGroups;
    PageData["groupImages"]   = groupImages;
    PageData["latestPosts"]   = latestPosts;
    PageData["teamMembers"]   = teamMembers;
    PageData["discoverButtons"] = discoverButtons;
}

<main class="max-w-8xl w-full m-auto flex flex-col gap-4">
    @RenderPage("Shared/CommunityHome/_BannerPosts.cshtml")
    @RenderPage("Shared/CommunityHome/_Ondekt.cshtml")
    @RenderPage("Shared/CommunityHome/_Groups.cshtml")
    @RenderPage("Shared/CommunityHome/_Team.cshtml")
</main>

@RenderPage("Shared/CommunityHome/_DragScroll.cshtml")
