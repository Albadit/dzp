@using DZP.CommunityAuth
@using DotNetNuke.Entities.Users
@using DotNetNuke.Entities.Portals
@using System.Web
@using System.Data.SqlClient
@using System.Configuration
@using System.Linq
@{
  var debugLog = new List<string>();
  debugLog.Add("Page started");

  CommunityAuth rc = null;
  try
  {
    rc = CommunityAuth.Current;
    debugLog.Add("CommunityAuth.Current = " + (rc != null ? "OK" : "NULL"));
  }
  catch (Exception ex)
  {
    debugLog.Add("CommunityAuth.Current ERROR: " + ex.GetType().Name + ": " + ex.Message);
    if (ex.InnerException != null) { debugLog.Add("Inner: " + ex.InnerException.Message); }
  }

  var user = Dnn.User;
  debugLog.Add("User = " + (user != null ? user.DisplayName + " (ID=" + user.UserID + ")" : "NULL"));
  var portalId = PortalSettings.Current != null ? PortalSettings.Current.PortalId : 0;
  debugLog.Add("PortalId = " + portalId);

  /* ── Community info from route ── */
  var communityName = rc != null ? rc.CommunityName : "Community";
  var communitySlug = rc != null ? rc.CommunitySlug : "";
  var companyName   = rc != null && !string.IsNullOrEmpty(rc.CompanyName) ? rc.CompanyName : "";

  /* ── Lookup Community.ImageUrl from DB (canonical CommunityAuth doesn't expose it) ── */
  string communityBannerUrl = "";
  if (rc != null)
  {
    var bannerCs = ConfigurationManager.ConnectionStrings["SiteSqlServer"];
    if (bannerCs != null && !string.IsNullOrEmpty(bannerCs.ConnectionString))
    {
      using (var bc = new SqlConnection(bannerCs.ConnectionString))
      {
        using (var bcmd = new SqlCommand("SELECT ImageUrl FROM Community WHERE Id = @cid", bc))
        {
          bcmd.Parameters.AddWithValue("@cid", rc.CommunityId);
          bc.Open();
          var br = bcmd.ExecuteScalar();
          if (br != null && br != DBNull.Value) { communityBannerUrl = (string)br; }
        }
      }
    }
  }
  var bannerImage = !string.IsNullOrEmpty(communityBannerUrl)
                      ? communityBannerUrl
                      : "https://picsum.photos/seed/" + communitySlug + "/1200/400";
  debugLog.Add("communityName=" + communityName + ", slug=" + communitySlug + ", banner=" + bannerImage);

  /* ── Helper: resolve 2sxc "file:NNN" references to URLs ── */
  Func<string, string, string> resolveImage = (imgVal, connString) => {
    if (string.IsNullOrEmpty(imgVal)) return "";
    if (!imgVal.StartsWith("file:")) return imgVal;
    var fileIdStr = imgVal.Substring(5);
    int fileId;
    if (!int.TryParse(fileIdStr, out fileId)) return "";
    using (var c = new SqlConnection(connString))
    {
      using (var cmd2 = new SqlCommand("SELECT Folder, FileName, PortalId FROM Files WHERE FileId = @fid", c))
      {
        cmd2.Parameters.AddWithValue("@fid", fileId);
        c.Open();
        using (var r = cmd2.ExecuteReader())
        {
          if (r.Read())
          {
            var folder = r["Folder"] as string;
            var fileName = r["FileName"] as string;
            var pid = (int)r["PortalId"];
            return "/Portals/" + pid + "/" + folder + fileName;
          }
        }
      }
    }
    return "";
  };

  /* ── Groepen (communities this user belongs to) ── */
  var groups = user != null && user.UserID > 0
    ? CommunityAuth.GetUserCommunities(user)
    : new List<CommunityAuth.CommunityInfo>();

  /* ── Community Groups for current community ── */
  var communityId = rc != null ? rc.CommunityId : 0;
  var allCommunityGroups = CommunityAuth.GetAllCommunityGroups(communityId);
  var userGroups = user != null && user.UserID > 0
    ? CommunityAuth.GetUserGroups(user)
    : new List<CommunityAuth.GroupInfo>();

  /* ── Build visible tags (same logic as Blog6/ListMain) ── */
  var visibleTags = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
  if (!string.IsNullOrEmpty(communitySlug)) { visibleTags.Add(communitySlug); }
  var isSU = user != null && user.IsSuperUser;
  var isCM = rc != null && rc.CommunityRoleNames != null && rc.CommunityRoleNames.Any(rn => string.Equals(rn, "Community Manager", StringComparison.OrdinalIgnoreCase));
  if (isCM || isSU) {
    foreach (var g in allCommunityGroups) {
      visibleTags.Add(g.Name);
      visibleTags.Add(g.Id.ToString());
    }
  } else {
    foreach (var g in userGroups) {
      if (communityId == 0 || g.CommunityId == communityId) {
        visibleTags.Add(g.Name);
        visibleTags.Add(g.Id.ToString());
      }
    }
  }
  debugLog.Add("visibleTags count=" + visibleTags.Count + " tags=" + string.Join(",", visibleTags));

  /* ── Map group IDs→names for display ── */
  var groupIdToName = new Dictionary<string, string>();
  foreach (var g in allCommunityGroups) { groupIdToName[g.Id.ToString()] = g.Name; }
  // Also map groups from other communities
  foreach (var g in userGroups) {
    if (!groupIdToName.ContainsKey(g.Id.ToString())) { groupIdToName[g.Id.ToString()] = g.Name; }
  }

  /* ── Groups to display: CM/SU see all, others see only their own ── */
  var displayGroups = (isCM || isSU)
    ? allCommunityGroups
    : userGroups.Where(g => g.CommunityId == communityId).ToList();

  /* ── Lookup ImageUrl for displayed groups (not exposed by GroupInfo) ── */
  var groupImages = new Dictionary<int, string>();
  try {
    if (displayGroups.Count > 0) {
      var giCs = ConfigurationManager.ConnectionStrings["SiteSqlServer"];
      var giConnStr = giCs != null ? giCs.ConnectionString : "";
      if (!string.IsNullOrEmpty(giConnStr)) {
        using (var giConn = new SqlConnection(giConnStr))
        {
          using (var giCmd = giConn.CreateCommand())
          {
            var giSb = new System.Text.StringBuilder("SELECT Id, ImageUrl FROM CommunityGroups WHERE Id IN (");
            for (var i = 0; i < displayGroups.Count; i++) {
              if (i > 0) { giSb.Append(","); }
              giSb.Append("@gid").Append(i);
              giCmd.Parameters.AddWithValue("@gid" + i, displayGroups[i].Id);
            }
            giSb.Append(")");
            giCmd.CommandText = giSb.ToString();
            giConn.Open();
            using (var giR = giCmd.ExecuteReader())
            {
              while (giR.Read()) {
                var gid = (int)giR["Id"];
                var gurl = giR["ImageUrl"] as string;
                if (!string.IsNullOrEmpty(gurl)) { groupImages[gid] = gurl; }
              }
            }
          }
        }
      }
    }
  } catch (Exception ex) {
    debugLog.Add("Group images query ERROR: " + ex.Message);
  }

  /* ── Slug → community name lookup ── */
  var slugToName = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
  if (!string.IsNullOrEmpty(communitySlug)) { slugToName[communitySlug] = communityName; }
  foreach (var c in groups) {
    if (!string.IsNullOrEmpty(c.Slug)) { slugToName[c.Slug] = c.Name; }
  }

  /* ── Laatste berichten (from Dnn_Modules_Blog_Posts) ── */
  /*  Visibility:
   *   - Post is in current community (CommunityId = rc.CommunityId)
   *   - AND (post has no group mapping  OR  CM/SU  OR  user shares at least one group)
   *  Returns latest 2 published, non-draft, non-deleted posts ordered by PublishOn DESC.
   */
  var latestPosts = new List<dynamic>();
  try
  {
  if (rc != null)
  {
    var cs = ConfigurationManager.ConnectionStrings["SiteSqlServer"];
    var connStr = cs != null ? cs.ConnectionString : "";
    debugLog.Add("connStr empty? " + string.IsNullOrEmpty(connStr));
    if (!string.IsNullOrEmpty(connStr))
    {
      // Build user's group-id list for visibility filter
      var userGroupIds = new List<int>();
      foreach (var g in userGroups) {
        if (g.CommunityId == rc.CommunityId) { userGroupIds.Add(g.Id); }
      }
      var seeAll = isCM || isSU;

      using (var conn = new SqlConnection(connStr))
      {
        using (var cmd = conn.CreateCommand())
        {
          var sb = new System.Text.StringBuilder();
          sb.Append(@"
            SELECT TOP 2
                p.PostId,
                p.PostType,
                p.Title,
                p.Content,
                p.ImageUrl,
                p.AuthorUserId,
                p.PublishOn,
                p.CommentCount,
                p.ViewCount
            FROM Dnn_Modules_Blog_Posts p
            WHERE p.CommunityId = @cid
              AND p.IsDeleted   = 0
              AND p.IsDraft     = 0
              AND p.PublishOn  <= SYSUTCDATETIME()
              AND (
                    NOT EXISTS (SELECT 1 FROM Dnn_Modules_Blog_PostGroups pg WHERE pg.PostId = p.PostId)
              ");
          if (seeAll) {
            sb.Append(@" OR 1 = 1 ");
          } else if (userGroupIds.Count > 0) {
            sb.Append(@" OR EXISTS (SELECT 1
                                    FROM Dnn_Modules_Blog_PostGroups pg
                                    WHERE pg.PostId = p.PostId
                                      AND pg.CommunityGroupId IN (");
            for (var i = 0; i < userGroupIds.Count; i++) {
              if (i > 0) { sb.Append(","); }
              sb.Append("@gid" + i);
            }
            sb.Append(")) ");
          }
          sb.Append(@"   )
            ORDER BY p.PublishOn DESC");
          cmd.CommandText = sb.ToString();
          cmd.Parameters.AddWithValue("@cid", rc.CommunityId);
          if (!seeAll) {
            for (var i = 0; i < userGroupIds.Count; i++) {
              cmd.Parameters.AddWithValue("@gid" + i, userGroupIds[i]);
            }
          }

          conn.Open();
          using (var reader = cmd.ExecuteReader())
          {
            while (reader.Read())
            {
              var postId       = (int)reader["PostId"];
              var title        = reader["Title"] as string ?? "";
              var content      = reader["Content"] as string ?? "";
              var imageUrl     = reader["ImageUrl"] as string ?? "";
              var authorUserId = (int)reader["AuthorUserId"];
              var publishOn    = reader["PublishOn"] is DateTime ? ((DateTime)reader["PublishOn"]).ToString("o") : "";

              // Build excerpt from Content (strip HTML)
              var excerpt = System.Text.RegularExpressions.Regex.Replace(content ?? "", "<[^>]+>", "").Trim();
              if (excerpt.Length > 300) { excerpt = excerpt.Substring(0, 300) + "..."; }

              // Resolve author display name via DNN
              var authorName = "";
              var au = UserController.Instance.GetUserById(portalId, authorUserId);
              if (au != null) { authorName = au.DisplayName; }

              latestPosts.Add(new {
                Title          = title,
                Teaser         = excerpt,
                Image          = imageUrl,
                Date           = publishOn,
                CommunitySlug  = communitySlug,
                CommunityLabel = communityName,
                Author         = authorName,
                PostId         = postId
              });
            }
          }
        }
      }

      for (var i = 0; i < latestPosts.Count; i++)
      {
        debugLog.Add("Post[" + i + "] id=" + (int)latestPosts[i].PostId
          + " title='" + (string)latestPosts[i].Title + "'"
          + " image='" + (string)latestPosts[i].Image + "'");
      }
    }
  }
  debugLog.Add("latestPosts found: " + latestPosts.Count);
  }
  catch (Exception ex)
  {
    debugLog.Add("Posts query ERROR: " + ex.Message);
  }

  /* ── Ondekt (quick-links grid) ── */
  var ondektLinks = new[] {
    new { Label = "VISIT HW",                       Icon = "map-pin",     Url = "/" + communitySlug + "/visit" },
    new { Label = "Cadeaubon Hoeksche Waard",       Icon = "gift",        Url = "/" + communitySlug + "/cadeaubon" },
    new { Label = "Gemeente Hoeksche Waard",        Icon = "landmark",    Url = "/" + communitySlug + "/gemeente" },
    new { Label = "Ondernemend Hoeksche Waard",     Icon = "briefcase",   Url = "/" + communitySlug + "/ondernemend" },
    new { Label = "Duurzaamheid",                   Icon = "leaf",        Url = "/" + communitySlug + "/duurzaamheid" },
    new { Label = "Ondernemersplein",               Icon = "store",       Url = "/" + communitySlug + "/ondernemersplein" },
    new { Label = "Mijn (notificatie)instellingen", Icon = "bell",        Url =  "/settings" },
    new { Label = "Q&A",                            Icon = "help-circle", Url = "/" + communitySlug + "/qa" },
    new { Label = "Tijdlijn",                       Icon = "clock",       Url = "/" + communitySlug + "/timeline" },
    new { Label = "Evenementen",                    Icon = "calendar",    Url = "/" + communitySlug + "/evenementen" },
    new { Label = "Leden",                          Icon = "users",       Url = "/" + communitySlug + "/leden" },
    new { Label = "Bestanden",                      Icon = "folder",      Url = "/" + communitySlug + "/bestanden" },
  };

  /* ── Ontmoet het team (members of this community) ── */
  var teamMembers = new List<dynamic>();
  try
  {
  if (rc != null)
  {
    var cs2 = ConfigurationManager.ConnectionStrings["SiteSqlServer"];
    var connStr2 = cs2 != null ? cs2.ConnectionString : "";
    if (!string.IsNullOrEmpty(connStr2))
    {
      var userIds = new List<int>();
      using (var conn = new SqlConnection(connStr2))
      {
        using (var cmd = new SqlCommand(@"
          SELECT TOP 10 uc.UserId
          FROM UserCommunity uc
          INNER JOIN UserCommunityRole ucr ON ucr.UserCommunityId = uc.Id
          INNER JOIN Roles r ON r.RoleID = ucr.RoleId
          WHERE uc.CommunityId = @cid
            AND r.RoleName = 'Community beheerder'", conn))
        {
          cmd.Parameters.AddWithValue("@cid", rc.CommunityId);
          conn.Open();
          using (var reader = cmd.ExecuteReader())
          {
            while (reader.Read())
            {
              userIds.Add(reader.GetInt32(0));
            }
          }
        }
      }
      foreach (var uid in userIds)
      {
        var u = UserController.Instance.GetUserById(portalId, uid);
        if (u != null)
        {
          teamMembers.Add(new {
            Name  = u.DisplayName,
            Role  = "Community beheerder",
            Email = u.Email ?? "",
            Image = "/DnnImageHandler.ashx?mode=profilepic&userId=" + u.UserID + "&w=80&h=80"
          });
        }
      }
    }
  }
  debugLog.Add("teamMembers found: " + teamMembers.Count);
  }
  catch (Exception ex)
  {
    debugLog.Add("Team query ERROR: " + ex.Message);
  }

  debugLog.Add("Render start");

}


@* DEBUG ON *@
@* <div class="bg-yellow-50 border border-yellow-300 rounded-xl p-4 m-4 text-xs font-mono text-yellow-900">
  <strong>DEBUG _CommunityHome</strong>
  <ul class="mt-1">
    @foreach (var msg in debugLog) {
    <li>@msg</li>
    }
  </ul>
</div> *@

<main class="max-w-8xl w-full m-auto">
  <!-- ============================================ -->
  <!-- 1) BANNER + LATEST POSTS                     -->
  <!-- ============================================ -->
  <section class="w-full">
    <div class="w-full px-4 sm:px-6 lg:px-8 py-4 sm:py-8">
      <div class="flex flex-col xl:flex-row gap-5 sm:gap-8">

        <!-- Left: community banner -->
        <div class="relative flex-1 min-h-48 sm:min-h-80 rounded-lg overflow-hidden">
          <img src="@bannerImage" alt="@communityName" class="absolute inset-0 w-full h-full object-cover" />
          <div class="absolute inset-0 bg-linear-to-t from-black/70 via-black/20 to-transparent"></div>
          <div class="relative flex flex-col justify-end h-full p-6 gap-1">
            <h1 class="text-2xl sm:text-3xl font-bold text-white leading-tight">@communityName</h1>
            @if (companyName.Length > 0) {
            <span class="text-sm text-white/80">@companyName</span>
            }
          </div>
        </div>

        <!-- Right: latest posts from community & groups -->
        <div class="flex flex-col gap-3 sm:gap-4 xl:w-[480px]">
          <div class="flex items-center justify-between">
            <h2 class="text-base font-semibold text-foreground-900">Laatste berichten</h2>
            <a href="/@communitySlug/timeline" class="text-sm font-medium text-foreground-500 hover:text-primary transition flex items-center gap-1">
              Ga naar <i data-lucide="arrow-right" class="size-3.5"></i>
            </a>
          </div>
          @if (latestPosts.Count == 0) {
          <div class="flex flex-col items-center gap-3 py-8 text-center bg-content1 rounded-xl border border-divider">
            <p class="text-sm text-foreground-400">Er zijn nog geen berichten.</p>
          </div>
          } else {
          <div class="grid grid-rows-2 gap-3 sm:gap-4 flex-1">
          @foreach (var post in latestPosts) {
            var postImg = !string.IsNullOrEmpty((string)post.Image) ? (string)post.Image : "https://picsum.photos/seed/post" + post.Title.GetHashCode() + "/400/300";
            var postSlug = !string.IsNullOrEmpty((string)post.CommunitySlug) ? (string)post.CommunitySlug : communitySlug;
          <a href="/@postSlug/timeline?post=@post.PostId" class="flex cursor-pointer group bg-content2 hover:bg-primary/5 overflow-hidden min-h-[130px] rounded-lg p-1 transition">
            <img src="@postImg" alt="@post.Title" class="rounded-md w-36 object-cover shrink-0" />
            <div class="flex flex-col gap-2 pl-4 min-w-0 flex-1 py-2">
              <h3 class="text-sm sm:text-base font-bold text-foreground-900 leading-snug group-hover:text-primary transition line-clamp-2">@post.Title</h3>
              <p class="text-xs sm:text-sm text-foreground-500 leading-relaxed line-clamp-3 sm:line-clamp-5">@post.Teaser</p>
              @if (!string.IsNullOrEmpty((string)post.Author)) {
              <span class="text-xs font-medium text-primary/80 mt-auto pt-1 truncate">@post.Author</span>
              }
            </div>
          </a>
          }
          </div>
          }
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- 2) ONDEKT (quick-links)                      -->
  <!-- ============================================ -->
  <section class="w-full">
    <div class="w-full px-4 sm:px-6 lg:px-8 py-4 sm:py-6 flex flex-col gap-3 sm:gap-4">
      <div class="flex items-center justify-between">
        <h2 class="text-base font-semibold text-foreground-900">Ondekt</h2>
        <a href="/@communitySlug/discover" class="text-sm font-medium text-foreground-500 hover:text-primary transition flex items-center gap-1">
          Ga naar <i data-lucide="arrow-right" class="size-3.5"></i>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 sm:gap-3">
        @foreach (var link in ondektLinks) {
        <a href="@link.Url" class="group flex items-center gap-3 px-3 py-2.5 sm:px-4 sm:py-3 rounded-lg bg-content2 text-xs sm:text-sm font-medium text-foreground-700 hover:text-primary hover:bg-primary/5 transition">
          <i data-lucide="@link.Icon" class="size-4 text-foreground-500 group-hover:text-primary transition shrink-0"></i>
          <span class="truncate flex-1">@link.Label</span>
          <i data-lucide="chevron-right" class="size-3.5 text-foreground-300 group-hover:text-primary group-hover:translate-x-0.5 transition shrink-0"></i>
        </a>
        }
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- 3) GROEPEN                                   -->
  <!-- ============================================ -->
  <section class="w-full">
    <div class="w-full px-4 sm:px-6 lg:px-8 flex flex-col gap-3 sm:gap-4 py-4 sm:py-6">
      <div class="flex items-center justify-between">
        <h2 class="text-base font-semibold text-foreground-900">Groepen</h2>
        <a href="/@communitySlug/manage/groups" class="text-sm font-medium text-foreground-500 hover:text-primary transition flex items-center gap-1">
          Ga naar <i data-lucide="arrow-right" class="size-3.5"></i>
        </a>
      </div>
    </div>
    <div class="w-full px-4 sm:px-6 lg:px-8">
      <div class="js-groups-strip flex gap-4 overflow-x-auto snap-x snap-mandatory scrollbar-hide">
        @if (displayGroups.Count == 0) {
        <div class="flex flex-col items-center gap-3 py-8 text-center w-full">
          <p class="text-sm text-foreground-400">Er zijn nog geen groepen in deze community.</p>
        </div>
        } else {
        foreach (var g in displayGroups) {
          var groupImg = groupImages.ContainsKey(g.Id) && !string.IsNullOrEmpty(groupImages[g.Id])
            ? groupImages[g.Id]
            : "https://picsum.photos/seed/group" + g.Id + "/300/400";
          <div class="relative w-32 h-40 sm:w-36 sm:h-44 shrink-0 rounded-lg overflow-hidden group snap-start">
            <img src="@groupImg" alt="@g.Name" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
            <div class="absolute inset-0 bg-linear-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="relative flex items-end h-full p-3">
              <span class="text-xs font-semibold text-white leading-tight">@g.Name</span>
            </div>
          </div>
        }
        }
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- 4) ONTMOET HET TEAM                          -->
  <!-- ============================================ -->
  <section class="w-full">
    <div class="w-full px-4 sm:px-6 lg:px-8 flex flex-col gap-3 sm:gap-4 py-4 sm:py-6">
      <div class="flex items-center justify-between">
        <h2 class="text-base font-semibold text-foreground-900">Ontmoet het team</h2>
        <a href="/@communitySlug/manage/managers" class="text-sm font-medium text-foreground-500 hover:text-primary transition flex items-center gap-1">
          Ga naar <i data-lucide="arrow-right" class="size-3.5"></i>
        </a>
      </div>
    </div>
    @if (teamMembers.Count == 0) {
    <div class="w-full px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center gap-3 py-8 text-center">
        <p class="text-sm text-foreground-400">Er zijn nog geen teamleden in deze community.</p>
      </div>
    </div>
    } else {
    <div class="w-full px-4 sm:px-6 lg:px-8">
      <div class="js-team-strip flex gap-4 sm:gap-6 overflow-x-auto snap-x snap-mandatory scrollbar-hide">
        @foreach (var member in teamMembers) {
        <button type="button" onclick="openTeamModal(this)" data-name="@member.Name" data-role="@member.Role" data-email="@member.Email" data-image="@member.Image" class="flex flex-col items-center gap-1.5 sm:gap-2 shrink-0 snap-start cursor-pointer hover:opacity-80 transition">
          <div class="size-16 sm:size-20 rounded-full overflow-hidden border-2 border-divider">
            <img src="@member.Image" alt="@member.Name" class="w-full h-full object-cover rounded-full" />
          </div>
          <div class="flex flex-col items-center gap-0.5">
            <span class="text-sm font-semibold text-foreground-900">@member.Name</span>
            <span class="text-xs text-foreground-400">@member.Role</span>
          </div>
        </button>
        }
      </div>
    </div>
    }
  </section>

  <!-- Team member modal -->
  <div id="teamModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm" onclick="if(event.target===this)closeTeamModal()">
    <div class="bg-content1 rounded-2xl shadow-xl w-[90vw] max-w-sm mx-auto p-6 flex flex-col items-center gap-4 relative">
      <button type="button" onclick="closeTeamModal()" class="absolute top-3 right-3 text-foreground-400 hover:text-foreground-900 transition">
        <i data-lucide="x" class="size-5"></i>
      </button>
      <div class="size-24 rounded-full overflow-hidden border-2 border-divider">
        <img id="tmImg" src="" alt="" class="w-full h-full object-cover rounded-full" />
      </div>
      <div class="flex flex-col items-center gap-1">
        <h3 id="tmName" class="text-lg font-bold text-foreground-900"></h3>
        <span id="tmRole" class="text-sm text-foreground-400"></span>
      </div>
      <div id="tmEmailRow" class="flex items-center gap-2 w-full bg-background rounded-xl border border-divider px-3 py-2.5">
        <i data-lucide="mail" class="size-4 text-foreground-400 shrink-0"></i>
        <span id="tmEmail" class="text-sm text-foreground-700 truncate flex-1"></span>
        <button type="button" onclick="copyTeamEmail()" class="shrink-0 text-primary hover:text-primary/70 transition" title="Kopieer e-mail">
          <i data-lucide="copy" class="size-4"></i>
        </button>
      </div>

    </div>
  </div>

  <script>
    function openTeamModal(el) {
      var m = document.getElementById('teamModal');
      document.getElementById('tmImg').src = el.dataset.image;
      document.getElementById('tmName').textContent = el.dataset.name;
      document.getElementById('tmRole').textContent = el.dataset.role;
      var email = el.dataset.email;
      var emailRow = document.getElementById('tmEmailRow');
      if (email) {
        document.getElementById('tmEmail').textContent = email;
        emailRow.classList.remove('hidden');
      } else {
        emailRow.classList.add('hidden');
      }
      m.classList.remove('hidden');
      m.classList.add('flex');
      if (typeof lucide !== 'undefined') lucide.createIcons();
    }
    function closeTeamModal() {
      var m = document.getElementById('teamModal');
      m.classList.add('hidden');
      m.classList.remove('flex');
      var btn = document.querySelector('#tmEmailRow button');
      btn.innerHTML = '<i data-lucide="copy" class="size-4"></i>';
      if (typeof lucide !== 'undefined') lucide.createIcons();
    }
    function copyTeamEmail() {
      var email = document.getElementById('tmEmail').textContent;
      var btn = document.querySelector('#tmEmailRow button');
      var doCopy;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        doCopy = navigator.clipboard.writeText(email);
      } else {
        var ta = document.createElement('textarea');
        ta.value = email;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        doCopy = Promise.resolve();
      }
      doCopy.then(function() {
        btn.innerHTML = '<i data-lucide="check" class="size-4"></i>';
        if (typeof lucide !== 'undefined') lucide.createIcons();
        setTimeout(function() {
          btn.innerHTML = '<i data-lucide="copy" class="size-4"></i>';
          if (typeof lucide !== 'undefined') lucide.createIcons();
        }, 2000);
      });
    }
  </script>
</main>

<style>
  .js-groups-strip,
  .js-team-strip { cursor: grab; -webkit-user-select: none; user-select: none; }
  .js-groups-strip.is-dragging,
  .js-team-strip.is-dragging { cursor: grabbing; scroll-snap-type: none; }
  .js-groups-strip.is-dragging a,
  .js-groups-strip.is-dragging button,
  .js-groups-strip.is-dragging img,
  .js-team-strip.is-dragging a,
  .js-team-strip.is-dragging button,
  .js-team-strip.is-dragging img { pointer-events: none; }
</style>
<script>
  (function () {
    var strips = document.querySelectorAll('.js-groups-strip, .js-team-strip');
    if (!strips.length) return;
    strips.forEach(function (strip) { initDragScroll(strip); });

  function initDragScroll(strip) {
    var isDown = false, didDrag = false, startX = 0, startScroll = 0;
    var THRESHOLD = 5;

    strip.addEventListener('pointerdown', function (e) {
      if (e.pointerType === 'touch') return;
      if (e.button !== 0) return;
      isDown = true;
      didDrag = false;
      startX = e.clientX;
      startScroll = strip.scrollLeft;
      // Don't capture yet — capturing immediately prevents click events
      // from firing on child buttons/links when the user just clicks.
    });

    strip.addEventListener('pointermove', function (e) {
      if (!isDown) return;
      var dx = e.clientX - startX;
      if (!didDrag && Math.abs(dx) > THRESHOLD) {
        didDrag = true;
        strip.classList.add('is-dragging');
        try { strip.setPointerCapture(e.pointerId); } catch (_) {}
      }
      if (didDrag) {
        strip.scrollLeft = startScroll - dx;
        e.preventDefault();
      }
    });

    function endDrag(e) {
      if (!isDown) return;
      isDown = false;
      if (didDrag) {
        strip.classList.remove('is-dragging');
        // Swallow the synthetic click that follows the drag.
        var swallow = function (ev) {
          ev.preventDefault();
          ev.stopPropagation();
          window.removeEventListener('click', swallow, true);
        };
        window.addEventListener('click', swallow, true);
      }
      try { strip.releasePointerCapture(e.pointerId); } catch (_) {}
    }
    strip.addEventListener('pointerup', endDrag);
    strip.addEventListener('pointercancel', endDrag);
    strip.addEventListener('dragstart', function (e) { e.preventDefault(); });
  }
  })();
</script>
