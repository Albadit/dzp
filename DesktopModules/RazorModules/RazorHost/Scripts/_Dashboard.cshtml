@using DZP.CommunityAuth
@using DotNetNuke.Entities.Portals
@using System.Web
@using System.Data.SqlClient
@using System.Configuration
@using System.Web.Helpers
@using System.Linq
@*
    Dashboard ("Mijn communities").
    Owns all data fetching: membership list, optional admin top-up to "see
    all communities", banner-image lookup, and JSON serialization for the
    client. Section partials in Shared/Dashboard/ stay markup-only.
*@
@{
    var user            = Dnn.User;
    var adminRoleName   = PortalSettings.Current != null ? PortalSettings.Current.AdministratorRoleName : "Administrators";
    var isAdministrator = user != null && !string.IsNullOrEmpty(adminRoleName) && user.IsInRole(adminRoleName);
    var isSuperUser     = user != null && user.IsSuperUser;
    var isElevated      = isSuperUser || isAdministrator;

    var communities = (user != null && user.UserID > 0)
        ? CommunityAuth.GetUserCommunities(user)
        : new List<CommunityAuth.CommunityInfo>();

    /* ── Administrators get the same "see all communities" view as SuperUsers.
          The shared library only grants this to SuperUsers, so for
          Administrators we top up the list manually here. ── */
    if (isAdministrator && !isSuperUser) {
        var cs = ConfigurationManager.ConnectionStrings["SiteSqlServer"];
        if (cs != null && !string.IsNullOrEmpty(cs.ConnectionString)) {
            try {
                var seen = new HashSet<int>(communities.Select(c => c.Id));
                using (var conn = new SqlConnection(cs.ConnectionString)) {
                using (var cmd = new SqlCommand("SELECT Id, Slug, Name FROM Community ORDER BY Name", conn)) {
                    conn.Open();
                    using (var rdr = cmd.ExecuteReader()) {
                        while (rdr.Read()) {
                            var id = rdr.GetInt32(0);
                            if (seen.Contains(id)) { continue; }
                            communities.Add(new CommunityAuth.CommunityInfo {
                                Id   = id,
                                Slug = rdr.GetString(1),
                                Name = rdr.GetString(2)
                            });
                            seen.Add(id);
                        }
                    }
                }
                }
            } catch { /* fall back to membership-only list on error */ }
        }
    }

    /* Single community → skip dashboard and go straight to it (unless elevated). */
    if (communities.Count == 1 && !isElevated) {
        Response.Redirect("/" + communities[0].Slug + "/home", true);
        return;
    }

    /* ── Lookup ImageUrl for the listed communities ── */
    var imageUrls = new Dictionary<int, string>();
    if (communities.Count > 0) {
        var csImg = ConfigurationManager.ConnectionStrings["SiteSqlServer"];
        if (csImg != null && !string.IsNullOrEmpty(csImg.ConnectionString)) {
            try {
                using (var iconn = new SqlConnection(csImg.ConnectionString)) {
                using (var icmd = iconn.CreateCommand()) {
                    var isb = new System.Text.StringBuilder("SELECT Id, ImageUrl FROM Community WHERE Id IN (");
                    for (var ix = 0; ix < communities.Count; ix++) {
                        if (ix > 0) { isb.Append(","); }
                        isb.Append("@cid").Append(ix);
                        icmd.Parameters.AddWithValue("@cid" + ix, communities[ix].Id);
                    }
                    isb.Append(")");
                    icmd.CommandText = isb.ToString();
                    iconn.Open();
                    using (var ir = icmd.ExecuteReader()) {
                        while (ir.Read()) {
                            var iid = (int)ir["Id"];
                            var url = ir["ImageUrl"] as string;
                            if (!string.IsNullOrEmpty(url)) { imageUrls[iid] = url; }
                        }
                    }
                }
                }
            } catch { /* leave map empty → fall back to letter avatar client-side */ }
        }
    }

    /* ── Build serializable payload for client-side render ── */
    var communityPayload = communities.Select(c => new {
        id    = c.Id,
        slug  = c.Slug,
        name  = c.Name,
        image = imageUrls.ContainsKey(c.Id) ? imageUrls[c.Id] : null
    }).ToList();
    var communitiesJson = Json.Encode(communityPayload);

    /* ── Publish to PageData ── */
    PageData["isElevated"]      = isElevated;
    PageData["isSuperUser"]     = isSuperUser;
    PageData["communityCount"]  = communities.Count;
    PageData["communitiesJson"] = communitiesJson;
}

<section class="w-full max-w-full min-w-0 flex flex-col overflow-x-hidden">
    @RenderPage("Shared/Dashboard/_Header.cshtml")

    @if (communities.Count == 0) {
        @RenderPage("Shared/Dashboard/_EmptyState.cshtml")
    } else {
        @RenderPage("Shared/Dashboard/_SearchBar.cshtml")
        @RenderPage("Shared/Dashboard/_Grid.cshtml")
        @RenderPage("Shared/Dashboard/_Script.cshtml")
    }
</section>
