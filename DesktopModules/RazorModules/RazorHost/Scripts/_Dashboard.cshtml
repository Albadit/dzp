@using DZP.CommunityAuth
@using System.Web

@{
    var user = Dnn.User;
    var communities = (user != null && user.UserID > 0)
        ? CommunityAuth.GetUserCommunities(user)
        : new List<CommunityAuth.CommunityInfo>();

    // Single community → skip dashboard and go straight to it (unless superuser)
    if (communities.Count == 1 && (user == null || !user.IsSuperUser))
    {
        Response.Redirect("/" + communities[0].Slug + "/home", true);
        return;
    }
}

<section class="w-full flex flex-col">
    <h1 class="text-3xl font-bold text-foreground-900 mb-2">Mijn communities</h1>
    <p class="text-foreground-500 mb-8">
        @if (user != null && user.IsSuperUser)
        {
            <span>Je ziet alle communities (superuser).</span>
        }
        else
        {
            <span>Communities waar je lid van bent.</span>
        }
    </p>

    @if (communities.Count == 0)
    {
        <div class="bg-warning-50 border border-warning-200 rounded-xl px-5 py-4">
            <p class="text-sm text-warning-800">Je bent nog niet gekoppeld aan een community.</p>
        </div>
    }
    else
    {
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            @foreach (var c in communities)
            {
                <a href="/@c.Slug/home"
                    class="group block rounded-xl border border-divider bg-background p-5 shadow-card hover:shadow-card-hover hover:border-primary-300 transition">
                    <div class="flex items-center gap-4">
                        <div class="flex size-12 items-center justify-center rounded-lg bg-primary-50 text-primary font-bold text-lg shrink-0">
                            @(c.Name.Substring(0, 1).ToUpper())
                        </div>
                        <div class="min-w-0">
                            <h2 class="text-lg font-semibold text-foreground-900 group-hover:text-primary transition truncate">
                                @c.Name
                            </h2>
                            <p class="text-sm text-foreground-400 font-mono truncate">/@c.Slug</p>
                        </div>
                        <i data-lucide="chevron-right" class="size-5 text-foreground-300 group-hover:text-primary-400 ml-auto shrink-0 transition"></i>
                    </div>
                </a>
            }
        </div>
    }
</section>



