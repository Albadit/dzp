@*
    "Terug naar bedrijven" link at the bottom of the company detail page.
    Reads from PageData: communitySlug.
*@
@{
    var communitySlug = (string)PageData["communitySlug"];
}

<section class="w-full">
    <div class="w-full px-4 sm:px-6 lg:px-8 pb-8">
        <a href="/@communitySlug/companies"
           class="inline-flex items-center gap-2 text-sm font-medium text-foreground-500 hover:text-primary transition">
            <i data-lucide="arrow-left" class="size-4"></i>
            Terug naar bedrijven
        </a>
    </div>
</section>
