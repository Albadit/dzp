@*
    Embedded Google Maps panel for the company address.
    Renders nothing when `address` is empty.
    Reads from PageData: address (string).
*@
@{
    var address = (string)PageData["address"];
}

@if (!string.IsNullOrEmpty(address)) {
    <section class="w-full">
        <div class="w-full px-4 sm:px-6 lg:px-8 py-4 sm:py-6">
            <div class="flex flex-col gap-3 sm:gap-4">
                <h2 class="text-base font-semibold text-foreground-900">Locatie</h2>
                <div class="rounded-xl overflow-hidden border border-divider h-64 sm:h-80">
                    <iframe
                        class="w-full h-full border-0"
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        src="https://maps.google.com/maps?q=@System.Web.HttpUtility.UrlEncode(address)&output=embed&z=15"
                        allowfullscreen>
                    </iframe>
                </div>
            </div>
        </div>
    </section>
}
