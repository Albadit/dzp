@*
    Privacy & security feature pairs.
*@
@{
    var items = new[] {
        new { Icon = "user",         Title = "Privé of openbaar profiel",       Desc = "Jij kiest wat anderen van je zien." },
        new { Icon = "building",     Title = "Bedrijfsgegevens onder controle", Desc = "Elk bedrijf beslist zelf welke info zichtbaar is." },
        new { Icon = "lock",         Title = "Data blijft in het gebied",       Desc = "Content is strikt gescheiden per gebied - geen lekkage." },
        new { Icon = "shield-check", Title = "AVG-proof",                       Desc = "Privacy, logging en dataminimalisatie zitten ingebakken in het systeem." }
    };
}

<section id="privacy" aria-label="Privacy en veiligheid" class="w-full bg-content2 py-20 flex flex-col items-center">
    <div class="max-w-7xl w-full px-4 sm:px-6 lg:px-8 flex flex-col items-center gap-12">
        <div class="max-w-3xl flex flex-col items-center text-center">
            <h2 class="text-3xl font-bold text-foreground-900">
                Veilig &amp; privé by design
            </h2>
        </div>
        <div class="grid sm:grid-cols-2 gap-6 max-w-3xl w-full">
            @foreach (var pi in items) {
            <div class="flex items-start gap-4 bg-background rounded-xl p-5 shadow-card">
                <div class="w-10 h-10 rounded-lg bg-indigo-100 flex items-center justify-center shrink-0">
                    <i data-lucide="@pi.Icon" class="size-5 text-indigo-600"></i>
                </div>
                <div class="flex flex-col gap-1">
                    <h3 class="font-semibold text-foreground-900 text-sm">@pi.Title</h3>
                    <p class="text-xs text-foreground-500">@pi.Desc</p>
                </div>
            </div>
            }
        </div>
    </div>
</section>
