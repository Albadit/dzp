@*
    Six-feature grid (icon + title + description).
*@
@{
    var features = new[] {
        new { Icon = "layout-dashboard", Bg = "bg-indigo-100", HoverBg = "group-hover:bg-indigo-600", Color = "text-indigo-600", Title = "Dashboard",         Desc = "Open de app en zie direct wat er speelt - de laatste updates, pinned berichten en highlights." },
        new { Icon = "clock",            Bg = "bg-amber-100",  HoverBg = "group-hover:bg-amber-500",  Color = "text-amber-600",  Title = "Tijdlijn",          Desc = "Scroll door alle berichten op volgorde, of filter op type, tag en datum." },
        new { Icon = "newspaper",        Bg = "bg-blue-100",   HoverBg = "group-hover:bg-blue-600",   Color = "text-blue-600",   Title = "Nieuws & Events",   Desc = "Publiceer nieuws, plan events, stuur waarschuwingen - kies type, voeg tags en bijlagen toe." },
        new { Icon = "folder",           Bg = "bg-green-100",  HoverBg = "group-hover:bg-green-600",  Color = "text-green-600",  Title = "Documenten",        Desc = "Upload bestanden, organiseer in mappen. Iedereen met de juiste rol kan ze downloaden." },
        new { Icon = "building",         Bg = "bg-purple-100", HoverBg = "group-hover:bg-purple-600", Color = "text-purple-600", Title = "Bedrijfsprofielen", Desc = "Elk bedrijf in het gebied heeft een profiel met contactgegevens en gekoppelde medewerkers." },
        new { Icon = "settings",         Bg = "bg-rose-100",   HoverBg = "group-hover:bg-rose-600",   Color = "text-rose-600",   Title = "Beheerpaneel",      Desc = "Volledige controle: gebieden, rollen, tags en content moderatie vanuit één dashboard." }
    };
}

<section id="functionaliteiten" aria-label="Functionaliteiten" class="w-full bg-background py-20 flex flex-col items-center">
    <div class="max-w-7xl w-full px-4 sm:px-6 lg:px-8 flex flex-col gap-12">
        <div class="flex flex-col items-center text-center gap-4">
            <h2 class="text-3xl font-bold text-foreground-900">
                Dit zit er allemaal in
            </h2>
            <p class="text-foreground-500 max-w-2xl">Zes krachtige features die samen jouw gebiedscommunicatie compleet maken.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var f in features) {
            <div class="group rounded-xl border border-default-100 p-6 hover:border-indigo-200 hover:shadow-lg transition flex flex-col gap-4">
                <div class="w-12 h-12 rounded-xl @f.Bg flex items-center justify-center @f.HoverBg transition">
                    <i data-lucide="@f.Icon" class="size-6 @f.Color group-hover:text-white transition"></i>
                </div>
                <div class="flex flex-col gap-2">
                    <h3 class="font-semibold text-foreground-900">@f.Title</h3>
                    <p class="text-sm text-foreground-500">@f.Desc</p>
                </div>
            </div>
            }
        </div>
    </div>
</section>
