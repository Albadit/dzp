@*
    Reusable image-upload dropzone component.
    Mirrors the TableDZP dropzone markup contract so that dropzone.js
    (loaded from the TableDZP module) can wire it up automatically.

    Params (via PageData):
      name        (string, required) - hidden input name (also id if no `id` given)
      id          (string, optional) - hidden input id (defaults to `name`)
      value       (string, optional) - existing image URL to preview
      uploadUrl   (string, optional) - upload endpoint
                                       (default: TableDZP UploadImage handler)
      required    (bool,   optional)
      emptyText   (string, optional) - main drop label (default NL)
      emptyHint   (string, optional) - hint line under the main label
                                       (default derived from resolved max size)
      removeLabel (string, optional) - aria-label for the remove × button
      maxBytes    (long,   optional) - explicit cap; if omitted, uses the
                                       lowest of DNN Host.MaxUploadSize and
                                       httpRuntime.maxRequestLength.
      extraClass  (string, optional) - extra Tailwind classes on the dropzone
*@
@{
    var dzName       = PageData["name"]        as string;
    if (string.IsNullOrEmpty(dzName)) { dzName = "image"; }
    var dzId         = PageData["id"]          as string;
    if (string.IsNullOrEmpty(dzId)) { dzId = dzName; }
    var dzValue      = PageData["value"]       as string;
    if (dzValue == null) { dzValue = ""; }
    var dzUploadUrl  = PageData["uploadUrl"]   as string;
    var dzRequired   = PageData["required"] != null && (bool)PageData["required"];
    var dzEmptyText  = PageData["emptyText"]   as string;
    if (string.IsNullOrEmpty(dzEmptyText)) { dzEmptyText = "Sleep een afbeelding hierheen of klik om te uploaden"; }
    var dzRemoveLbl  = PageData["removeLabel"] as string;
    if (string.IsNullOrEmpty(dzRemoveLbl)) { dzRemoveLbl = "Afbeelding verwijderen"; }
    var dzExtra      = PageData["extraClass"]  as string;
    if (dzExtra == null) { dzExtra = ""; }

    /* Resolve max upload size from DNN Host setting + web.config httpRuntime */
    long dzMaxBytes;
    if (PageData["maxBytes"] != null) {
        dzMaxBytes = System.Convert.ToInt64(PageData["maxBytes"]);
    } else {
        long dzLimit = long.MaxValue;
        try {
            long hostMax = DotNetNuke.Common.Utilities.Config.GetMaxUploadSize();
            if (hostMax > 0 && hostMax < dzLimit) { dzLimit = hostMax; }
        }
        catch (System.Exception) { }
        try {
            System.Web.Configuration.HttpRuntimeSection dzSection =
                (System.Web.Configuration.HttpRuntimeSection)System.Web.Configuration.WebConfigurationManager.GetSection("system.web/httpRuntime");
            if (dzSection != null && dzSection.MaxRequestLength > 0) {
                long dzBytes = (long)dzSection.MaxRequestLength * 1024L;
                if (dzBytes < dzLimit) { dzLimit = dzBytes; }
            }
        }
        catch (System.Exception) { }
        if (dzLimit == long.MaxValue) { dzLimit = 10L * 1024L * 1024L; }
        dzMaxBytes = dzLimit;
    }

    double dzMb = dzMaxBytes / 1024.0 / 1024.0;
    string dzMaxLabel;
    if (dzMb >= 10) {
        dzMaxLabel = string.Format("{0:0} MB", dzMb);
    } else {
        dzMaxLabel = string.Format("{0:0.#} MB", dzMb);
    }

    var dzEmptyHint  = PageData["emptyHint"]   as string;
    if (dzEmptyHint == null) { dzEmptyHint = "PNG, JPG, GIF of WebP · max " + dzMaxLabel; }

    if (string.IsNullOrEmpty(dzUploadUrl)) {
        var appBase = (Request.ApplicationPath ?? "").TrimEnd('/');
        dzUploadUrl = appBase + "/DesktopModules/CommunityAuth/API/Upload/UploadImage";
    }

    var dzHas = !string.IsNullOrEmpty(dzValue);
}
<div class="dt-dropzone relative flex flex-col items-center justify-center gap-2 px-4 py-6 rounded-lg border-2 border-dashed border-divider hover:border-primary/60 bg-content2 cursor-pointer transition @dzExtra"
     tabindex="0" role="button"
     title="Maximale uploadgrootte: @dzMaxLabel"
     data-upload-url="@dzUploadUrl"
     data-max-bytes="@dzMaxBytes">
    <input type="hidden" name="@dzName" id="@dzId" value="@dzValue" class="dt-dz-value" @(dzRequired ? new System.Web.HtmlString("required=\"required\"") : new System.Web.HtmlString("")) />
    <input type="file" class="dt-dz-input sr-only" accept="image/png,image/jpeg,image/gif,image/webp" />

    <div class="dt-dz-empty flex flex-col items-center gap-1 text-foreground-500 text-sm pointer-events-none select-none @(dzHas ? "hidden" : "")">
        <i data-lucide="image-up" class="size-8"></i>
        <span>@dzEmptyText</span>
        @if (!string.IsNullOrEmpty(dzEmptyHint)) {
            <span class="text-xs text-foreground-400">@dzEmptyHint</span>
        }
    </div>

    <div class="dt-dz-preview relative w-full @(dzHas ? "" : "hidden")">
        <img class="dt-dz-preview-img w-full max-h-48 object-contain rounded-md" alt=""
             @(dzHas ? new System.Web.HtmlString("src=\"" + System.Web.HttpUtility.HtmlAttributeEncode(dzValue) + "\"") : null) />
        <button type="button" class="dt-dz-remove absolute top-2 right-2 inline-flex items-center justify-center size-8 rounded-full bg-content1 border border-divider shadow hover:bg-danger-50 hover:text-danger transition" aria-label="@dzRemoveLbl">
            <i data-lucide="x" class="size-4"></i>
        </button>
    </div>

    <div class="dt-dz-progress hidden absolute inset-0 flex items-center justify-center bg-overlay/40 rounded-lg text-sm text-foreground-700">
        <i data-lucide="loader-2" class="size-5 animate-spin"></i>
    </div>
</div>
