@*
    Shared "geen toegang" panel.
    PageData:
      compact (bool, optional)   — true for inline mini-warning, false (default) for hero panel
      message (string, optional) — body text (default depends on compact mode)
      backHref (string, optional) — only used in hero mode; renders a "Terug" link
      backLabel (string, optional) — link label for backHref (default "Terug")
*@
@{
    var compact   = PageData["compact"]   != null && (bool)PageData["compact"];
    var message   = (PageData["message"]   as string) ?? "";
    var backHref  = (PageData["backHref"]  as string) ?? "";
    var backLabel = (PageData["backLabel"] as string) ?? "Terug";
}
@if (compact) {
    <div class="p-4 rounded-xl border border-warning/30 bg-warning/5 text-sm text-foreground-700">
        @(string.IsNullOrEmpty(message) ? "Je hebt geen rechten om deze pagina te bewerken." : message)
    </div>
} else {
    <section class="w-full">
        <div class="w-full px-4 sm:px-6 lg:px-8 py-12">
            <div class="flex flex-col items-center gap-4 text-center">
                <div class="flex items-center justify-center size-16 rounded-full bg-danger-100">
                    <i data-lucide="shield-x" class="size-8 text-danger"></i>
                </div>
                <h1 class="text-xl font-bold text-foreground-900">Geen toegang</h1>
                <p class="text-sm text-foreground-500 max-w-md">@(string.IsNullOrEmpty(message) ? "Je hebt geen rechten om deze pagina te bewerken." : message)</p>
                @if (!string.IsNullOrEmpty(backHref)) {
                    <a href="@backHref" class="mt-2 inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline">
                        <i data-lucide="arrow-left" class="size-4"></i>
                        @backLabel
                    </a>
                }
            </div>
        </div>
    </section>
}
