@* ═══════════════════════════════════════════════════════════════════
    Reusable DataTable Component
    ─────────────────────────────
    Usage:  @RenderPage("Shared/_DataTable.cshtml",
                new DataTableConfig { ... })

    Features:
    • Dynamic columns from config        • CRUD (create / edit / delete)
    • Multi-row selection + bulk delete   • Sorting, filtering, search
    • Pagination (server-rendered)        • Inline editing
    • Form validation                     • Multiple cell types
    • Loading / empty / error states      • Responsive Tailwind UI
═══════════════════════════════════════════════════════════════════ *@

@using System.Configuration
@using System.Data.SqlClient
@using System.Web
@using System.Text.RegularExpressions
@using DnnDev.Routing.Models

@functions {
    static string SafeId(string raw) {
        return Regex.Replace(raw ?? "", @"[^a-zA-Z0-9_-]", "");
    }

    static string ConnStr() {
        return ConfigurationManager.ConnectionStrings["SiteSqlServer"]?.ConnectionString ?? "";
    }

    static bool IsValidColumnName(string name) {
        return !string.IsNullOrEmpty(name) && Regex.IsMatch(name, @"^[A-Za-z_][A-Za-z0-9_]*$");
    }

    static bool IsValidTableName(string name) {
        return !string.IsNullOrEmpty(name) && Regex.IsMatch(name, @"^[A-Za-z_][A-Za-z0-9_]*$");
    }
}

@{
    // ── Read config from PageData ─────────────────────────────────
    var cfg = PageData["config"] as DataTableConfig;
    if (cfg == null) {
        <div class="p-4 text-red-600 bg-red-50 rounded-lg">DataTable: missing config.</div>
        return;
    }

    if (!IsValidTableName(cfg.DbTable)) {
        <div class="p-4 text-red-600 bg-red-50 rounded-lg">DataTable: invalid table name.</div>
        return;
    }
    foreach (var c in cfg.Columns) {
        if (!IsValidColumnName(c.Key)) {
            <div class="p-4 text-red-600 bg-red-50 rounded-lg">DataTable: invalid column name "@c.Key".</div>
            return;
        }
    }
    if (!IsValidColumnName(cfg.PrimaryKey)) {
        <div class="p-4 text-red-600 bg-red-50 rounded-lg">DataTable: invalid primary key.</div>
        return;
    }

    var tid = SafeId(cfg.TableId);
    var connStr = ConnStr();
    var errorMsg = "";
    var successMsg = "";
    var rows = new List<Dictionary<string, object>>();
    var editableColumns = cfg.Columns.Where(c => c.Type != "readonly" && c.Type != "hidden").ToArray();
    var visibleColumns  = cfg.Columns.Where(c => c.Type != "hidden").ToArray();

    // ── Handle POST actions ───────────────────────────────────────
    if (IsPost && Request["_dt_id"] == tid) {
        var action = Request["_dt_action"] ?? "";
        try {
            using (var conn = new SqlConnection(connStr)) {
                conn.Open();

                if (action == "create") {
                    var cols = new List<string>();
                    var pars = new List<string>();
                    var cmd = conn.CreateCommand();
                    int pi = 0;
                    foreach (var col in editableColumns) {
                        var val = (Request["_dt_new_" + col.Key] ?? "").Trim();
                        if (col.Required && string.IsNullOrEmpty(val)) {
                            errorMsg = col.Label + " is verplicht.";
                            break;
                        }
                        cols.Add("[" + col.Key + "]");
                        pars.Add("@p" + pi);
                        cmd.Parameters.AddWithValue("@p" + pi, (object)val ?? DBNull.Value);
                        pi++;
                    }
                    if (string.IsNullOrEmpty(errorMsg)) {
                        cmd.CommandText = "INSERT INTO [" + cfg.DbTable + "] (" + string.Join(",", cols) + ") VALUES (" + string.Join(",", pars) + ")";
                        cmd.ExecuteNonQuery();
                        successMsg = "Rij aangemaakt.";
                    }
                }
                else if (action == "update") {
                    var pkVal = Request["_dt_edit_pk"] ?? "";
                    if (!string.IsNullOrEmpty(pkVal)) {
                        var sets = new List<string>();
                        var cmd = conn.CreateCommand();
                        int pi = 0;
                        foreach (var col in editableColumns) {
                            var val = (Request["_dt_edit_" + col.Key] ?? "").Trim();
                            if (col.Required && string.IsNullOrEmpty(val)) {
                                errorMsg = col.Label + " is verplicht.";
                                break;
                            }
                            sets.Add("[" + col.Key + "] = @p" + pi);
                            cmd.Parameters.AddWithValue("@p" + pi, (object)val ?? DBNull.Value);
                            pi++;
                        }
                        if (string.IsNullOrEmpty(errorMsg)) {
                            cmd.Parameters.AddWithValue("@pk", pkVal);
                            cmd.CommandText = "UPDATE [" + cfg.DbTable + "] SET " + string.Join(",", sets) + " WHERE [" + cfg.PrimaryKey + "] = @pk";
                            cmd.ExecuteNonQuery();
                            successMsg = "Rij bijgewerkt.";
                        }
                    }
                }
                else if (action == "delete") {
                    var pkVal = Request["_dt_del_pk"] ?? "";
                    if (!string.IsNullOrEmpty(pkVal)) {
                        var cmd = conn.CreateCommand();
                        cmd.Parameters.AddWithValue("@pk", pkVal);
                        cmd.CommandText = "DELETE FROM [" + cfg.DbTable + "] WHERE [" + cfg.PrimaryKey + "] = @pk";
                        cmd.ExecuteNonQuery();
                        successMsg = "Rij verwijderd.";
                    }
                }
                else if (action == "bulkdelete") {
                    var ids = (Request["_dt_bulk_ids"] ?? "").Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries);
                    if (ids.Length > 0) {
                        var cmd = conn.CreateCommand();
                        var placeholders = new List<string>();
                        for (int i = 0; i < ids.Length; i++) {
                            placeholders.Add("@id" + i);
                            cmd.Parameters.AddWithValue("@id" + i, ids[i].Trim());
                        }
                        cmd.CommandText = "DELETE FROM [" + cfg.DbTable + "] WHERE [" + cfg.PrimaryKey + "] IN (" + string.Join(",", placeholders) + ")";
                        var count = cmd.ExecuteNonQuery();
                        successMsg = count + " rij(en) verwijderd.";
                    }
                }
            }
        } catch (Exception ex) {
            errorMsg = "Fout: " + ex.Message;
        }
    }

    // ── Load data ─────────────────────────────────────────────────
    var isLoading = false;
    try {
        if (!string.IsNullOrEmpty(connStr)) {
            isLoading = true;
            var colNames = string.Join(",", cfg.Columns.Select(c => "[" + c.Key + "]").Concat(new[] { "[" + cfg.PrimaryKey + "]" }).Distinct());
            using (var conn = new SqlConnection(connStr)) {
                conn.Open();
                using (var cmd = conn.CreateCommand()) {
                    cmd.CommandText = "SELECT " + colNames + " FROM [" + cfg.DbTable + "] ORDER BY [" + cfg.PrimaryKey + "]";
                    using (var reader = cmd.ExecuteReader()) {
                        while (reader.Read()) {
                            var row = new Dictionary<string, object>();
                            for (int i = 0; i < reader.FieldCount; i++) {
                                row[reader.GetName(i)] = reader.IsDBNull(i) ? null : reader.GetValue(i);
                            }
                            rows.Add(row);
                        }
                    }
                }
            }
            isLoading = false;
        } else {
            errorMsg = "Geen databaseverbinding beschikbaar.";
        }
    } catch (Exception ex) {
        isLoading = false;
        errorMsg = "Data laden mislukt: " + ex.Message;
    }

    var totalRows = rows.Count;
}

<!-- ═══════════════════════════════════════════════════════════════ -->
<!--  DataTable: @tid                                               -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<div id="@tid" class="w-full" data-page-size="@cfg.PageSize" data-total="@totalRows">

    <!-- Title bar -->
    @if (!string.IsNullOrEmpty(cfg.Title)) {
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-gray-900">@cfg.Title</h2>
        </div>
    }

    <!-- Alerts -->
    @if (!string.IsNullOrEmpty(successMsg)) {
        <div class="mb-4 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800 dt-alert" data-auto-dismiss="4000">
            <i data-lucide="check-circle-2" class="size-4 shrink-0"></i> @successMsg
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMsg)) {
        <div class="mb-4 flex items-center gap-2 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800 dt-alert">
            <i data-lucide="alert-circle" class="size-4 shrink-0"></i> @errorMsg
        </div>
    }

    <!-- Toolbar: search + add + bulk actions -->
    <div class="flex flex-wrap items-center gap-3 mb-4">
        <div class="relative flex-1 min-w-[200px] max-w-sm">
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-gray-400 pointer-events-none"></i>
            <input type="text" placeholder="Zoeken…"
                   class="dt-search w-full pl-9 pr-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                   data-target="@tid" />
        </div>

        @if (cfg.AllowCreate) {
            <button type="button" class="dt-btn-add inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition" data-target="@tid">
                <i data-lucide="plus" class="size-4"></i> Nieuw
            </button>
        }

        @if (cfg.AllowBulkDelete) {
            <button type="button" class="dt-btn-bulk-del hidden items-center gap-1.5 px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 transition" data-target="@tid">
                <i data-lucide="trash-2" class="size-4"></i> <span class="dt-bulk-count"></span> verwijderen
            </button>
        }
    </div>

    <!-- Create row form (hidden by default) -->
    @if (cfg.AllowCreate) {
        <form method="post" class="dt-create-form hidden mb-4 bg-indigo-50/50 border border-indigo-200 rounded-xl p-5" data-target="@tid">
            <input type="hidden" name="_dt_id" value="@tid" />
            <input type="hidden" name="_dt_action" value="create" />
            <h3 class="text-sm font-semibold text-indigo-900 mb-3">Nieuw item toevoegen</h3>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                @foreach (var col in editableColumns) {
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">
                            @col.Label @if (col.Required) { <span class="text-red-500">*</span> }
                        </label>
                        <input type="@(col.Type == "slug" ? "text" : col.Type)"
                               name="_dt_new_@col.Key"
                               placeholder="@(col.Placeholder ?? col.Label)"
                               @if (col.Required) { <text>required</text> }
                               @if (col.MaxLength.HasValue) { <text>maxlength="@col.MaxLength"</text> }
                               @if (!string.IsNullOrEmpty(col.Pattern)) { <text>pattern="@col.Pattern" title="@(col.PatternMessage ?? "")"</text> }
                               class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none" />
                    </div>
                }
            </div>
            <div class="flex gap-2 mt-4">
                <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition">Opslaan</button>
                <button type="button" class="dt-btn-cancel px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition" data-target="@tid">Annuleren</button>
            </div>
        </form>
    }

    <!-- Table -->
    <div class="overflow-x-auto rounded-xl border border-gray-200 bg-white shadow-sm">
        <table class="dt-table min-w-full text-sm" data-id="@tid">
            <thead class="bg-gray-50">
                <tr>
                    @if (cfg.AllowBulkDelete) {
                        <th class="w-10 px-3 py-3">
                            <input type="checkbox" class="dt-check-all size-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer" data-target="@tid" />
                        </th>
                    }
                    @foreach (var col in visibleColumns) {
                        <th class="px-4 py-3 text-left font-semibold text-gray-700 select-none @(col.Sortable ? "cursor-pointer hover:text-indigo-600 dt-sort" : "")"
                            @if (col.Sortable) { <text>data-col="@col.Key" data-dir="" data-target="@tid"</text> }>
                            <span class="inline-flex items-center gap-1">
                                @col.Label
                                @if (col.Sortable) { <i data-lucide="arrow-up-down" class="size-3.5 opacity-40"></i> }
                            </span>
                        </th>
                    }
                    @if (cfg.AllowEdit || cfg.AllowDelete) {
                        <th class="w-24 px-4 py-3 text-right font-semibold text-gray-700">Acties</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (rows.Count == 0 && string.IsNullOrEmpty(errorMsg)) {
                    <tr class="dt-row-empty">
                        <td colspan="@(visibleColumns.Length + (cfg.AllowBulkDelete ? 1 : 0) + (cfg.AllowEdit || cfg.AllowDelete ? 1 : 0))"
                            class="px-4 py-12 text-center text-gray-400">
                            <i data-lucide="inbox" class="size-8 mx-auto mb-2 opacity-40"></i>
                            <p>Geen gegevens gevonden.</p>
                        </td>
                    </tr>
                }
                @foreach (var row in rows) {
                    var pkVal = row.ContainsKey(cfg.PrimaryKey) ? row[cfg.PrimaryKey]?.ToString() : "";
                    <tr class="dt-row border-t border-gray-100 hover:bg-gray-50/50 transition-colors" data-pk="@pkVal">
                        @if (cfg.AllowBulkDelete) {
                            <td class="px-3 py-3">
                                <input type="checkbox" class="dt-check-row size-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer" value="@pkVal" data-target="@tid" />
                            </td>
                        }
                        @foreach (var col in visibleColumns) {
                            var cellVal = row.ContainsKey(col.Key) ? (row[col.Key]?.ToString() ?? "") : "";
                            <td class="px-4 py-3 dt-cell" data-col="@col.Key"
                                @if (col.Type == "url") { <text>title="@cellVal"</text> }>
                                @if (col.Type == "url" && !string.IsNullOrEmpty(cellVal)) {
                                    <a href="@cellVal" target="_blank" class="text-indigo-600 hover:underline truncate block max-w-[200px]">@cellVal</a>
                                } else {
                                    <span class="dt-cell-text">@cellVal</span>
                                }
                            </td>
                        }
                        @if (cfg.AllowEdit || cfg.AllowDelete) {
                            <td class="px-4 py-3 text-right">
                                <div class="inline-flex items-center gap-1">
                                    @if (cfg.AllowEdit) {
                                        <button type="button" class="dt-btn-edit p-1.5 rounded-md text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 transition" data-pk="@pkVal" data-target="@tid" title="Bewerken">
                                            <i data-lucide="pencil" class="size-4"></i>
                                        </button>
                                    }
                                    @if (cfg.AllowDelete) {
                                        <button type="button" class="dt-btn-del p-1.5 rounded-md text-gray-400 hover:text-red-600 hover:bg-red-50 transition" data-pk="@pkVal" data-target="@tid" title="Verwijderen">
                                            <i data-lucide="trash-2" class="size-4"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex flex-wrap items-center justify-between gap-3 mt-4 text-sm text-gray-600">
        <span class="dt-page-info"></span>
        <div class="inline-flex items-center gap-1 dt-pagination"></div>
    </div>

    <!-- Hidden forms for edit / delete / bulk delete -->
    @if (cfg.AllowEdit) {
        <form method="post" class="dt-edit-form hidden">
            <input type="hidden" name="_dt_id" value="@tid" />
            <input type="hidden" name="_dt_action" value="update" />
            <input type="hidden" name="_dt_edit_pk" class="dt-edit-pk" />
            @foreach (var col in editableColumns) {
                <input type="hidden" name="_dt_edit_@col.Key" class="dt-edit-@SafeId(col.Key)" />
            }
        </form>
    }
    @if (cfg.AllowDelete) {
        <form method="post" class="dt-del-form hidden">
            <input type="hidden" name="_dt_id" value="@tid" />
            <input type="hidden" name="_dt_action" value="delete" />
            <input type="hidden" name="_dt_del_pk" class="dt-del-pk" />
        </form>
    }
    @if (cfg.AllowBulkDelete) {
        <form method="post" class="dt-bulk-form hidden">
            <input type="hidden" name="_dt_id" value="@tid" />
            <input type="hidden" name="_dt_action" value="bulkdelete" />
            <input type="hidden" name="_dt_bulk_ids" class="dt-bulk-ids" />
        </form>
    }
</div>

<!-- Inline edit modal -->
<div id="@(tid)-modal" class="dt-modal hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/40">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4 overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
            <h3 class="font-semibold text-gray-900">Rij bewerken</h3>
            <button type="button" class="dt-modal-close p-1 rounded-md hover:bg-gray-100 transition text-gray-400 hover:text-gray-600" data-target="@tid">
                <i data-lucide="x" class="size-5"></i>
            </button>
        </div>
        <div class="px-5 py-4 space-y-4">
            @foreach (var col in editableColumns) {
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">
                        @col.Label @if (col.Required) { <span class="text-red-500">*</span> }
                    </label>
                    <input type="@(col.Type == "slug" ? "text" : col.Type)"
                           class="dt-modal-input w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                           data-col="@col.Key"
                           @if (col.Required) { <text>required</text> }
                           @if (col.MaxLength.HasValue) { <text>maxlength="@col.MaxLength"</text> }
                           @if (!string.IsNullOrEmpty(col.Pattern)) { <text>pattern="@col.Pattern" title="@(col.PatternMessage ?? "")"</text> } />
                </div>
            }
        </div>
        <div class="flex justify-end gap-2 px-5 py-4 border-t border-gray-200 bg-gray-50">
            <button type="button" class="dt-modal-close px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition" data-target="@tid">Annuleren</button>
            <button type="button" class="dt-modal-save px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition" data-target="@tid">Opslaan</button>
        </div>
    </div>
</div>

<!-- Delete confirm modal -->
<div id="@(tid)-del-modal" class="dt-del-modal hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/40">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-sm mx-4 overflow-hidden">
        <div class="px-5 py-6 text-center">
            <div class="mx-auto flex size-12 items-center justify-center rounded-full bg-red-100 mb-4">
                <i data-lucide="alert-triangle" class="size-6 text-red-600"></i>
            </div>
            <h3 class="font-semibold text-gray-900 mb-1">Weet je het zeker?</h3>
            <p class="text-sm text-gray-500 dt-del-msg">Dit item wordt permanent verwijderd.</p>
        </div>
        <div class="flex gap-2 px-5 py-4 border-t border-gray-200 bg-gray-50 justify-end">
            <button type="button" class="dt-del-cancel px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition" data-target="@tid">Annuleren</button>
            <button type="button" class="dt-del-confirm px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 transition" data-target="@tid">Verwijderen</button>
        </div>
    </div>
</div>

<script>
(function() {
    var tid = '@tid';
    var root = document.getElementById(tid);
    if (!root) return;

    var pageSize = parseInt(root.dataset.pageSize) || 10;
    var currentPage = 1;
    var sortCol = null, sortDir = 'asc';

    // ── Selectors ────────────────────────────────────────────
    var table    = root.querySelector('.dt-table');
    var allRows  = Array.from(table.querySelectorAll('tbody .dt-row'));
    var filtered = allRows.slice();

    var searchInput  = root.querySelector('.dt-search');
    var checkAll     = root.querySelector('.dt-check-all');
    var bulkBtn      = root.querySelector('.dt-btn-bulk-del');
    var createForm   = root.querySelector('.dt-create-form');
    var addBtn       = root.querySelector('.dt-btn-add');
    var cancelBtn    = root.querySelector('.dt-btn-cancel');
    var pageInfo     = root.querySelector('.dt-page-info');
    var pagination   = root.querySelector('.dt-pagination');

    var modal      = document.getElementById(tid + '-modal');
    var delModal  = document.getElementById(tid + '-del-modal');
    var editPk = null;
    var delMode = null; // 'single' or 'bulk'
    var delPkVal = null;

    // ── Search ───────────────────────────────────────────────
    if (searchInput) {
        searchInput.addEventListener('input', function() {
            var q = this.value.toLowerCase();
            filtered = allRows.filter(function(r) {
                return r.textContent.toLowerCase().indexOf(q) >= 0;
            });
            currentPage = 1; applySortAndRender();
        });
    }

    // ── Sorting ──────────────────────────────────────────────
    root.querySelectorAll('.dt-sort').forEach(function(th) {
        th.addEventListener('click', function() {
            var col = this.dataset.col;
            if (sortCol === col) { sortDir = sortDir === 'asc' ? 'desc' : 'asc'; }
            else { sortCol = col; sortDir = 'asc'; }
            // Reset sort icons
            root.querySelectorAll('.dt-sort').forEach(function(s) { s.dataset.dir = ''; });
            this.dataset.dir = sortDir;
            currentPage = 1; applySortAndRender();
        });
    });

    function applySortAndRender() {
        if (sortCol) {
            filtered.sort(function(a, b) {
                var aVal = getCellText(a, sortCol).toLowerCase();
                var bVal = getCellText(b, sortCol).toLowerCase();
                var cmp = aVal.localeCompare(bVal, undefined, { numeric: true });
                return sortDir === 'desc' ? -cmp : cmp;
            });
        }
        render();
    }

    function getCellText(row, col) {
        var cell = row.querySelector('[data-col="' + col + '"]');
        return cell ? (cell.textContent || '').trim() : '';
    }

    // ── Pagination + render ──────────────────────────────────
    function render() {
        var total = filtered.length;
        var pages = Math.max(1, Math.ceil(total / pageSize));
        if (currentPage > pages) currentPage = pages;
        var start = (currentPage - 1) * pageSize;
        var end   = start + pageSize;

        // Hide all, show filtered page
        allRows.forEach(function(r) { r.style.display = 'none'; });
        for (var i = start; i < Math.min(end, total); i++) {
            filtered[i].style.display = '';
        }

        // Empty row
        var emptyRow = table.querySelector('.dt-row-empty');
        if (emptyRow) emptyRow.style.display = total > 0 ? 'none' : '';

        // Info
        if (pageInfo) {
            pageInfo.textContent = total === 0
                ? ''
                : (start + 1) + '–' + Math.min(end, total) + ' van ' + total;
        }

        // Pagination buttons
        if (pagination) {
            pagination.innerHTML = '';
            if (pages <= 1) return;
            addPageBtn('«', 1, currentPage === 1);
            addPageBtn('‹', currentPage - 1, currentPage === 1);
            for (var p = 1; p <= pages; p++) {
                addPageBtn(p, p, false, p === currentPage);
            }
            addPageBtn('›', currentPage + 1, currentPage === pages);
            addPageBtn('»', pages, currentPage === pages);
        }

        updateBulkState();
    }

    function addPageBtn(label, page, disabled, active) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = label;
        btn.className = 'px-3 py-1.5 text-sm rounded-md transition ' +
            (active ? 'bg-indigo-600 text-white' : 'text-gray-600 hover:bg-gray-100') +
            (disabled ? ' opacity-30 pointer-events-none' : ' cursor-pointer');
        btn.addEventListener('click', function() { currentPage = page; render(); });
        pagination.appendChild(btn);
    }

    // ── Select all / row checkboxes ──────────────────────────
    if (checkAll) {
        checkAll.addEventListener('change', function() {
            var checked = this.checked;
            getVisibleCheckboxes().forEach(function(cb) { cb.checked = checked; });
            updateBulkState();
        });
    }
    root.addEventListener('change', function(e) {
        if (e.target.classList.contains('dt-check-row')) updateBulkState();
    });

    function getVisibleCheckboxes() {
        return Array.from(root.querySelectorAll('.dt-check-row')).filter(function(cb) {
            return cb.closest('.dt-row').style.display !== 'none';
        });
    }
    function getSelectedIds() {
        return getVisibleCheckboxes().filter(function(cb) { return cb.checked; }).map(function(cb) { return cb.value; });
    }
    function updateBulkState() {
        if (!bulkBtn) return;
        var ids = getSelectedIds();
        if (ids.length > 0) {
            bulkBtn.classList.remove('hidden');
            bulkBtn.classList.add('inline-flex');
            bulkBtn.querySelector('.dt-bulk-count').textContent = ids.length;
        } else {
            bulkBtn.classList.add('hidden');
            bulkBtn.classList.remove('inline-flex');
        }
    }

    // ── Add / Cancel ─────────────────────────────────────────
    if (addBtn) addBtn.addEventListener('click', function() {
        createForm.classList.remove('hidden');
        createForm.querySelector('input[type="text"],input[type="email"],input[type="number"]')?.focus();
    });
    if (cancelBtn) cancelBtn.addEventListener('click', function() {
        createForm.classList.add('hidden');
        createForm.reset();
    });

    // ── Edit (opens modal) ───────────────────────────────────
    root.addEventListener('click', function(e) {
        var btn = e.target.closest('.dt-btn-edit');
        if (!btn) return;
        editPk = btn.dataset.pk;
        var row = btn.closest('.dt-row');
        modal.querySelectorAll('.dt-modal-input').forEach(function(inp) {
            var col = inp.dataset.col;
            inp.value = getCellText(row, col);
        });
        modal.classList.remove('hidden');
    });
    // Save edit
    if (modal) modal.querySelector('.dt-modal-save').addEventListener('click', function() {
        var valid = true;
        modal.querySelectorAll('.dt-modal-input').forEach(function(inp) {
            if (!inp.checkValidity()) { inp.reportValidity(); valid = false; }
        });
        if (!valid) return;

        var form = root.querySelector('.dt-edit-form');
        form.querySelector('.dt-edit-pk').value = editPk;
        modal.querySelectorAll('.dt-modal-input').forEach(function(inp) {
            var field = form.querySelector('.dt-edit-' + inp.dataset.col);
            if (field) field.value = inp.value;
        });
        form.submit();
    });
    // Close edit modal
    document.querySelectorAll('.dt-modal-close[data-target="' + tid + '"]').forEach(function(btn) {
        btn.addEventListener('click', function() { modal.classList.add('hidden'); });
    });

    // ── Delete (confirm modal) ───────────────────────────────
    root.addEventListener('click', function(e) {
        var btn = e.target.closest('.dt-btn-del');
        if (!btn) return;
        delMode = 'single'; delPkVal = btn.dataset.pk;
        delModal.querySelector('.dt-del-msg').textContent = 'Dit item wordt permanent verwijderd.';
        delModal.classList.remove('hidden');
    });
    // Bulk delete button
    if (bulkBtn) bulkBtn.addEventListener('click', function() {
        var ids = getSelectedIds();
        if (ids.length === 0) return;
        delMode = 'bulk'; delPkVal = ids.join(',');
        delModal.querySelector('.dt-del-msg').textContent = ids.length + ' item(s) worden permanent verwijderd.';
        delModal.classList.remove('hidden');
    });
    // Confirm delete
    if (delModal) {
        delModal.querySelector('.dt-del-confirm').addEventListener('click', function() {
            if (delMode === 'single') {
                var form = root.querySelector('.dt-del-form');
                form.querySelector('.dt-del-pk').value = delPkVal;
                form.submit();
            } else {
                var form = root.querySelector('.dt-bulk-form');
                form.querySelector('.dt-bulk-ids').value = delPkVal;
                form.submit();
            }
        });
        delModal.querySelector('.dt-del-cancel').addEventListener('click', function() {
            delModal.classList.add('hidden');
        });
    }

    // ── Auto-dismiss success alerts ──────────────────────────
    root.querySelectorAll('.dt-alert[data-auto-dismiss]').forEach(function(el) {
        setTimeout(function() {
            el.style.transition = 'opacity 0.3s';
            el.style.opacity = '0';
            setTimeout(function() { el.remove(); }, 300);
        }, parseInt(el.dataset.autoDismiss));
    });

    // ── Init ─────────────────────────────────────────────────
    render();

    // Re-init lucide icons in this component
    if (window.lucide) lucide.createIcons();
})();
</script>
