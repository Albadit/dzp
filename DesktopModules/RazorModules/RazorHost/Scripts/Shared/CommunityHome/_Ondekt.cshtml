@*
    "Ondekt" — quick-links grid for the community home.
    Reads visible discovery buttons + communitySlug from PageData.
    The button list is owned by _CommunityHome.cshtml and sourced
    from CommunityDiscoverButton/CommunityDiscoverCategory.
*@
@{
    var communitySlug = (string)PageData["communitySlug"];
    var discoverButtons = PageData["discoverButtons"] as List<Dictionary<string, object>>
                          ?? new List<Dictionary<string, object>>();

    Func<string, string> normalizeUrl = (raw) => {
        if (string.IsNullOrWhiteSpace(raw)) return "";
        var s = raw.Trim();
        if (s.StartsWith("/") || s.StartsWith("#") || s.StartsWith("?")) return s;
        if (s.StartsWith("mailto:", StringComparison.OrdinalIgnoreCase)
         || s.StartsWith("tel:",    StringComparison.OrdinalIgnoreCase)
         || s.StartsWith("sms:",    StringComparison.OrdinalIgnoreCase)) return s;
        var schemeIdx = s.IndexOf("://", StringComparison.Ordinal);
        if (schemeIdx > 0 && schemeIdx <= 10) return s;
        return "https://" + s.TrimStart('/');
    };
}

<section class="w-full flex flex-col gap-4 sm:gap-6">
        <div class="flex items-center justify-between">
            <h2 class="text-base font-semibold text-foreground-900">Ondekt</h2>
            <a href="/@communitySlug/discover" class="text-sm font-medium text-foreground-500 hover:text-primary transition flex items-center gap-1">
                Ga naar <i data-lucide="arrow-right" class="size-3.5"></i>
            </a>
        </div>
        @if (discoverButtons.Count > 0) {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 sm:gap-3">
                @foreach (var b in discoverButtons) {
                    var bLabel = (string)b["Label"];
                    var bIcon  = (string)b["Icon"];
                    var bUrl   = normalizeUrl((string)b["Url"]);
                    <a href="@bUrl" class="group flex items-center gap-3 px-3 py-2.5 sm:px-4 sm:py-3 rounded-lg bg-content2 text-xs sm:text-sm font-medium text-foreground-700 hover:text-primary hover:bg-primary/5 transition">
                        @if (!string.IsNullOrEmpty(bIcon)) {
                            <i data-lucide="@bIcon" class="size-4 text-foreground-500 group-hover:text-primary transition shrink-0"></i>
                        }
                        <span class="truncate flex-1">@bLabel</span>
                        <i data-lucide="chevron-right" class="size-3.5 text-foreground-300 group-hover:text-primary group-hover:translate-x-0.5 transition shrink-0"></i>
                    </a>
                }
            </div>
        } else {
            <div class="flex flex-col items-center gap-3 py-8 text-center">
                <p class="text-sm text-foreground-400">Er zijn nog geen ontdek-links voor deze community.</p>
            </div>
        }
</section>

