@*
    "Ondekt" — quick-links grid for the community home.
    Owns its link list (it's purely UI/IA configuration, not user data).
    Reads from PageData: communitySlug.
*@
@{
    var communitySlug = (string)PageData["communitySlug"];
    var communityName = (string)PageData["communityName"];

    var links = new[] {
        new { Label = "VISIT HW",                       Icon = "map-pin",     Url = "/" + communitySlug + "/visit" },
        new { Label = "Cadeaubon " + communityName,     Icon = "gift",        Url = "/" + communitySlug + "/cadeaubon" },
        new { Label = "Gemeente " + communityName,      Icon = "landmark",    Url = "/" + communitySlug + "/gemeente" },
        new { Label = "Ondernemend Hoeksche Waard",     Icon = "briefcase",   Url = "/" + communitySlug + "/ondernemend" },
        new { Label = "Duurzaamheid",                   Icon = "leaf",        Url = "/" + communitySlug + "/duurzaamheid" },
        new { Label = "Ondernemersplein",               Icon = "store",       Url = "/" + communitySlug + "/ondernemersplein" },
        new { Label = "Mijn (notificatie)instellingen", Icon = "bell",        Url = "/settings" },
        new { Label = "Q&A",                            Icon = "help-circle", Url = "/" + communitySlug + "/qa" },
        new { Label = "Tijdlijn",                       Icon = "clock",       Url = "/" + communitySlug + "/timeline" },
        new { Label = "Evenementen",                    Icon = "calendar",    Url = "/" + communitySlug + "/evenementen" },
        new { Label = "Leden",                          Icon = "users",       Url = "/" + communitySlug + "/leden" },
        new { Label = "Bestanden",                      Icon = "folder",      Url = "/" + communitySlug + "/bestanden" }
    };
}

<section class="w-full">
    <div class="w-full px-4 sm:px-6 lg:px-8 py-4 sm:py-6 flex flex-col gap-3 sm:gap-4">
        <div class="flex items-center justify-between">
            <h2 class="text-base font-semibold text-foreground-900">Ondekt</h2>
            <a href="/@communitySlug/discover" class="text-sm font-medium text-foreground-500 hover:text-primary transition flex items-center gap-1">
                Ga naar <i data-lucide="arrow-right" class="size-3.5"></i>
            </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 sm:gap-3">
            @foreach (var link in links) {
                <a href="@link.Url" class="group flex items-center gap-3 px-3 py-2.5 sm:px-4 sm:py-3 rounded-lg bg-content2 text-xs sm:text-sm font-medium text-foreground-700 hover:text-primary hover:bg-primary/5 transition">
                    <i data-lucide="@link.Icon" class="size-4 text-foreground-500 group-hover:text-primary transition shrink-0"></i>
                    <span class="truncate flex-1">@link.Label</span>
                    <i data-lucide="chevron-right" class="size-3.5 text-foreground-300 group-hover:text-primary group-hover:translate-x-0.5 transition shrink-0"></i>
                </a>
            }
        </div>
    </div>
</section>
