@*
    Top section of the community home page.
    Left column: full-bleed banner with community name + (optional) company name.
    Right column: latest 2 posts (image + title + teaser + author).

    Reads from PageData: bannerImage, communityName, communitySlug, companyName,
                         latestPosts (List<Dictionary<string,object>>).
*@
@{
    var bannerImage   = (string)PageData["bannerImage"];
    var communityName = (string)PageData["communityName"];
    var communitySlug = (string)PageData["communitySlug"];
    var companyName   = (string)PageData["companyName"] ?? "";
    var latestPosts   = (List<Dictionary<string, object>>)PageData["latestPosts"];
}

<section class="w-full">
    <div class="flex flex-col xl:flex-row gap-5 sm:gap-8">

        <!-- Left: community banner -->
        <div class="relative flex-1 min-h-48 sm:min-h-80 rounded-lg overflow-hidden">
            <img src="@bannerImage" alt="@communityName" class="absolute inset-0 w-full h-full object-cover" />
            <div class="absolute inset-0 bg-linear-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="relative flex flex-col justify-end h-full p-6 gap-1">
                <h1 class="text-2xl sm:text-3xl font-bold text-white leading-tight">@communityName</h1>
                @if (!string.IsNullOrEmpty(companyName)) {
                    <span class="text-sm text-white/80">@companyName</span>
                }
            </div>
        </div>

        <!-- Right: latest posts from community & groups -->
        <div class="flex flex-col gap-3 sm:gap-4 xl:w-[480px]">
            <div class="flex items-center justify-between">
                <h2 class="text-base font-semibold text-foreground-900">Laatste berichten</h2>
                <a href="/@communitySlug/timeline" class="text-sm font-medium text-foreground-500 hover:text-primary transition flex items-center gap-1">
                    Ga naar <i data-lucide="arrow-right" class="size-3.5"></i>
                </a>
            </div>
            @if (latestPosts.Count == 0) {
                <div class="flex flex-col items-center gap-3 py-8 text-center bg-content1 rounded-xl border border-divider">
                    <p class="text-sm text-foreground-400">Er zijn nog geen berichten.</p>
                </div>
            } else {
                <div class="grid grid-rows-2 gap-3 sm:gap-4 flex-1">
                    @foreach (var post in latestPosts) {
                        var title    = (string)post["Title"];
                        var teaser   = (string)post["Teaser"];
                        var image    = (string)post["Image"];
                        var author   = (string)post["Author"];
                        var pSlug    = (string)post["CommunitySlug"];
                        var postId   = (int)post["PostId"];
                        var postImg  = !string.IsNullOrEmpty(image) ? image : "https://picsum.photos/seed/post" + title.GetHashCode() + "/400/300";
                        var postSlug = !string.IsNullOrEmpty(pSlug) ? pSlug : communitySlug;
                        <a href="/@postSlug/timeline?post=@postId" class="flex cursor-pointer group bg-content1 border border-divider hover:border-primary overflow-hidden min-h-[130px] rounded-lg p-1 transition">
                            <img src="@postImg" alt="@title" class="rounded-md w-36 object-cover shrink-0" />
                            <div class="flex flex-col gap-2 pl-4 min-w-0 flex-1 py-2">
                                <h3 class="text-sm sm:text-base font-bold text-foreground-900 leading-snug group-hover:text-primary transition line-clamp-2">@title</h3>
                                <p class="text-xs sm:text-sm text-foreground-500 leading-relaxed line-clamp-3 sm:line-clamp-5">@teaser</p>
                                @if (!string.IsNullOrEmpty(author)) {
                                    <span class="text-xs font-medium text-primary/80 mt-auto pt-1 truncate">@author</span>
                                }
                            </div>
                        </a>
                    }
                </div>
            }
        </div>

    </div>
</section>
