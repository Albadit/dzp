<!-- DZP Connect Footer -->
<footer id="contact" class="bg-foreground-900 text-foreground-400" itemscope itemtype="https://schema.org/Organization">
    <!-- Eind-CTA -->
    <div class="bg-indigo-600">
        <div class="max-w-4xl mx-auto py-16 px-4 text-center">
            <h2 class="text-3xl font-bold text-white mb-4">
                Maak communicatie in jouw gebied professioneel en terugvindbaar
            </h2>
            <p class="text-indigo-100 mb-8 max-w-2xl mx-auto">
                Vraag een demo aan en ontdek hoe DZP Connect structuur brengt in samenwerking, updates en documenten.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                <a href="#demo"
                   class="px-8 py-3 rounded-lg bg-white text-indigo-600 font-semibold hover:bg-indigo-50 transition shadow-lg">
                    Vraag demo aan
                </a>
                <a href="#contact-form"
                   class="px-8 py-3 rounded-lg border-2 border-white text-white font-semibold hover:bg-white/10 transition">
                    Neem contact op
                </a>
            </div>
        </div>
    </div>

    <!-- Footer links -->
    <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Brand -->
            <div>
                <div class="flex items-center space-x-2 mb-4">
                    <i data-lucide="users" class="size-7 shrink-0 text-indigo-400"></i>
                    <span class="text-lg font-bold text-white">DZP Connect</span>
                </div>
                <p class="text-sm leading-relaxed" itemprop="description">
                    Dé zakelijke community-app voor winkelgebieden. Structuur, samenwerking en overzicht — op één plek.
                </p>
            </div>

            <!-- Contact -->
            <div>
                <h4 class="text-white font-semibold mb-4">Contact</h4>
                <ul class="space-y-2 text-sm">
                    <li>
                        <i data-lucide="mail" class="inline size-4 mr-1 text-indigo-400"></i>
                        <span itemprop="email">info&#64;dzpconnect.nl</span>
                    </li>
                    <li>
                        <i data-lucide="phone" class="inline size-4 mr-1 text-indigo-400"></i>
                        <span itemprop="telephone">+31 (0)20 123 4567</span>
                    </li>
                </ul>
            </div>

            <!-- Links -->
            <nav aria-label="Footer navigatie">
                <h4 class="text-white font-semibold mb-4">Links</h4>
                <ul class="space-y-2 text-sm">
                    <li><a href="#" class="hover:text-white transition">Privacy</a></li>
                    <li><a href="#" class="hover:text-white transition">Voorwaarden</a></li>
                    <li><a href="#" class="hover:text-white transition">Support</a></li>
                </ul>
            </nav>
        </div>

        <div class="border-t border-foreground-800 mt-10 pt-6 text-center text-xs text-foreground-500">
            &copy; @DateTime.Now.Year DZP Connect. Alle rechten voorbehouden.
        </div>
    </div>
</footer>