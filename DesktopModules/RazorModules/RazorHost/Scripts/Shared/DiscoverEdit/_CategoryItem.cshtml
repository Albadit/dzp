@*
    Discovery edit – single category card.
    Renders the category summary, edit form, list of buttons, and the
    inline "add new button" form. Iterates the cat's button list.

    Reads from PageData:
      cat        -> Dictionary<string, object> for this category
      btns       -> List<Dictionary<string, object>> of button rows
      requestUrl -> string, used as data-reorder-url for SortableJS
      communitySlug -> string, used for placeholder URLs

    NOTE: HTML5's parser strips <form> tags nested inside DNN's outer
    <form id="Form">. So all marker attributes (hidden, data-add-btn-form)
    must live on the inner <div>, not the <form>.
*@
@{
    var cat        = (System.Collections.Generic.Dictionary<string, object>)PageData["cat"];
    var btns       = (System.Collections.Generic.List<System.Collections.Generic.Dictionary<string, object>>)PageData["btns"];
    var requestUrl = (PageData["requestUrl"]    as string) ?? "";
    var commSlug   = (PageData["communitySlug"] as string) ?? "";

    var catId      = (int)   cat["Id"];
    var catTitle   = (string)cat["Title"];
    var catDesc    = (string)cat["Description"];
    var catIcon    = (string)cat["Icon"];
    var catVisible = (bool)  cat["IsVisible"];
}

<div class="dt-sort-item bg-content1 rounded-xl border border-divider overflow-hidden" data-id="@catId">
    <details>
        <summary class="cursor-pointer flex items-center gap-3 p-5 sm:p-6 hover:bg-content2/50 transition">
            <span class="dt-sort-handle shrink-0 inline-flex items-center justify-center size-8 rounded-md text-foreground-400 hover:text-foreground-700 hover:bg-content2 cursor-grab active:cursor-grabbing"
                  title="Sleep om te verplaatsen"
                  onclick="event.preventDefault(); event.stopPropagation();">
                <i data-lucide="grip-vertical" class="size-4"></i>
            </span>
            <div class="size-10 rounded-lg flex items-center justify-center bg-primary/10 shrink-0 overflow-hidden">
                @if (!string.IsNullOrEmpty(catIcon)) {
                    <i data-lucide="@catIcon" class="size-5 text-primary"></i>
                } else {
                    <span class="text-sm font-bold text-primary">@(catTitle.Length > 0 ? catTitle.Substring(0, 1).ToUpper() : "?")</span>
                }
            </div>
            <div class="flex-1 min-w-0">
                <h2 class="text-base font-semibold text-foreground-900 truncate">@catTitle</h2>
                <p class="text-xs text-foreground-500 truncate">@btns.Count knop@(btns.Count == 1 ? "" : "pen")</p>
            </div>
            @if (!catVisible) {
                <span class="shrink-0 text-xs px-2 py-1 rounded-full bg-warning/10 text-warning-700 font-medium">verborgen</span>
            }
            <i data-lucide="chevron-down" class="size-5 text-foreground-400 shrink-0"></i>
        </summary>

        <!-- Category edit form -->
        <div class="p-5 sm:p-6 flex flex-col gap-4">
            <form method="post" data-ajax="cat-save" class="contents">
            <div data-edit-cat-form data-cat-id="@catId" class="contents">
                <input type="hidden" name="formAction" value="cat-save" />
                <input type="hidden" name="catId" value="@catId" />

                <div class="flex flex-col gap-1.5">
                    <label class="text-sm font-medium text-foreground-700">Titel <span class="text-danger">*</span></label>
                    @{
                        PageData["id"]       = "catTitle_" + catId;
                        PageData["name"]     = "title";
                        PageData["value"]    = catTitle;
                        PageData["required"] = true;
                    }
                    @RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_Input.cshtml")
                </div>

                <div class="flex flex-col gap-1.5">
                    <label class="text-sm font-medium text-foreground-700">Beschrijving</label>
                    @{
                        PageData["id"]    = "catDesc_" + catId;
                        PageData["name"]  = "description";
                        PageData["value"] = catDesc;
                        PageData["rows"]  = 3;
                    }
                    @RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_Textarea.cshtml")
                </div>

                <div class="flex flex-col gap-1.5">
                    <label class="text-sm font-medium text-foreground-700">Lucide icon</label>
                    @{
                        PageData["id"]          = "catIcon_" + catId;
                        PageData["name"]        = "icon";
                        PageData["value"]       = catIcon;
                        PageData["placeholder"] = "bijv. map-pin";
                        PageData["attrs"]       = "data-icon-picker";
                    }
                    @RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_Input.cshtml")
                    @{ PageData["attrs"] = null; }
                </div>

                <div class="flex items-center gap-4">
                    <input type="hidden" name="isVisible" value="@(catVisible ? "1" : "0")" data-vis-input />
                    <button type="button" data-vis-toggle
                            aria-pressed="@(catVisible ? "true" : "false")"
                            title="@(catVisible ? "Verbergen op de Ondekt-pagina" : "Tonen op de Ondekt-pagina")"
                            class="inline-flex items-center justify-center size-9 rounded-lg border transition-colors shrink-0 @(catVisible ? "border-primary/30 bg-primary/10 text-primary hover:bg-primary/20" : "border-divider bg-content2 text-foreground-400 hover:text-foreground-700 hover:bg-content3")">
                        <i data-lucide="@(catVisible ? "eye" : "eye-off")" class="size-4"></i>
                    </button>
                    <span class="text-sm font-medium text-foreground-700">Zichtbaar op de Ondekt-pagina</span>
                </div>

                <div class="flex flex-col-reverse sm:flex-row sm:flex-wrap items-stretch sm:items-center sm:justify-end gap-3 pt-2 border-t border-divider">
                    <button type="button" data-ajax-delete="cat" data-cat-id="@catId"
                            class="inline-flex items-center justify-center gap-2 px-3 py-2.5 rounded-lg border border-divider text-sm font-medium text-foreground-700 hover:bg-content2 hover:border-danger/40 hover:text-danger-700 transition">
                        <span>Verwijderen</span>
                    </button>
                    <button type="submit"
                            class="inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-primary/90 transition">
                        <i data-lucide="save" class="size-4"></i>
                        <span>Opslaan</span>
                    </button>
                </div>
            </div>
        <!-- Buttons section -->
        <div class="border-t border-divider bg-content2/30 p-5 sm:p-6">
            <h3 class="text-xs font-bold uppercase tracking-wider text-foreground-500 mb-3">Knoppen</h3>

            @if (btns.Count == 0) {
                <p class="text-sm text-foreground-400 italic mb-4">Nog geen knoppen in deze categorie.</p>
            }

            <div class="flex flex-col gap-3"
                 data-sortable="btn"
                 data-cat-id="@catId"
                 data-reorder-url="@requestUrl">
                @foreach (var b in btns) {
                    var bId      = (int)   b["Id"];
                    var bLabel   = (string)b["Label"];
                    var bIcon    = (string)b["Icon"];
                    var bUrl     = (string)b["Url"];
                    var bVisible = (bool)  b["IsVisible"];
                    <form method="post" data-ajax="btn-save" class="contents">
                    <div data-edit-btn-form data-btn-id="@bId" data-cat-id="@catId" data-id="@bId"
                         class="dt-sort-item bg-content1 rounded-lg border border-divider p-4 flex flex-wrap items-end gap-3">
                        <input type="hidden" name="formAction" value="btn-save" />
                        <input type="hidden" name="catId"      value="@catId" />
                        <input type="hidden" name="btnId"      value="@bId" />

                        <span class="dt-sort-handle hidden sm:inline-flex items-center justify-center size-9 rounded-md text-foreground-400 hover:text-foreground-700 hover:bg-content2 cursor-grab active:cursor-grabbing shrink-0"
                              title="Sleep om te verplaatsen">
                            <i data-lucide="grip-vertical" class="size-4"></i>
                        </span>

                        <div class="w-full sm:w-auto sm:flex-1 sm:min-w-40 flex flex-col gap-1.5">
                            <label class="text-xs font-medium text-foreground-500">Label *</label>
                            @{
                                PageData["id"]       = "btnLabel_" + bId;
                                PageData["name"]     = "label";
                                PageData["value"]    = bLabel;
                                PageData["required"] = true;
                            }
                            @RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_Input.cshtml")
                        </div>

                        <div class="w-full sm:w-auto sm:basis-32 sm:shrink-0 flex flex-col gap-1.5">
                            <label class="text-xs font-medium text-foreground-500">Icon</label>
                            @{
                                PageData["id"]          = "btnIcon_" + bId;
                                PageData["name"]        = "icon";
                                PageData["value"]       = bIcon;
                                PageData["placeholder"] = "chevron-right";
                                PageData["attrs"]       = "data-icon-picker";
                            }
                            @RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_Input.cshtml")
                            @{ PageData["attrs"] = null; }
                        </div>

                        <div class="w-full sm:w-auto sm:flex-[2] sm:min-w-[12rem] flex flex-col gap-1.5">
                            <label class="text-xs font-medium text-foreground-500">URL *</label>
                            @{
                                PageData["id"]       = "btnUrl_" + bId;
                                PageData["name"]     = "url";
                                PageData["type"]     = "text";
                                PageData["value"]    = bUrl;
                                PageData["required"] = true;
                            }
                            @RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_Input.cshtml")
                        </div>

                        <div class="w-full sm:w-auto flex items-center gap-2 sm:justify-end">
                            <input type="hidden" name="isVisible" value="@(bVisible ? "1" : "0")" data-vis-input />
                            <button type="button" data-vis-toggle
                                    aria-pressed="@(bVisible ? "true" : "false")"
                                    title="@(bVisible ? "Verbergen" : "Tonen")"
                                    class="flex-1 sm:flex-none inline-flex items-center justify-center h-9 sm:size-9 rounded-lg border transition-colors @(bVisible ? "border-primary/30 bg-primary/10 text-primary hover:bg-primary/20" : "border-divider bg-content2 text-foreground-400 hover:text-foreground-700 hover:bg-content3")">
                                <i data-lucide="@(bVisible ? "eye" : "eye-off")" class="size-4"></i>
                            </button>
                            <button type="submit" title="Opslaan"
                                    class="flex-1 sm:flex-none inline-flex items-center justify-center h-9 sm:size-9 rounded-lg bg-primary text-white hover:bg-primary/90 transition">
                                <i data-lucide="save" class="size-4"></i>
                            </button>
                            <button type="button" data-ajax-delete="btn" data-btn-id="@bId"
                                    title="Verwijderen"
                                    class="flex-1 sm:flex-none inline-flex items-center justify-center h-9 sm:size-9 rounded-lg border border-divider text-foreground-700 hover:bg-content2 hover:border-danger/40 hover:text-danger-700 transition">
                                <i data-lucide="trash-2" class="size-4"></i>
                            </button>
                        </div>
                    </div>
                    </form>
                }
            </div>

            <!-- Add new button (inline form appears ABOVE the trigger so '+' stays anchored to the bottom of the list) -->
            <div class="mt-4" data-add-btn-wrap="@catId">
                <form method="post" data-ajax="btn-save">
                <div data-add-btn-form="@catId" class="hidden mb-3 bg-content1 rounded-lg border border-divider p-4">
                    <input type="hidden" name="formAction" value="btn-save" />
                    <input type="hidden" name="catId"      value="@catId" />
                    <input type="hidden" name="btnId"      value="0" />
                    <div class="flex flex-wrap items-end gap-3">

                    <div class="w-full sm:w-auto sm:flex-1 sm:min-w-[10rem] flex flex-col gap-1.5">
                        <label class="text-xs font-medium text-foreground-500">Label *</label>
                        @{
                            PageData["id"]       = "newBtnLabel_" + catId;
                            PageData["name"]     = "label";
                            PageData["value"]    = "";
                            PageData["required"] = true;
                        }
                        @RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_Input.cshtml")
                    </div>

                    <div class="w-full sm:w-auto sm:basis-32 sm:shrink-0 flex flex-col gap-1.5">
                        <label class="text-xs font-medium text-foreground-500">Icon</label>
                        @{
                            PageData["id"]          = "newBtnIcon_" + catId;
                            PageData["name"]        = "icon";
                            PageData["value"]       = "";
                            PageData["placeholder"] = "chevron-right";
                            PageData["attrs"]       = "data-icon-picker";
                        }
                        @RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_Input.cshtml")
                        @{ PageData["attrs"] = null; }
                    </div>

                    <div class="w-full sm:w-auto sm:flex-[2] sm:min-w-[12rem] flex flex-col gap-1.5">
                        <label class="text-xs font-medium text-foreground-500">URL *</label>
                        @{
                            PageData["id"]          = "newBtnUrl_" + catId;
                            PageData["name"]        = "url";
                            PageData["type"]        = "text";
                            PageData["value"]       = "";
                            PageData["placeholder"] = "/" + commSlug + "/... of www.voorbeeld.nl";
                            PageData["required"]    = true;
                        }
                        @RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_Input.cshtml")
                    </div>

                    <div class="w-full sm:w-auto flex items-center gap-2 sm:justify-end">
                        <input type="hidden" name="isVisible" value="1" data-vis-input />
                        <button type="button" data-vis-toggle
                                aria-pressed="true"
                                title="Verbergen"
                                class="flex-1 sm:flex-none inline-flex items-center justify-center h-9 sm:size-9 rounded-lg border transition-colors border-primary/30 bg-primary/10 text-primary hover:bg-primary/20">
                            <i data-lucide="eye" class="size-4"></i>
                        </button>
                        <button type="submit"
                                class="flex-1 sm:flex-none inline-flex items-center justify-center gap-1 px-3 h-9 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-primary/90 transition">
                            <i data-lucide="plus" class="size-4"></i>
                            <span>Toev.</span>
                        </button>
                    </div>
                    </div>
                </div>
                </form>
                <button type="button" data-add-btn-trigger="@catId"
                        class="w-full flex items-center justify-center gap-2 py-3 rounded-lg border-2 border-dashed border-divider text-sm font-medium text-primary hover:border-primary hover:bg-primary/5 transition">
                    <i data-lucide="plus" class="size-4"></i>
                    <span>Knop toevoegen</span>
                </button>
            </div>
        </div>
    </details>
</div>
