@*
    Discovery edit – save success/error banners + AJAX toast region.
    Delegates to shared Components partials so styling stays in one place.
    Reads from PageData: saveMsg, saveError.
*@
@{
    PageData["success"] = (PageData["saveMsg"]   as string) ?? "";
    PageData["error"]   = (PageData["saveError"] as string) ?? "";
}
@RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_SaveAlert.cshtml")
@RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_ToastRegion.cshtml")
