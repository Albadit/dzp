@*
    Discovery edit – server-side save success / error banners + AJAX toast region.
    Reads from PageData: saveMsg, saveError.
*@
@{
    var saveMsg   = (PageData["saveMsg"]   as string) ?? "";
    var saveError = (PageData["saveError"] as string) ?? "";
}
@if (!string.IsNullOrEmpty(saveMsg)) {
    <div class="p-3 rounded-xl border border-success-200 bg-success-50 text-sm font-medium text-success-800 flex items-center gap-2">
        <i data-lucide="check-circle-2" class="size-4"></i><span>@saveMsg</span>
    </div>
}
@if (!string.IsNullOrEmpty(saveError)) {
    <div class="p-3 rounded-xl border border-danger-200 bg-danger-50 text-sm font-medium text-danger-800 flex items-center gap-2">
        <i data-lucide="alert-circle" class="size-4"></i><span>@saveError</span>
    </div>
}

<!-- Floating toast region for AJAX feedback -->
<div id="de-toast-region" class="fixed top-4 right-4 z-50 flex flex-col gap-2 pointer-events-none"></div>
