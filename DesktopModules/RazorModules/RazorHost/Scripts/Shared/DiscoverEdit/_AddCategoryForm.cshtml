@*
    Discovery edit – inline "add new category" form.
    Reads from PageData: communitySlug (currently unused, but kept for parity).

    NOTE: HTML5's parser strips <form> tags nested inside DNN's outer
    <form id="Form">. The marker attributes (hidden, data-add-cat-form)
    must live on the inner <div>, not the <form>, so they survive parsing.
    The <form> tag is preserved so a non-AJAX fallback POST still works.
*@
<div data-add-cat-wrap>
    <form method="post" data-ajax="cat-save">
    <div data-add-cat-form class="hidden mb-3 bg-content1 rounded-xl border border-divider p-5 sm:p-6 space-y-4">
        <input type="hidden" name="formAction" value="cat-save" />
        <input type="hidden" name="catId" value="0" />

        <div class="flex flex-col gap-1.5">
            <label for="newCatTitle" class="text-sm font-medium text-foreground-700">Titel <span class="text-danger">*</span></label>
            @{
                PageData["id"]       = "newCatTitle";
                PageData["name"]     = "title";
                PageData["value"]    = "";
                PageData["required"] = true;
            }
            @RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_Input.cshtml")
        </div>

        <div class="flex flex-col gap-1.5">
            <label for="newCatDesc" class="text-sm font-medium text-foreground-700">Beschrijving</label>
            @{
                PageData["id"]    = "newCatDesc";
                PageData["name"]  = "description";
                PageData["value"] = "";
                PageData["rows"]  = 3;
            }
            @RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_Textarea.cshtml")
        </div>

        <div class="flex flex-col gap-1.5">
            <label for="newCatIcon" class="text-sm font-medium text-foreground-700">Lucide icon</label>
            @{
                PageData["id"]          = "newCatIcon";
                PageData["name"]        = "icon";
                PageData["value"]       = "";
                PageData["placeholder"] = "bijv. map-pin";
                PageData["attrs"]       = "data-icon-picker";
            }
            @RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_Input.cshtml")
            @{ PageData["attrs"] = null; }
        </div>

        <div class="flex items-center gap-4">
            <input type="hidden" name="isVisible" value="1" data-vis-input />
            <button type="button" data-vis-toggle
                    aria-pressed="true"
                    title="Verbergen op de Ondekt-pagina"
                    class="inline-flex items-center justify-center size-9 rounded-lg border transition-colors shrink-0 border-primary/30 bg-primary/10 text-primary hover:bg-primary/20">
                <i data-lucide="eye" class="size-4"></i>
            </button>
            <span class="text-sm font-medium text-foreground-700">Zichtbaar op de Ondekt-pagina</span>
        </div>

        <div class="flex flex-col-reverse sm:flex-row sm:flex-wrap items-stretch sm:items-center sm:justify-end gap-2 pt-2 border-t border-divider">
            <button type="button" data-add-cat-cancel
                    class="inline-flex items-center justify-center gap-2 px-3 py-2.5 rounded-lg border border-divider text-sm font-medium text-foreground-700 hover:bg-content2 transition">
                <span>Annuleren</span>
            </button>
            <button type="submit" class="inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-primary/90 transition">
                <i data-lucide="plus" class="size-4"></i>
                <span>Categorie toevoegen</span>
            </button>
        </div>
    </div>
    </form>
    <button type="button" data-add-cat-trigger
            class="w-full flex items-center justify-center gap-2 py-4 rounded-xl border-2 border-dashed border-primary/40 text-sm font-semibold text-primary hover:border-primary hover:bg-primary/5 transition">
        <i data-lucide="plus" class="size-4"></i>
        <span>Categorie toevoegen</span>
    </button>
</div>
