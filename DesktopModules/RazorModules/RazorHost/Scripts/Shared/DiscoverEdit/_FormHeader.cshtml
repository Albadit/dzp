@*
    Discovery edit – page header.
    Delegates to the shared Components/_PageHeader partial.
    Reads from PageData: communityName, communitySlug.
*@
@{
    var communityName = (PageData["communityName"] as string) ?? "";
    var communitySlug = (PageData["communitySlug"] as string) ?? "";
    PageData["title"]    = "Ondekt beheren";
    PageData["subtitle"] = "Beheer de Ondekt-categorieën en knoppen voor <strong>" + System.Web.HttpUtility.HtmlEncode(communityName) + "</strong>.";
    if (!string.IsNullOrEmpty(communitySlug)) {
        PageData["actionHref"]  = "/" + communitySlug + "/discover";
        PageData["actionLabel"] = "Bekijk Ondekt";
        PageData["actionIcon"]  = "eye";
    }
}
@RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_PageHeader.cshtml")
