@*
    Company edit – "Geen toegang" hero panel.
    Delegates to shared Components/_AccessDenied partial.
    Reads from PageData: communitySlug, companySlug.
*@
@{
    var communitySlug = (string)PageData["communitySlug"];
    var companySlug   = (string)PageData["companySlug"];
    PageData["compact"]   = false;
    PageData["message"]   = "Je hebt geen rechten om dit bedrijf te bewerken. Alleen gekoppelde teamleden kunnen wijzigingen aanbrengen.";
    PageData["backHref"]  = "/" + communitySlug + "/companies/" + companySlug;
    PageData["backLabel"] = "Terug naar bedrijfspagina";
}
@RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_AccessDenied.cshtml")
