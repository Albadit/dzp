@*
    Company edit – page header with cancel link.
    Delegates to shared Components/_PageHeader partial.
    Reads from PageData: communitySlug, companySlug.
*@
@{
    var communitySlug = (string)PageData["communitySlug"];
    var companySlug   = (string)PageData["companySlug"];
    PageData["title"]       = "Bedrijf bewerken";
    PageData["actionHref"]  = "/" + communitySlug + "/companies/" + companySlug;
    PageData["actionLabel"] = "Annuleren";
    PageData["actionIcon"]  = "x";
}
@RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_PageHeader.cshtml")
