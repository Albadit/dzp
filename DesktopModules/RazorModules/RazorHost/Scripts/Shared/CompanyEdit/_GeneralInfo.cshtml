@*
    "Algemene informatie" section: company name, about, banner image upload.
    The banner uses the shared dropzone component (which itself wires up to
    the TableDZP module's dropzone.js).
    Reads from PageData: companyName, about, bannerImage.
*@
@{
    var companyName     = (string)PageData["companyName"];
    var about           = (string)PageData["about"];
    var bannerImage     = (string)PageData["bannerImage"];
}

<div class="flex flex-col gap-4 bg-content1 rounded-xl border border-divider p-5 sm:p-6">
    <h2 class="text-base font-semibold text-foreground-900">Algemene informatie</h2>

    <div class="flex flex-col gap-1.5">
        <label for="companyName" class="text-sm font-medium text-foreground-700">Bedrijfsnaam <span class="text-danger">*</span></label>
        @{
            PageData["id"]       = "companyName";
            PageData["name"]     = "companyName";
            PageData["type"]     = "text";
            PageData["value"]    = companyName;
            PageData["required"] = true;
        }
        @RenderPage("../Components/_Input.cshtml")
    </div>

    <div class="flex flex-col gap-1.5">
        <label for="about" class="text-sm font-medium text-foreground-700">Over het bedrijf</label>
        @{
            PageData["id"]          = "about";
            PageData["name"]        = "about";
            PageData["value"]       = about;
            PageData["rows"]        = 4;
            PageData["placeholder"] = "Beschrijf het bedrijf...";
        }
        @RenderPage("../Components/_Textarea.cshtml")
    </div>

    <div class="flex flex-col gap-1.5">
        <label for="banner" class="text-sm font-medium text-foreground-700">Banner afbeelding</label>
        @{
            PageData["id"]    = "banner";
            PageData["name"]  = "banner";
            PageData["value"] = bannerImage;
        }
        @RenderPage("../Components/_Dropzone.cshtml")
    </div>
</div>
