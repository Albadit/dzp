@*
    Success / error banners shown after a save POST.
    Reads from PageData: saveSuccess (bool), saveError (string),
                         communitySlug, companySlug.
*@
@{
    var saveSuccess   = (bool)PageData["saveSuccess"];
    var saveError     = (string)PageData["saveError"];
    var communitySlug = (string)PageData["communitySlug"];
    var companySlug   = (string)PageData["companySlug"];
}

@if (saveSuccess) {
    <div class="flex items-center gap-3 p-4 rounded-xl border border-success-200 bg-success-50">
        <i data-lucide="check-circle-2" class="size-5 text-success shrink-0"></i>
        <div class="flex flex-col gap-0.5">
            <span class="text-sm font-medium text-success-800">Opgeslagen!</span>
            <span class="text-xs text-success-800">De bedrijfsgegevens zijn bijgewerkt.
                <a href="/@communitySlug/companies/@companySlug" class="underline font-medium">Bekijk bedrijfspagina</a>
            </span>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(saveError)) {
    <div class="flex items-center gap-3 p-4 rounded-xl border border-danger-200 bg-danger-50">
        <i data-lucide="alert-circle" class="size-5 text-danger shrink-0"></i>
        <span class="text-sm text-danger-800">@saveError</span>
    </div>
}
