@*
    Company edit – save success/error banners + AJAX toast region.
    Delegates to shared Components partials.
    Reads from PageData: saveSuccess (bool), saveError (string),
                         communitySlug, companySlug.
*@
@{
    var saveSuccess   = (bool)PageData["saveSuccess"];
    var saveError     = (string)PageData["saveError"];
    var communitySlug = (string)PageData["communitySlug"];
    var companySlug   = (string)PageData["companySlug"];

    PageData["success"]     = saveSuccess ? "Opgeslagen!" : "";
    PageData["successHtml"] = saveSuccess
        ? "De bedrijfsgegevens zijn bijgewerkt. <a href=\"/" + communitySlug + "/companies/" + companySlug + "\" class=\"underline font-medium\">Bekijk bedrijfspagina</a>"
        : "";
    PageData["error"]       = saveError ?? "";
}
@RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_SaveAlert.cshtml")
@RenderPage("~/DesktopModules/RazorModules/RazorHost/Scripts/Shared/Components/_ToastRegion.cshtml")
