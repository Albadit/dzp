@*
    "Teamleden" section: add-member dropdown + current members list.
    Members are augmented client-side via /Resources/js/company-edit.js
    (toggle ShowInTeam, remove, add) — this partial only emits the markup.

    Reads from PageData: members (List<Dictionary<string,object>> with keys
                         Id, UserId, DisplayName, Email, ShowInTeam),
                         ownerId (int).
*@
@{
    var members = (List<Dictionary<string, object>>)PageData["members"];
    var ownerId = (int)PageData["ownerId"];
    // Always render the owner first, then everyone else in original order.
    members = members
        .OrderByDescending(m => (int)m["UserId"] == ownerId)
        .ToList();
}

<div class="flex flex-col gap-4 bg-content1 rounded-xl border border-divider p-5 sm:p-6">
    <h2 class="text-base font-semibold text-foreground-900">Teamleden</h2>

    <!-- Add member form (hydrated by company-edit.js) -->
    <div id="ce-add-form" class="flex items-end gap-3">
        <div class="flex flex-col gap-1.5 flex-1">
            <label class="text-sm font-medium text-foreground-700">Lid toevoegen</label>
            <div id="ce-add-user-select"></div>
        </div>
        @{
            PageData["text"]       = "Toevoegen";
            PageData["variant"]    = "primary";
            PageData["type"]       = "button";
            PageData["id"]         = "ce-add-btn";
            PageData["icon"]       = "user-plus";
            PageData["extraClass"] = "shrink-0";
        }
        @RenderPage("../Components/_Button.cshtml")
    </div>

    <!-- Current members list -->
    <div id="ce-members">
        @if (members.Count == 0) {
            <p class="text-sm text-foreground-400 py-2">Er zijn nog geen teamleden gekoppeld.</p>
        } else {
            <div class="flex flex-col divide-y divide-divider">
                @foreach (var m in members) {
                    var mId          = (int)m["Id"];
                    var mUserId      = (int)m["UserId"];
                    var mDisplayName = (string)m["DisplayName"];
                    var mEmail       = (string)m["Email"];
                    var mShowInTeam  = (bool)m["ShowInTeam"];
                    <div class="flex items-center justify-between gap-4 py-3">
                        <div class="flex items-center gap-3 min-w-0">
                            <button type="button" data-toggle-user="@mUserId" title="@(mShowInTeam ? "Verbergen in team" : "Tonen in team")"
                                    aria-pressed="@(mShowInTeam ? "true" : "false")"
                                    class="inline-flex items-center justify-center size-9 rounded-lg border transition-colors shrink-0 @(mShowInTeam ? "border-primary/30 bg-primary/10 text-primary hover:bg-primary/20" : "border-divider bg-content2 text-foreground-400 hover:text-foreground-700 hover:bg-content3")">
                                <i data-lucide="@(mShowInTeam ? "eye" : "eye-off")" class="size-4"></i>
                            </button>
                            <div class="size-10 rounded-full overflow-hidden border-2 border-divider shrink-0">
                                <img src="/DnnImageHandler.ashx?mode=profilepic&userId=@mUserId&w=80&h=80" alt="@mDisplayName" class="w-full h-full object-cover rounded-full" />
                            </div>
                            <div class="flex flex-col min-w-0">
                                <span class="text-sm font-medium text-foreground-900 truncate">@mDisplayName</span>
                                @if (!string.IsNullOrEmpty(mEmail)) {
                                    <span class="text-xs text-foreground-400 truncate">@mEmail</span>
                                }
                            </div>
                        </div>
                        <div class="flex items-center gap-2 shrink-0">
                            @if (mUserId == ownerId) {
                                <span class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg border border-primary/20 bg-primary/5 text-xs font-medium text-primary">
                                    <i data-lucide="crown" class="size-3.5"></i>
                                    Eigenaar
                                </span>
                            } else {
                                <button type="button" data-remove-id="@mId"
                                        class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg border border-divider text-xs font-medium text-danger hover:bg-danger-50 hover:border-danger/30 transition">
                                    <i data-lucide="user-minus" class="size-3.5"></i>
                                    Verwijderen
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
