@*
    Submit + cancel buttons for the company edit form.
    Reads from PageData: communitySlug, companySlug.
*@
@{
    var communitySlug = (string)PageData["communitySlug"];
    var companySlug   = (string)PageData["companySlug"];
}

<div class="flex items-center gap-3 pt-2">
    @{
        PageData["text"]    = "Opslaan";
        PageData["variant"] = "primary";
        PageData["type"]    = "submit";
        PageData["icon"]    = "save";
        PageData["href"]    = null;
        PageData["onclick"] = null;
        PageData["id"]      = null;
        PageData["name"]    = null;
        PageData["value"]   = null;
        PageData["disabled"]   = null;
        PageData["extraClass"] = null;
        PageData["attrs"]      = null;
    }
    @RenderPage("../Components/_Button.cshtml")

    @{
        PageData["text"]    = "Annuleren";
        // "ghost" swaps text to white on hover, but Tailwind's JIT can purge
        // the dynamically-built `hover:text-white` class, leaving the label
        // invisible against the filled hover background. Use the stable
        // bordered variant on the default colour instead.
        PageData["variant"] = "bordered";
        PageData["color"]   = "default";
        PageData["icon"]    = null;
        PageData["href"]    = "/" + communitySlug + "/companies/" + companySlug;
        PageData["extraClass"] = null;
    }
    @RenderPage("../Components/_Button.cshtml")
</div>
