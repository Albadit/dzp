@*
    Search input + count + grid/list view toggle.
    Reads from PageData: companyCount (int).
    The toggle buttons call window.setView() defined in _Script.cshtml.
*@
@{
    var companyCount = (int)PageData["companyCount"];
}

<section class="w-full">
    <div class="w-full px-4 sm:px-6 lg:px-8 pb-2">
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
            @{
                PageData["id"]          = "companySearch";
                PageData["placeholder"] = "Zoek een bedrijf...";
                PageData["countId"]     = "companyCount";
                PageData["countText"]   = companyCount + " bedrijven";
                PageData["extraClass"]  = "flex-1";
            }
            @RenderPage("../Components/_SearchBox.cshtml")

            <div class="flex items-center gap-2">
                <div class="flex items-center rounded-lg border border-divider bg-background p-0.5">
                    <button type="button" id="btnGrid" onclick="setView('grid')" title="Rasterweergave"
                            class="flex items-center justify-center size-8 rounded-md transition bg-primary text-white">
                        <i data-lucide="layout-grid" class="size-4"></i>
                    </button>
                    <button type="button" id="btnList" onclick="setView('list')" title="Lijstweergave"
                            class="flex items-center justify-center size-8 rounded-md transition text-foreground-400 hover:text-foreground-700">
                        <i data-lucide="list" class="size-4"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>
