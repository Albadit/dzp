@*
    Search input + count.
    Reads from PageData: companyCount (int).
*@
@{
    var companyCount = (int)PageData["companyCount"];
}

<section class="w-full">
    <div class="w-full px-4 sm:px-6 lg:px-8 pb-2">
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
            @{
                PageData["id"]          = "companySearch";
                PageData["placeholder"] = "Zoek een bedrijf...";
                PageData["countId"]     = "companyCount";
                PageData["countText"]   = companyCount + " bedrijven";
                PageData["extraClass"]  = "flex-1";
            }
            @RenderPage("../Components/_SearchBox.cshtml")
        </div>
    </div>
</section>
