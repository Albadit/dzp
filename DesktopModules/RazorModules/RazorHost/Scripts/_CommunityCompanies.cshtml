@using DZP.CommunityAuth
@using DotNetNuke.Entities.Portals
@using System.Data.SqlClient
@using System.Configuration
@using System.Linq
@using System.Web.Script.Serialization
@*
    Community → Bedrijven page.
    Fetches the company list from SQL, builds the JSON payload that the
    client-side script consumes, then orchestrates the section partials in
    Shared/CommunityCompanies/. Markup-heavy work lives in the partials so
    this file stays a high-level overview.
*@
@{
    var rc            = CommunityAuth.Current;
    var communityName = rc != null ? rc.CommunityName : "Community";
    var communitySlug = rc != null ? rc.CommunitySlug : "";
    var communityId   = rc != null ? rc.CommunityId   : 0;

    /* ── Fetch companies for this community ── */
    var companies = new List<Dictionary<string, object>>();
    if (communityId > 0) {
        var cs = ConfigurationManager.ConnectionStrings["SiteSqlServer"];
        var connStr = cs != null ? cs.ConnectionString : "";
        if (!string.IsNullOrEmpty(connStr)) {
            using (var conn = new SqlConnection(connStr)) {
            using (var cmd = new SqlCommand(@"
                SELECT c.Id, c.Slug, c.Name, c.CompanyInfo, c.ImageUrl,
                       (SELECT COUNT(*) FROM UserCompany uc WHERE uc.CompanyId = c.Id) AS MemberCount
                FROM Company c
                WHERE c.CommunityId = @cid
                ORDER BY c.Name", conn)) {
                cmd.Parameters.AddWithValue("@cid", communityId);
                conn.Open();
                using (var reader = cmd.ExecuteReader()) {
                    while (reader.Read()) {
                        var infoJson = reader.IsDBNull(3) ? "" : reader.GetString(3);
                        var imageUrl = reader.IsDBNull(4) ? "" : reader.GetString(4);

                        /* Try to extract a short description + address from the
                           CompanyInfo JSON; fall back to the raw value if it's
                           plain text. */
                        var shortDesc = "";
                        var address   = "";
                        if (!string.IsNullOrEmpty(infoJson)) {
                            try {
                                var json = System.Web.Helpers.Json.Decode(infoJson);
                                if (json != null) {
                                    shortDesc = json.about ?? json.description ?? "";
                                    address   = json.address ?? "";
                                }
                            } catch { /* not valid JSON, treat as plain text */ }
                        }
                        if (string.IsNullOrEmpty(shortDesc) && !string.IsNullOrEmpty(infoJson) && !infoJson.TrimStart().StartsWith("{")) {
                            shortDesc = infoJson;
                        }
                        if (!string.IsNullOrEmpty(shortDesc) && shortDesc.Length > 150) {
                            shortDesc = shortDesc.Substring(0, 150) + "...";
                        }

                        companies.Add(new Dictionary<string, object> {
                            { "id",   reader.GetInt32(0) },
                            { "slug", reader.GetString(1) },
                            { "name", reader.GetString(2) },
                            { "desc", shortDesc },
                            { "addr", address },
                            { "img",  imageUrl },
                            { "mc",   reader.GetInt32(5) }
                        });
                    }
                }
            }
            }
        }
    }

    var serializer = new JavaScriptSerializer();
    serializer.MaxJsonLength = int.MaxValue;

    /* Publish state via PageData (proven pattern in this codebase). */
    PageData["communityName"] = communityName;
    PageData["communitySlug"] = communitySlug;
    PageData["bannerImage"]   = "https://picsum.photos/seed/" + communitySlug + "/1200/400";
    PageData["companyCount"]  = companies.Count;
    PageData["companiesJson"] = serializer.Serialize(companies);
}

<main class="max-w-7xl w-full">
    @RenderPage("Shared/CommunityCompanies/_Banner.cshtml")
    @RenderPage("Shared/CommunityCompanies/_FilterBar.cshtml")
    @RenderPage("Shared/CommunityCompanies/_Grid.cshtml")
</main>

@RenderPage("Shared/CommunityCompanies/_Script.cshtml")
