@using DZP.CommunityAuth
@using DotNetNuke.Entities.Portals
@using System.Web
@using System.Data.SqlClient
@using System.Configuration
@using System.Linq
@*
    Discovery edit page.
    Manage CommunityDiscoverCategory + CommunityDiscoverButton rows for
    the current community. Inline POST handlers for create/update/delete
    on both entities. Auth: SuperUser, Administrator, or Community
    beheerder. Styling matches _CommunityHome / _GeneralInfo cards.
*@
@{
    var rc       = CommunityAuth.Current;
    var user     = Dnn.User;

    var communityName = rc != null ? rc.CommunityName : "Community";
    var communitySlug = rc != null ? rc.CommunitySlug : "";
    var communityId   = rc != null ? rc.CommunityId   : 0;

    var cs      = ConfigurationManager.ConnectionStrings["SiteSqlServer"];
    var connStr = cs != null ? cs.ConnectionString : "";

    var isSuperUser     = user != null && user.IsSuperUser;
    var adminRoleName   = PortalSettings.Current != null ? PortalSettings.Current.AdministratorRoleName : "Administrators";
    var isAdministrator = user != null && !string.IsNullOrEmpty(adminRoleName) && user.IsInRole(adminRoleName);
    var isCommunityMgr  = user != null && user.IsInRole("Community beheerder");
    var canEdit         = isSuperUser || isAdministrator || isCommunityMgr;

    var saveMsg   = "";
    var saveError = "";

    // Helper: JSON response for AJAX requests, then short-circuit the page.
    var insertsMap = new Dictionary<string, int>();
    Action<int, string, int, string> jsonOut = (status, msg, newId, kind) => {
        Response.Clear();
        Response.StatusCode  = status;
        Response.ContentType = "application/json";
        var jss = new System.Web.Script.Serialization.JavaScriptSerializer();
        Response.Write(jss.Serialize(new {
            ok      = (status >= 200 && status < 300),
            id      = newId,
            kind    = kind,
            msg     = msg ?? "",
            inserts = insertsMap
        }));
        Response.Flush();
        Response.SuppressContent = true;
        Context.ApplicationInstance.CompleteRequest();
    };
    var isAjax = string.Equals(Request.Headers["X-Requested-With"], "fetch", StringComparison.OrdinalIgnoreCase)
              || Request["ajax"] == "1";

    // Accept user-friendly URLs like "www.youtube.com" or "youtube.com" and
    // turn them into a real absolute URL (https://...).
    Func<string, string> normalizeUrl = (raw) => {
        if (string.IsNullOrWhiteSpace(raw)) return "";
        var s = raw.Trim();
        if (s.StartsWith("/") || s.StartsWith("#") || s.StartsWith("?")) return s;
        if (s.StartsWith("mailto:",     StringComparison.OrdinalIgnoreCase)
         || s.StartsWith("tel:",        StringComparison.OrdinalIgnoreCase)
         || s.StartsWith("sms:",        StringComparison.OrdinalIgnoreCase)
         || s.StartsWith("javascript:", StringComparison.OrdinalIgnoreCase)) return s;
        var schemeIdx = s.IndexOf("://", StringComparison.Ordinal);
        if (schemeIdx > 0 && schemeIdx <= 10) return s;
        return "https://" + s.TrimStart('/');
    };

    // SELECT ISNULL(MAX(SortOrder), -1) + 1 helper. Caller owns the open conn.
    // Table/column names are hard-coded literals at every call site.
    Func<SqlConnection, string, string, object, int> nextSortOrder = (conn, table, whereCol, whereVal) => {
        var sql = "SELECT ISNULL(MAX(SortOrder), -1) + 1 FROM " + table + " WHERE " + whereCol + "=@v";
        using (var cmd = new SqlCommand(sql, conn)) {
            cmd.Parameters.AddWithValue("@v", whereVal ?? DBNull.Value);
            var o = cmd.ExecuteScalar();
            return (o == null || o == DBNull.Value) ? 0 : Convert.ToInt32(o);
        }
    };

    /* â”€â”€ POST handling â”€â”€ */
    if (IsPost && canEdit && communityId > 0 && !string.IsNullOrEmpty(connStr)) {
        var action = (Request["formAction"] ?? "").Trim();
        try {
            if (action == "cat-save") {
                var catId       = 0; int.TryParse(Request["catId"], out catId);
                var title       = (Request["title"] ?? "").Trim();
                var description = (Request["description"] ?? "").Trim();
                var icon        = (Request["icon"] ?? "").Trim();
                var isVisible   = Request["isVisible"] == "1" || Request["isVisible"] == "on" || Request["isVisible"] == "true";

                if (string.IsNullOrEmpty(title)) {
                    saveError = "Titel is verplicht.";
                    if (isAjax) { jsonOut(400, saveError, 0, "cat"); return; }
                } else {
                    var newCatId = catId;
                    using (var conn = new SqlConnection(connStr)) {
                        conn.Open();
                        if (catId > 0) {
                            using (var cmd = new SqlCommand(
                                "UPDATE CommunityDiscoverCategory SET Title=@t, Description=@d, Icon=@i, IsVisible=@v WHERE Id=@id AND CommunityId=@cid", conn)) {
                                cmd.Parameters.AddWithValue("@t",   title);
                                cmd.Parameters.AddWithValue("@d",   (object)description ?? DBNull.Value);
                                cmd.Parameters.AddWithValue("@i",   string.IsNullOrEmpty(icon)     ? (object)DBNull.Value : icon);
                                cmd.Parameters.AddWithValue("@v",   isVisible);
                                cmd.Parameters.AddWithValue("@id",  catId);
                                cmd.Parameters.AddWithValue("@cid", communityId);
                                cmd.ExecuteNonQuery();
                            }
                            saveMsg = "Categorie bijgewerkt.";
                        } else {
                            // new categories go to the end
                            var nextSort = nextSortOrder(conn, "CommunityDiscoverCategory", "CommunityId", communityId);
                            using (var cmd = new SqlCommand(
                                "INSERT INTO CommunityDiscoverCategory (CommunityId, Title, Description, Icon, IsVisible, SortOrder) OUTPUT inserted.Id VALUES (@cid, @t, @d, @i, @v, @s)", conn)) {
                                cmd.Parameters.AddWithValue("@cid", communityId);
                                cmd.Parameters.AddWithValue("@t",   title);
                                cmd.Parameters.AddWithValue("@d",   (object)description ?? DBNull.Value);
                                cmd.Parameters.AddWithValue("@i",   string.IsNullOrEmpty(icon)     ? (object)DBNull.Value : icon);
                                cmd.Parameters.AddWithValue("@v",   isVisible);
                                cmd.Parameters.AddWithValue("@s",   nextSort);
                                var o = cmd.ExecuteScalar();
                                if (o != null && o != DBNull.Value) { newCatId = Convert.ToInt32(o); }
                            }
                            saveMsg = "Categorie aangemaakt.";
                        }

                        // ── If the client posted a JSON list of buttons,
                        //    update each one in this category in one go.
                        //    Per-row save buttons no longer exist; the
                        //    category "Opslaan" persists everything.
                        var btnsJson = Request["btnsJson"];
                        if (!string.IsNullOrEmpty(btnsJson) && newCatId > 0) {
                            try {
                                var jss = new System.Web.Script.Serialization.JavaScriptSerializer();
                                var rawList = jss.Deserialize<List<Dictionary<string, object>>>(btnsJson);
                                if (rawList != null) {
                                    // Compute next sort order for any inserts.
                                    var nextBtnSort = nextSortOrder(conn, "CommunityDiscoverButton", "CommunityDiscoverCategoryId", newCatId);
                                    foreach (var item in rawList) {
                                        if (item == null) { continue; }
                                        var bId = 0;
                                        object oId; if (item.TryGetValue("id", out oId) && oId != null) { int.TryParse(Convert.ToString(oId), out bId); }
                                        object oTemp; item.TryGetValue("tempId", out oTemp);
                                        var tempId = oTemp as string ?? "";
                                        object oLabel, oIcon, oUrl, oVis;
                                        item.TryGetValue("label",     out oLabel);
                                        item.TryGetValue("icon",      out oIcon);
                                        item.TryGetValue("url",       out oUrl);
                                        item.TryGetValue("isVisible", out oVis);
                                        var bLabel  = (oLabel as string ?? "").Trim();
                                        var bIcon   = (oIcon  as string ?? "").Trim();
                                        var bUrl    = normalizeUrl(oUrl as string ?? "");
                                        var bVis    = oVis is bool ? (bool)oVis : (Convert.ToString(oVis) == "1" || Convert.ToString(oVis) == "true");
                                        if (string.IsNullOrEmpty(bLabel) || string.IsNullOrEmpty(bUrl)) { continue; }
                                        if (bId > 0) {
                                            using (var cmd = new SqlCommand(
                                                "UPDATE b SET b.Label=@l, b.Icon=@i, b.Url=@u, b.IsVisible=@v "
                                              + "FROM CommunityDiscoverButton b "
                                              + "INNER JOIN CommunityDiscoverCategory c ON c.Id = b.CommunityDiscoverCategoryId "
                                              + "WHERE b.Id=@id AND b.CommunityDiscoverCategoryId=@cat AND c.CommunityId=@cid", conn)) {
                                                cmd.Parameters.AddWithValue("@l",   bLabel);
                                                cmd.Parameters.AddWithValue("@i",   string.IsNullOrEmpty(bIcon) ? (object)DBNull.Value : bIcon);
                                                cmd.Parameters.AddWithValue("@u",   bUrl);
                                                cmd.Parameters.AddWithValue("@v",   bVis);
                                                cmd.Parameters.AddWithValue("@id",  bId);
                                                cmd.Parameters.AddWithValue("@cat", newCatId);
                                                cmd.Parameters.AddWithValue("@cid", communityId);
                                                cmd.ExecuteNonQuery();
                                            }
                                        } else {
                                            // INSERT a freshly added row. Map the JS-side tempId
                                            // back to the new DB id so the client can stamp it.
                                            var insertedId = 0;
                                            using (var cmd = new SqlCommand(
                                                "INSERT INTO CommunityDiscoverButton (CommunityDiscoverCategoryId, Label, Icon, Url, IsVisible, SortOrder) "
                                              + "OUTPUT inserted.Id "
                                              + "VALUES (@cat, @l, @i, @u, @v, @s)", conn)) {
                                                cmd.Parameters.AddWithValue("@cat", newCatId);
                                                cmd.Parameters.AddWithValue("@l",   bLabel);
                                                cmd.Parameters.AddWithValue("@i",   string.IsNullOrEmpty(bIcon) ? (object)DBNull.Value : bIcon);
                                                cmd.Parameters.AddWithValue("@u",   bUrl);
                                                cmd.Parameters.AddWithValue("@v",   bVis);
                                                cmd.Parameters.AddWithValue("@s",   nextBtnSort++);
                                                var o2 = cmd.ExecuteScalar();
                                                if (o2 != null && o2 != DBNull.Value) { insertedId = Convert.ToInt32(o2); }
                                            }
                                            if (insertedId > 0 && !string.IsNullOrEmpty(tempId)) {
                                                insertsMap[tempId] = insertedId;
                                            }
                                        }
                                    }
                                }
                            } catch (Exception bex) {
                                // Surface as a soft warning; cat itself was saved.
                                saveMsg = (saveMsg ?? "") + " (Knoppen niet bijgewerkt: " + bex.Message + ")";
                            }
                        }
                    }
                    if (isAjax) { jsonOut(200, saveMsg, newCatId, "cat"); return; }
                }
            } else if (action == "cat-reorder") {
                var orderedIds = (Request["orderedIds"] ?? "").Trim();
                if (!string.IsNullOrEmpty(orderedIds)) {
                    var parts = orderedIds.Split(',');
                    using (var conn = new SqlConnection(connStr)) {
                        conn.Open();
                        for (var i = 0; i < parts.Length; i++) {
                            var pid = 0;
                            if (!int.TryParse(parts[i], out pid) || pid <= 0) { continue; }
                            using (var cmd = new SqlCommand(
                                "UPDATE CommunityDiscoverCategory SET SortOrder=@s WHERE Id=@id AND CommunityId=@cid", conn)) {
                                cmd.Parameters.AddWithValue("@s",   i);
                                cmd.Parameters.AddWithValue("@id",  pid);
                                cmd.Parameters.AddWithValue("@cid", communityId);
                                cmd.ExecuteNonQuery();
                            }
                        }
                    }
                    Response.StatusCode = 204;
                    Response.SuppressContent = true;
                    Context.ApplicationInstance.CompleteRequest();
                    return;
                }
            } else if (action == "cat-delete") {
                var catId = 0; int.TryParse(Request["catId"], out catId);
                if (catId > 0) {
                    using (var conn = new SqlConnection(connStr)) {
                        conn.Open();
                        using (var cmd = new SqlCommand(
                            "DELETE FROM CommunityDiscoverCategory WHERE Id=@id AND CommunityId=@cid", conn)) {
                            cmd.Parameters.AddWithValue("@id",  catId);
                            cmd.Parameters.AddWithValue("@cid", communityId);
                            cmd.ExecuteNonQuery();
                        }
                    }
                    saveMsg = "Categorie verwijderd.";
                    if (isAjax) { jsonOut(200, saveMsg, catId, "cat"); return; }
                }
            } else if (action == "btn-save") {
                var btnId     = 0; int.TryParse(Request["btnId"], out btnId);
                var catId     = 0; int.TryParse(Request["catId"], out catId);
                var label     = (Request["label"] ?? "").Trim();
                var icon      = (Request["icon"]  ?? "").Trim();
                var url       = normalizeUrl(Request["url"] ?? "");
                var isVisible = Request["isVisible"] == "1" || Request["isVisible"] == "on" || Request["isVisible"] == "true";

                if (catId <= 0 || string.IsNullOrEmpty(label) || string.IsNullOrEmpty(url)) {
                    saveError = "Categorie, label en URL zijn verplicht.";
                    if (isAjax) { jsonOut(400, saveError, 0, "btn"); return; }
                } else {
                    var newBtnId = btnId;
                    using (var conn = new SqlConnection(connStr)) {
                        conn.Open();
                        var ownsCat = false;
                        using (var chk = new SqlCommand(
                            "SELECT 1 FROM CommunityDiscoverCategory WHERE Id=@id AND CommunityId=@cid", conn)) {
                            chk.Parameters.AddWithValue("@id",  catId);
                            chk.Parameters.AddWithValue("@cid", communityId);
                            ownsCat = chk.ExecuteScalar() != null;
                        }
                        if (!ownsCat) {
                            saveError = "Categorie hoort niet bij deze community.";
                        } else if (btnId > 0) {
                            using (var cmd = new SqlCommand(
                                "UPDATE CommunityDiscoverButton SET Label=@l, Icon=@i, Url=@u, IsVisible=@v WHERE Id=@id AND CommunityDiscoverCategoryId=@cat", conn)) {
                                cmd.Parameters.AddWithValue("@l",   label);
                                cmd.Parameters.AddWithValue("@i",   string.IsNullOrEmpty(icon) ? (object)DBNull.Value : icon);
                                cmd.Parameters.AddWithValue("@u",   url);
                                cmd.Parameters.AddWithValue("@v",   isVisible);
                                cmd.Parameters.AddWithValue("@id",  btnId);
                                cmd.Parameters.AddWithValue("@cat", catId);
                                cmd.ExecuteNonQuery();
                            }
                            saveMsg = "Knop bijgewerkt.";
                        } else {
                            var nextSort = nextSortOrder(conn, "CommunityDiscoverButton", "CommunityDiscoverCategoryId", catId);
                            using (var cmd = new SqlCommand(
                                "INSERT INTO CommunityDiscoverButton (CommunityDiscoverCategoryId, Label, Icon, Url, IsVisible, SortOrder) OUTPUT inserted.Id VALUES (@cat, @l, @i, @u, @v, @s)", conn)) {
                                cmd.Parameters.AddWithValue("@cat", catId);
                                cmd.Parameters.AddWithValue("@l",   label);
                                cmd.Parameters.AddWithValue("@i",   string.IsNullOrEmpty(icon) ? (object)DBNull.Value : icon);
                                cmd.Parameters.AddWithValue("@u",   url);
                                cmd.Parameters.AddWithValue("@v",   isVisible);
                                cmd.Parameters.AddWithValue("@s",   nextSort);
                                var o = cmd.ExecuteScalar();
                                if (o != null && o != DBNull.Value) { newBtnId = Convert.ToInt32(o); }
                            }
                            saveMsg = "Knop toegevoegd.";
                        }
                    }
                    if (isAjax) {
                        if (!string.IsNullOrEmpty(saveError)) { jsonOut(400, saveError, 0, "btn"); return; }
                        jsonOut(200, saveMsg, newBtnId, "btn"); return;
                    }
                }
            } else if (action == "btn-reorder") {
                var catId      = 0; int.TryParse(Request["catId"], out catId);
                var orderedIds = (Request["orderedIds"] ?? "").Trim();
                if (catId > 0 && !string.IsNullOrEmpty(orderedIds)) {
                    var parts = orderedIds.Split(',');
                    using (var conn = new SqlConnection(connStr)) {
                        conn.Open();
                        // verify category belongs to community
                        var ownsCat = false;
                        using (var chk = new SqlCommand(
                            "SELECT 1 FROM CommunityDiscoverCategory WHERE Id=@id AND CommunityId=@cid", conn)) {
                            chk.Parameters.AddWithValue("@id",  catId);
                            chk.Parameters.AddWithValue("@cid", communityId);
                            ownsCat = chk.ExecuteScalar() != null;
                        }
                        if (ownsCat) {
                            for (var i = 0; i < parts.Length; i++) {
                                var pid = 0;
                                if (!int.TryParse(parts[i], out pid) || pid <= 0) { continue; }
                                using (var cmd = new SqlCommand(
                                    "UPDATE CommunityDiscoverButton SET SortOrder=@s WHERE Id=@id AND CommunityDiscoverCategoryId=@cat", conn)) {
                                    cmd.Parameters.AddWithValue("@s",   i);
                                    cmd.Parameters.AddWithValue("@id",  pid);
                                    cmd.Parameters.AddWithValue("@cat", catId);
                                    cmd.ExecuteNonQuery();
                                }
                            }
                        }
                    }
                    Response.StatusCode = 204;
                    Response.SuppressContent = true;
                    Context.ApplicationInstance.CompleteRequest();
                    return;
                }
            } else if (action == "btn-delete") {
                var btnId = 0; int.TryParse(Request["btnId"], out btnId);
                if (btnId > 0) {
                    using (var conn = new SqlConnection(connStr)) {
                        conn.Open();
                        using (var cmd = new SqlCommand(
                            "DELETE b FROM CommunityDiscoverButton b INNER JOIN CommunityDiscoverCategory c ON c.Id = b.CommunityDiscoverCategoryId WHERE b.Id=@id AND c.CommunityId=@cid", conn)) {
                            cmd.Parameters.AddWithValue("@id",  btnId);
                            cmd.Parameters.AddWithValue("@cid", communityId);
                            cmd.ExecuteNonQuery();
                        }
                    }
                    saveMsg = "Knop verwijderd.";
                    if (isAjax) { jsonOut(200, saveMsg, btnId, "btn"); return; }
                }
            }
        } catch (Exception ex) {
            saveError = "Fout: " + ex.Message;
            if (isAjax) { jsonOut(500, saveError, 0, action); return; }
        }
    }

    /* â”€â”€ Load categories + buttons â”€â”€ */
    var categories   = new List<Dictionary<string, object>>();
    var buttonsByCat = new Dictionary<int, List<Dictionary<string, object>>>();

    if (canEdit && communityId > 0 && !string.IsNullOrEmpty(connStr)) {
        try {
            using (var conn = new SqlConnection(connStr)) {
                conn.Open();
                using (var cmd = new SqlCommand(
                    "SELECT Id, Title, Description, Icon, IsVisible, SortOrder FROM CommunityDiscoverCategory WHERE CommunityId=@cid ORDER BY SortOrder, Id", conn)) {
                    cmd.Parameters.AddWithValue("@cid", communityId);
                    using (var r = cmd.ExecuteReader()) {
                        while (r.Read()) {
                            categories.Add(new Dictionary<string, object> {
                                { "Id",          r.GetInt32(0) },
                                { "Title",       r.GetString(1) },
                                { "Description", r.IsDBNull(2) ? "" : r.GetString(2) },
                                { "Icon",        r.IsDBNull(3) ? "" : r.GetString(3) },
                                { "IsVisible",   r.GetBoolean(4) },
                                { "SortOrder",   r.GetInt32(5) }
                            });
                        }
                    }
                }
                using (var cmd = new SqlCommand(
                    "SELECT b.Id, b.CommunityDiscoverCategoryId, b.Label, b.Icon, b.Url, b.IsVisible, b.SortOrder FROM CommunityDiscoverButton b INNER JOIN CommunityDiscoverCategory c ON c.Id = b.CommunityDiscoverCategoryId WHERE c.CommunityId=@cid ORDER BY b.SortOrder, b.Id", conn)) {
                    cmd.Parameters.AddWithValue("@cid", communityId);
                    using (var r = cmd.ExecuteReader()) {
                        while (r.Read()) {
                            var catId = r.GetInt32(1);
                            if (!buttonsByCat.ContainsKey(catId)) {
                                buttonsByCat[catId] = new List<Dictionary<string, object>>();
                            }
                            buttonsByCat[catId].Add(new Dictionary<string, object> {
                                { "Id",        r.GetInt32(0) },
                                { "CatId",     catId },
                                { "Label",     r.GetString(2) },
                                { "Icon",      r.IsDBNull(3) ? "" : r.GetString(3) },
                                { "Url",       r.GetString(4) },
                                { "IsVisible", r.GetBoolean(5) },
                                { "SortOrder", r.GetInt32(6) }
                            });
                        }
                    }
                }
            }
        } catch (Exception ex) {
            saveError = string.IsNullOrEmpty(saveError) ? "Laden mislukt: " + ex.Message : saveError;
        }
    }

    /* ── Publish to PageData (so the partials below can read it) ── */
    PageData["communityName"] = communityName;
    PageData["communitySlug"] = communitySlug;
    PageData["saveMsg"]       = saveMsg;
    PageData["saveError"]     = saveError;
    PageData["requestUrl"]    = Request.RawUrl;
}

<section class="w-full max-w-5xl m-auto flex flex-col gap-6"
         data-module-id="@Dnn.Module.ModuleID" data-tab-id="@Dnn.Tab.TabID">

    @RenderPage("Shared/DiscoverEdit/_FormHeader.cshtml")

    @if (!canEdit) {
        @RenderPage("Shared/DiscoverEdit/_AccessDenied.cshtml")
    } else if (communityId <= 0) {
        @RenderPage("Shared/DiscoverEdit/_NoCommunity.cshtml")
    } else {
        @RenderPage("Shared/DiscoverEdit/_SaveAlerts.cshtml")

        if (categories.Count > 0) {
            @(new System.Web.HtmlString("<div class=\"flex flex-col gap-4\" data-sortable=\"cat\" data-reorder-url=\"" + System.Web.HttpUtility.HtmlAttributeEncode(Request.RawUrl) + "\">"))

            foreach (var cat in categories) {
                var catId = (int)cat["Id"];
                var btns  = buttonsByCat.ContainsKey(catId) ? buttonsByCat[catId] : new List<Dictionary<string, object>>();
                PageData["cat"]  = cat;
                PageData["btns"] = btns;
                @RenderPage("Shared/DiscoverEdit/_CategoryItem.cshtml")
            }

            @(new System.Web.HtmlString("</div>"))
        }

        @RenderPage("Shared/DiscoverEdit/_AddCategoryForm.cshtml")
    }
</section>

@if (canEdit && communityId > 0) {
    @RenderPage("Shared/DiscoverEdit/_Scripts.cshtml")
}

