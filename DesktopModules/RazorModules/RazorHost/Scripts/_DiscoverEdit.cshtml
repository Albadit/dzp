@using DZP.CommunityAuth
@using DotNetNuke.Entities.Portals
@using System.Web
@using System.Data.SqlClient
@using System.Configuration
@using System.Linq
@*
    Discovery edit page.
    Manage CommunityDiscoverCategory + CommunityDiscoverButton rows for
    the current community. Inline POST handlers for create/update/delete
    on both entities. Auth: SuperUser, Administrator, or Community
    beheerder. Styling matches _CommunityHome / _GeneralInfo cards.
*@
@{
    var rc       = CommunityAuth.Current;
    var user     = Dnn.User;

    var communityName = rc != null ? rc.CommunityName : "Community";
    var communitySlug = rc != null ? rc.CommunitySlug : "";
    var communityId   = rc != null ? rc.CommunityId   : 0;

    var cs      = ConfigurationManager.ConnectionStrings["SiteSqlServer"];
    var connStr = cs != null ? cs.ConnectionString : "";

    var isSuperUser     = user != null && user.IsSuperUser;
    var adminRoleName   = PortalSettings.Current != null ? PortalSettings.Current.AdministratorRoleName : "Administrators";
    var isAdministrator = user != null && !string.IsNullOrEmpty(adminRoleName) && user.IsInRole(adminRoleName);
    var isCommunityMgr  = user != null && user.IsInRole("Community beheerder");
    var canEdit         = isSuperUser || isAdministrator || isCommunityMgr;

    var saveMsg   = "";
    var saveError = "";

    /* ── POST handling ── */
    if (IsPost && canEdit && communityId > 0 && !string.IsNullOrEmpty(connStr)) {
        var action = (Request["formAction"] ?? "").Trim();
        try {
            if (action == "cat-save") {
                var catId       = 0; int.TryParse(Request["catId"], out catId);
                var title       = (Request["title"] ?? "").Trim();
                var description = (Request["description"] ?? "").Trim();
                var icon        = (Request["icon"] ?? "").Trim();
                var imageUrl    = (Request["imageUrl"] ?? "").Trim();
                var isVisible   = Request["isVisible"] == "1" || Request["isVisible"] == "on" || Request["isVisible"] == "true";

                if (string.IsNullOrEmpty(title)) {
                    saveError = "Titel is verplicht.";
                } else {
                    using (var conn = new SqlConnection(connStr)) {
                        conn.Open();
                        if (catId > 0) {
                            using (var cmd = new SqlCommand(
                                "UPDATE CommunityDiscoverCategory SET Title=@t, Description=@d, Icon=@i, ImageUrl=@u, IsVisible=@v WHERE Id=@id AND CommunityId=@cid", conn)) {
                                cmd.Parameters.AddWithValue("@t",   title);
                                cmd.Parameters.AddWithValue("@d",   (object)description ?? DBNull.Value);
                                cmd.Parameters.AddWithValue("@i",   string.IsNullOrEmpty(icon)     ? (object)DBNull.Value : icon);
                                cmd.Parameters.AddWithValue("@u",   string.IsNullOrEmpty(imageUrl) ? (object)DBNull.Value : imageUrl);
                                cmd.Parameters.AddWithValue("@v",   isVisible);
                                cmd.Parameters.AddWithValue("@id",  catId);
                                cmd.Parameters.AddWithValue("@cid", communityId);
                                cmd.ExecuteNonQuery();
                            }
                            saveMsg = "Categorie bijgewerkt.";
                        } else {
                            // new categories go to the end
                            var nextSort = 0;
                            using (var s = new SqlCommand("SELECT ISNULL(MAX(SortOrder), -1) + 1 FROM CommunityDiscoverCategory WHERE CommunityId=@cid", conn)) {
                                s.Parameters.AddWithValue("@cid", communityId);
                                var o = s.ExecuteScalar();
                                if (o != null && o != DBNull.Value) { nextSort = Convert.ToInt32(o); }
                            }
                            using (var cmd = new SqlCommand(
                                "INSERT INTO CommunityDiscoverCategory (CommunityId, Title, Description, Icon, ImageUrl, IsVisible, SortOrder) VALUES (@cid, @t, @d, @i, @u, @v, @s)", conn)) {
                                cmd.Parameters.AddWithValue("@cid", communityId);
                                cmd.Parameters.AddWithValue("@t",   title);
                                cmd.Parameters.AddWithValue("@d",   (object)description ?? DBNull.Value);
                                cmd.Parameters.AddWithValue("@i",   string.IsNullOrEmpty(icon)     ? (object)DBNull.Value : icon);
                                cmd.Parameters.AddWithValue("@u",   string.IsNullOrEmpty(imageUrl) ? (object)DBNull.Value : imageUrl);
                                cmd.Parameters.AddWithValue("@v",   isVisible);
                                cmd.Parameters.AddWithValue("@s",   nextSort);
                                cmd.ExecuteNonQuery();
                            }
                            saveMsg = "Categorie aangemaakt.";
                        }
                    }
                }
            } else if (action == "cat-reorder") {
                var orderedIds = (Request["orderedIds"] ?? "").Trim();
                if (!string.IsNullOrEmpty(orderedIds)) {
                    var parts = orderedIds.Split(',');
                    using (var conn = new SqlConnection(connStr)) {
                        conn.Open();
                        for (var i = 0; i < parts.Length; i++) {
                            var pid = 0;
                            if (!int.TryParse(parts[i], out pid) || pid <= 0) { continue; }
                            using (var cmd = new SqlCommand(
                                "UPDATE CommunityDiscoverCategory SET SortOrder=@s WHERE Id=@id AND CommunityId=@cid", conn)) {
                                cmd.Parameters.AddWithValue("@s",   i);
                                cmd.Parameters.AddWithValue("@id",  pid);
                                cmd.Parameters.AddWithValue("@cid", communityId);
                                cmd.ExecuteNonQuery();
                            }
                        }
                    }
                    Response.StatusCode = 204;
                    Response.End();
                    return;
                }
            } else if (action == "cat-delete") {
                var catId = 0; int.TryParse(Request["catId"], out catId);
                if (catId > 0) {
                    using (var conn = new SqlConnection(connStr)) {
                    using (var cmd = new SqlCommand(
                        "DELETE FROM CommunityDiscoverCategory WHERE Id=@id AND CommunityId=@cid", conn)) {
                        cmd.Parameters.AddWithValue("@id",  catId);
                        cmd.Parameters.AddWithValue("@cid", communityId);
                        conn.Open();
                        cmd.ExecuteNonQuery();
                    }
                    }
                    saveMsg = "Categorie verwijderd.";
                }
            } else if (action == "btn-save") {
                var btnId     = 0; int.TryParse(Request["btnId"], out btnId);
                var catId     = 0; int.TryParse(Request["catId"], out catId);
                var label     = (Request["label"] ?? "").Trim();
                var icon      = (Request["icon"]  ?? "").Trim();
                var url       = (Request["url"]   ?? "").Trim();
                var isVisible = Request["isVisible"] == "1" || Request["isVisible"] == "on" || Request["isVisible"] == "true";

                if (catId <= 0 || string.IsNullOrEmpty(label) || string.IsNullOrEmpty(url)) {
                    saveError = "Categorie, label en URL zijn verplicht.";
                } else {
                    using (var conn = new SqlConnection(connStr)) {
                        conn.Open();
                        var ownsCat = false;
                        using (var chk = new SqlCommand(
                            "SELECT 1 FROM CommunityDiscoverCategory WHERE Id=@id AND CommunityId=@cid", conn)) {
                            chk.Parameters.AddWithValue("@id",  catId);
                            chk.Parameters.AddWithValue("@cid", communityId);
                            ownsCat = chk.ExecuteScalar() != null;
                        }
                        if (!ownsCat) {
                            saveError = "Categorie hoort niet bij deze community.";
                        } else if (btnId > 0) {
                            using (var cmd = new SqlCommand(
                                "UPDATE CommunityDiscoverButton SET Label=@l, Icon=@i, Url=@u, IsVisible=@v WHERE Id=@id AND CommunityDiscoverCategoryId=@cat", conn)) {
                                cmd.Parameters.AddWithValue("@l",   label);
                                cmd.Parameters.AddWithValue("@i",   string.IsNullOrEmpty(icon) ? (object)DBNull.Value : icon);
                                cmd.Parameters.AddWithValue("@u",   url);
                                cmd.Parameters.AddWithValue("@v",   isVisible);
                                cmd.Parameters.AddWithValue("@id",  btnId);
                                cmd.Parameters.AddWithValue("@cat", catId);
                                cmd.ExecuteNonQuery();
                            }
                            saveMsg = "Knop bijgewerkt.";
                        } else {
                            var nextSort = 0;
                            using (var s = new SqlCommand("SELECT ISNULL(MAX(SortOrder), -1) + 1 FROM CommunityDiscoverButton WHERE CommunityDiscoverCategoryId=@cat", conn)) {
                                s.Parameters.AddWithValue("@cat", catId);
                                var o = s.ExecuteScalar();
                                if (o != null && o != DBNull.Value) { nextSort = Convert.ToInt32(o); }
                            }
                            using (var cmd = new SqlCommand(
                                "INSERT INTO CommunityDiscoverButton (CommunityDiscoverCategoryId, Label, Icon, Url, IsVisible, SortOrder) VALUES (@cat, @l, @i, @u, @v, @s)", conn)) {
                                cmd.Parameters.AddWithValue("@cat", catId);
                                cmd.Parameters.AddWithValue("@l",   label);
                                cmd.Parameters.AddWithValue("@i",   string.IsNullOrEmpty(icon) ? (object)DBNull.Value : icon);
                                cmd.Parameters.AddWithValue("@u",   url);
                                cmd.Parameters.AddWithValue("@v",   isVisible);
                                cmd.Parameters.AddWithValue("@s",   nextSort);
                                cmd.ExecuteNonQuery();
                            }
                            saveMsg = "Knop toegevoegd.";
                        }
                    }
                }
            } else if (action == "btn-reorder") {
                var catId      = 0; int.TryParse(Request["catId"], out catId);
                var orderedIds = (Request["orderedIds"] ?? "").Trim();
                if (catId > 0 && !string.IsNullOrEmpty(orderedIds)) {
                    var parts = orderedIds.Split(',');
                    using (var conn = new SqlConnection(connStr)) {
                        conn.Open();
                        // verify category belongs to community
                        var ownsCat = false;
                        using (var chk = new SqlCommand(
                            "SELECT 1 FROM CommunityDiscoverCategory WHERE Id=@id AND CommunityId=@cid", conn)) {
                            chk.Parameters.AddWithValue("@id",  catId);
                            chk.Parameters.AddWithValue("@cid", communityId);
                            ownsCat = chk.ExecuteScalar() != null;
                        }
                        if (ownsCat) {
                            for (var i = 0; i < parts.Length; i++) {
                                var pid = 0;
                                if (!int.TryParse(parts[i], out pid) || pid <= 0) { continue; }
                                using (var cmd = new SqlCommand(
                                    "UPDATE CommunityDiscoverButton SET SortOrder=@s WHERE Id=@id AND CommunityDiscoverCategoryId=@cat", conn)) {
                                    cmd.Parameters.AddWithValue("@s",   i);
                                    cmd.Parameters.AddWithValue("@id",  pid);
                                    cmd.Parameters.AddWithValue("@cat", catId);
                                    cmd.ExecuteNonQuery();
                                }
                            }
                        }
                    }
                    Response.StatusCode = 204;
                    Response.End();
                    return;
                }
            } else if (action == "btn-delete") {
                var btnId = 0; int.TryParse(Request["btnId"], out btnId);
                if (btnId > 0) {
                    using (var conn = new SqlConnection(connStr)) {
                    using (var cmd = new SqlCommand(
                        "DELETE b FROM CommunityDiscoverButton b INNER JOIN CommunityDiscoverCategory c ON c.Id = b.CommunityDiscoverCategoryId WHERE b.Id=@id AND c.CommunityId=@cid", conn)) {
                        cmd.Parameters.AddWithValue("@id",  btnId);
                        cmd.Parameters.AddWithValue("@cid", communityId);
                        conn.Open();
                        cmd.ExecuteNonQuery();
                    }
                    }
                    saveMsg = "Knop verwijderd.";
                }
            }
        } catch (Exception ex) {
            saveError = "Fout: " + ex.Message;
        }
    }

    /* ── Load categories + buttons ── */
    var categories   = new List<Dictionary<string, object>>();
    var buttonsByCat = new Dictionary<int, List<Dictionary<string, object>>>();

    if (canEdit && communityId > 0 && !string.IsNullOrEmpty(connStr)) {
        try {
            using (var conn = new SqlConnection(connStr)) {
                conn.Open();
                using (var cmd = new SqlCommand(
                    "SELECT Id, Title, Description, Icon, ImageUrl, IsVisible, SortOrder FROM CommunityDiscoverCategory WHERE CommunityId=@cid ORDER BY SortOrder, Id", conn)) {
                    cmd.Parameters.AddWithValue("@cid", communityId);
                    using (var r = cmd.ExecuteReader()) {
                        while (r.Read()) {
                            categories.Add(new Dictionary<string, object> {
                                { "Id",          r.GetInt32(0) },
                                { "Title",       r.GetString(1) },
                                { "Description", r.IsDBNull(2) ? "" : r.GetString(2) },
                                { "Icon",        r.IsDBNull(3) ? "" : r.GetString(3) },
                                { "ImageUrl",    r.IsDBNull(4) ? "" : r.GetString(4) },
                                { "IsVisible",   r.GetBoolean(5) },
                                { "SortOrder",   r.GetInt32(6) }
                            });
                        }
                    }
                }
                using (var cmd = new SqlCommand(
                    "SELECT b.Id, b.CommunityDiscoverCategoryId, b.Label, b.Icon, b.Url, b.IsVisible, b.SortOrder FROM CommunityDiscoverButton b INNER JOIN CommunityDiscoverCategory c ON c.Id = b.CommunityDiscoverCategoryId WHERE c.CommunityId=@cid ORDER BY b.SortOrder, b.Id", conn)) {
                    cmd.Parameters.AddWithValue("@cid", communityId);
                    using (var r = cmd.ExecuteReader()) {
                        while (r.Read()) {
                            var catId = r.GetInt32(1);
                            if (!buttonsByCat.ContainsKey(catId)) {
                                buttonsByCat[catId] = new List<Dictionary<string, object>>();
                            }
                            buttonsByCat[catId].Add(new Dictionary<string, object> {
                                { "Id",        r.GetInt32(0) },
                                { "CatId",     catId },
                                { "Label",     r.GetString(2) },
                                { "Icon",      r.IsDBNull(3) ? "" : r.GetString(3) },
                                { "Url",       r.GetString(4) },
                                { "IsVisible", r.GetBoolean(5) },
                                { "SortOrder", r.GetInt32(6) }
                            });
                        }
                    }
                }
            }
        } catch (Exception ex) {
            saveError = string.IsNullOrEmpty(saveError) ? "Laden mislukt: " + ex.Message : saveError;
        }
    }
}

<section class="w-full max-w-5xl m-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col gap-6">

    <!-- Header -->
    <div class="flex flex-wrap items-start justify-between gap-3">
        <div class="flex flex-col gap-1 min-w-0">
            <h1 class="text-3xl font-bold text-foreground-900">Ondekt beheren</h1>
            <p class="text-sm text-foreground-500">Beheer de Ondekt-categorieën en knoppen voor <strong>@communityName</strong>.</p>
        </div>
        @if (!string.IsNullOrEmpty(communitySlug)) {
            <a href="/@communitySlug/discover"
               class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-divider bg-background text-sm font-medium text-foreground-700 hover:border-primary hover:text-primary transition shrink-0">
                <i data-lucide="eye" class="size-4"></i>
                <span>Bekijk Ondekt</span>
            </a>
        }
    </div>

    @if (!canEdit) {
        <div class="p-4 rounded-xl border border-warning/30 bg-warning/5 text-sm text-foreground-700">
            Je hebt geen rechten om deze pagina te bewerken.
        </div>
        return;
    }
    @if (communityId <= 0) {
        <div class="p-4 rounded-xl border border-warning/30 bg-warning/5 text-sm text-foreground-700">
            Geen community geselecteerd.
        </div>
        return;
    }

    @if (!string.IsNullOrEmpty(saveMsg)) {
        <div class="p-3 rounded-xl border border-success/30 bg-success/5 text-sm text-success-700 flex items-center gap-2">
            <i data-lucide="check-circle-2" class="size-4"></i><span>@saveMsg</span>
        </div>
    }
    @if (!string.IsNullOrEmpty(saveError)) {
        <div class="p-3 rounded-xl border border-danger/30 bg-danger/5 text-sm text-danger-700 flex items-center gap-2">
            <i data-lucide="alert-circle" class="size-4"></i><span>@saveError</span>
        </div>
    }

    <!-- Add new category -->
    <div class="bg-content1 rounded-xl border border-divider p-5 sm:p-6">
        <details>
            <summary class="cursor-pointer flex items-center gap-2 text-base font-semibold text-foreground-900 hover:text-primary transition">
                <i data-lucide="plus-circle" class="size-5 text-primary"></i>
                <span>Nieuwe categorie toevoegen</span>
            </summary>
            <form method="post" class="mt-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
                <input type="hidden" name="formAction" value="cat-save" />
                <input type="hidden" name="catId" value="0" />

                <div class="flex flex-col gap-1.5 sm:col-span-2">
                    <label for="newCatTitle" class="text-sm font-medium text-foreground-700">Titel <span class="text-danger">*</span></label>
                    @{
                        PageData["id"]       = "newCatTitle";
                        PageData["name"]     = "title";
                        PageData["required"] = true;
                    }
                    @RenderPage("Shared/Components/_Input.cshtml")
                </div>

                <div class="flex flex-col gap-1.5 sm:col-span-2">
                    <label for="newCatDesc" class="text-sm font-medium text-foreground-700">Beschrijving</label>
                    @{
                        PageData["id"]   = "newCatDesc";
                        PageData["name"] = "description";
                        PageData["rows"] = 3;
                    }
                    @RenderPage("Shared/Components/_Textarea.cshtml")
                </div>

                <div class="flex flex-col gap-1.5 sm:col-span-2">
                    <label for="newCatIcon" class="text-sm font-medium text-foreground-700">Lucide icon</label>
                    @{
                        PageData["id"]          = "newCatIcon";
                        PageData["name"]        = "icon";
                        PageData["placeholder"] = "bijv. map-pin";
                    }
                    @RenderPage("Shared/Components/_Input.cshtml")
                </div>

                <div class="flex flex-col gap-1.5 sm:col-span-2">
                    <label class="text-sm font-medium text-foreground-700">Afbeelding (alternatief voor icon)</label>
                    @{
                        PageData["name"]  = "imageUrl";
                        PageData["id"]    = "newCatImage";
                        PageData["value"] = "";
                    }
                    @RenderPage("Shared/Components/_Dropzone.cshtml")
                </div>

                <label class="flex items-center gap-2 sm:col-span-2">
                    <input type="checkbox" name="isVisible" value="1" checked class="size-4 accent-primary" />
                    <span class="text-sm text-foreground-700">Zichtbaar op de Ondekt-pagina</span>
                </label>

                <div class="sm:col-span-2 flex justify-end">
                    <button type="submit" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-primary/90 transition">
                        <i data-lucide="plus" class="size-4"></i>
                        <span>Categorie toevoegen</span>
                    </button>
                </div>
            </form>
        </details>
    </div>

    <!-- Existing categories -->
    @if (categories.Count == 0) {
        <div class="bg-content1 rounded-xl border border-divider p-8 text-center">
            <i data-lucide="folder-open" class="size-10 text-foreground-300 mx-auto mb-2"></i>
            <p class="text-sm text-foreground-500">Nog geen categorieën. Voeg er hierboven één toe.</p>
        </div>
    }

    @if (categories.Count > 0) {
        @Html.Raw("<div class=\"flex flex-col gap-4\" data-sortable=\"cat\" data-reorder-url=\"" + System.Web.HttpUtility.HtmlAttributeEncode(Request.RawUrl) + "\">")
    }

    @foreach (var cat in categories) {
        var catId      = (int)cat["Id"];
        var catTitle   = (string)cat["Title"];
        var catDesc    = (string)cat["Description"];
        var catIcon    = (string)cat["Icon"];
        var catImage   = (string)cat["ImageUrl"];
        var catVisible = (bool)cat["IsVisible"];
        var btns       = buttonsByCat.ContainsKey(catId) ? buttonsByCat[catId] : new List<Dictionary<string, object>>();

        <div class="dt-sort-item bg-content1 rounded-xl border border-divider overflow-hidden" data-id="@catId">
            <details>
                <summary class="cursor-pointer flex items-center gap-3 p-5 sm:p-6 hover:bg-content2/50 transition">
                    <span class="dt-sort-handle shrink-0 inline-flex items-center justify-center size-8 rounded-md text-foreground-400 hover:text-foreground-700 hover:bg-content2 cursor-grab active:cursor-grabbing"
                          title="Sleep om te verplaatsen"
                          onclick="event.preventDefault(); event.stopPropagation();">
                        <i data-lucide="grip-vertical" class="size-4"></i>
                    </span>
                    <div class="size-10 rounded-lg flex items-center justify-center bg-primary/10 shrink-0 overflow-hidden">
                        @if (!string.IsNullOrEmpty(catImage)) {
                            <img src="@catImage" alt="" class="w-full h-full object-cover" />
                        } else if (!string.IsNullOrEmpty(catIcon)) {
                            <i data-lucide="@catIcon" class="size-5 text-primary"></i>
                        } else {
                            <span class="text-sm font-bold text-primary">@(catTitle.Length > 0 ? catTitle.Substring(0, 1).ToUpper() : "?")</span>
                        }
                    </div>
                    <div class="flex-1 min-w-0">
                        <h2 class="text-base font-semibold text-foreground-900 truncate">@catTitle</h2>
                        <p class="text-xs text-foreground-500 truncate">@btns.Count knop@(btns.Count == 1 ? "" : "pen")</p>
                    </div>
                    @if (!catVisible) {
                        <span class="shrink-0 text-xs px-2 py-1 rounded-full bg-warning/10 text-warning-700 font-medium">verborgen</span>
                    }
                    <i data-lucide="chevron-down" class="size-5 text-foreground-400 shrink-0"></i>
                </summary>

                <!-- Category edit form -->
                <div class="border-t border-divider p-5 sm:p-6">
                    <form method="post" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <input type="hidden" name="formAction" value="cat-save" />
                        <input type="hidden" name="catId" value="@catId" />

                        <div class="flex flex-col gap-1.5 sm:col-span-2">
                            <label class="text-sm font-medium text-foreground-700">Titel <span class="text-danger">*</span></label>
                            @{
                                PageData["id"]       = "catTitle_" + catId;
                                PageData["name"]     = "title";
                                PageData["value"]    = catTitle;
                                PageData["required"] = true;
                            }
                            @RenderPage("Shared/Components/_Input.cshtml")
                        </div>

                        <div class="flex flex-col gap-1.5 sm:col-span-2">
                            <label class="text-sm font-medium text-foreground-700">Beschrijving</label>
                            @{
                                PageData["id"]    = "catDesc_" + catId;
                                PageData["name"]  = "description";
                                PageData["value"] = catDesc;
                                PageData["rows"]  = 3;
                            }
                            @RenderPage("Shared/Components/_Textarea.cshtml")
                        </div>

                        <div class="flex flex-col gap-1.5 sm:col-span-2">
                            <label class="text-sm font-medium text-foreground-700">Lucide icon</label>
                            @{
                                PageData["id"]          = "catIcon_" + catId;
                                PageData["name"]        = "icon";
                                PageData["value"]       = catIcon;
                                PageData["placeholder"] = "bijv. map-pin";
                            }
                            @RenderPage("Shared/Components/_Input.cshtml")
                        </div>

                        <div class="flex flex-col gap-1.5 sm:col-span-2">
                            <label class="text-sm font-medium text-foreground-700">Afbeelding (alternatief voor icon)</label>
                            @{
                                PageData["id"]    = "catImage_" + catId;
                                PageData["name"]  = "imageUrl";
                                PageData["value"] = catImage;
                            }
                            @RenderPage("Shared/Components/_Dropzone.cshtml")
                        </div>

                        <label class="flex items-center gap-2 sm:col-span-2">
                            <input type="checkbox" name="isVisible" value="1" @(catVisible ? "checked" : "") class="size-4 accent-primary" />
                            <span class="text-sm text-foreground-700">Zichtbaar op de Ondekt-pagina</span>
                        </label>

                        <div class="sm:col-span-2 flex flex-wrap items-center justify-between gap-3 pt-2 border-t border-divider">
                            <button type="submit" name="formAction" value="cat-delete"
                                    onclick="return confirm('Categorie en alle knoppen verwijderen?');"
                                    class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-danger/30 text-danger-700 text-sm font-medium hover:bg-danger/5 transition">
                                <i data-lucide="trash-2" class="size-4"></i>
                                <span>Verwijderen</span>
                            </button>
                            <button type="submit"
                                    class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-primary/90 transition">
                                <i data-lucide="save" class="size-4"></i>
                                <span>Opslaan</span>
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Buttons section -->
                <div class="border-t border-divider bg-content2/30 p-5 sm:p-6">
                    <h3 class="text-xs font-bold uppercase tracking-wider text-foreground-500 mb-3">Knoppen</h3>

                    @if (btns.Count == 0) {
                        <p class="text-sm text-foreground-400 italic mb-4">Nog geen knoppen in deze categorie.</p>
                    }

                    <div class="flex flex-col gap-3"
                         data-sortable="btn"
                         data-cat-id="@catId"
                         data-reorder-url="@Request.RawUrl">
                        @foreach (var b in btns) {
                            var bId      = (int)b["Id"];
                            var bLabel   = (string)b["Label"];
                            var bIcon    = (string)b["Icon"];
                            var bUrl     = (string)b["Url"];
                            var bVisible = (bool)b["IsVisible"];
                            <form method="post" class="dt-sort-item bg-content1 rounded-lg border border-divider p-4 grid grid-cols-1 sm:grid-cols-12 gap-3 items-end" data-id="@bId">
                                <input type="hidden" name="formAction" value="btn-save" />
                                <input type="hidden" name="catId"      value="@catId" />
                                <input type="hidden" name="btnId"      value="@bId" />

                                <div class="sm:col-span-1 flex items-center justify-center pb-2">
                                    <span class="dt-sort-handle inline-flex items-center justify-center size-8 rounded-md text-foreground-400 hover:text-foreground-700 hover:bg-content2 cursor-grab active:cursor-grabbing"
                                          title="Sleep om te verplaatsen">
                                        <i data-lucide="grip-vertical" class="size-4"></i>
                                    </span>
                                </div>

                                <div class="sm:col-span-3 flex flex-col gap-1.5">
                                    <label class="text-xs font-medium text-foreground-500">Label *</label>
                                    @{
                                        PageData["id"]       = "btnLabel_" + bId;
                                        PageData["name"]     = "label";
                                        PageData["value"]    = bLabel;
                                        PageData["required"] = true;
                                    }
                                    @RenderPage("Shared/Components/_Input.cshtml")
                                </div>

                                <div class="sm:col-span-2 flex flex-col gap-1.5">
                                    <label class="text-xs font-medium text-foreground-500">Icon</label>
                                    @{
                                        PageData["id"]          = "btnIcon_" + bId;
                                        PageData["name"]        = "icon";
                                        PageData["value"]       = bIcon;
                                        PageData["placeholder"] = "chevron-right";
                                    }
                                    @RenderPage("Shared/Components/_Input.cshtml")
                                </div>

                                <div class="sm:col-span-4 flex flex-col gap-1.5">
                                    <label class="text-xs font-medium text-foreground-500">URL *</label>
                                    @{
                                        PageData["id"]       = "btnUrl_" + bId;
                                        PageData["name"]     = "url";
                                        PageData["type"]     = "text";
                                        PageData["value"]    = bUrl;
                                        PageData["required"] = true;
                                    }
                                    @RenderPage("Shared/Components/_Input.cshtml")
                                </div>

                                <label class="sm:col-span-1 flex items-center gap-1.5 pb-2">
                                    <input type="checkbox" name="isVisible" value="1" @(bVisible ? "checked" : "") class="size-4 accent-primary" />
                                    <span class="text-xs text-foreground-700">zicht.</span>
                                </label>

                                <div class="sm:col-span-2 flex sm:flex-col gap-2">
                                    <button type="submit" title="Opslaan"
                                            class="flex-1 inline-flex items-center justify-center px-2 py-2 rounded-lg bg-primary text-white text-xs font-semibold hover:bg-primary/90 transition">
                                        <i data-lucide="save" class="size-4"></i>
                                    </button>
                                    <button type="submit" name="formAction" value="btn-delete"
                                            onclick="return confirm('Knop verwijderen?');"
                                            title="Verwijderen"
                                            class="flex-1 inline-flex items-center justify-center px-2 py-2 rounded-lg border border-danger/30 text-danger-700 text-xs hover:bg-danger/5 transition">
                                        <i data-lucide="trash-2" class="size-4"></i>
                                    </button>
                                </div>
                            </form>
                        }
                    </div>

                    <!-- Add new button -->
                    <details class="mt-4">
                        <summary class="cursor-pointer inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline">
                            <i data-lucide="plus" class="size-4"></i>
                            <span>Knop toevoegen</span>
                        </summary>
                        <form method="post" class="mt-3 bg-content1 rounded-lg border border-divider p-4 grid grid-cols-1 sm:grid-cols-12 gap-3 items-end">
                            <input type="hidden" name="formAction" value="btn-save" />
                            <input type="hidden" name="catId"      value="@catId" />
                            <input type="hidden" name="btnId"      value="0" />

                            <div class="sm:col-span-3 flex flex-col gap-1.5">
                                <label class="text-xs font-medium text-foreground-500">Label *</label>
                                @{
                                    PageData["id"]       = "newBtnLabel_" + catId;
                                    PageData["name"]     = "label";
                                    PageData["value"]    = "";
                                    PageData["required"] = true;
                                }
                                @RenderPage("Shared/Components/_Input.cshtml")
                            </div>

                            <div class="sm:col-span-2 flex flex-col gap-1.5">
                                <label class="text-xs font-medium text-foreground-500">Icon</label>
                                @{
                                    PageData["id"]          = "newBtnIcon_" + catId;
                                    PageData["name"]        = "icon";
                                    PageData["value"]       = "";
                                    PageData["placeholder"] = "chevron-right";
                                }
                                @RenderPage("Shared/Components/_Input.cshtml")
                            </div>

                            <div class="sm:col-span-5 flex flex-col gap-1.5">
                                <label class="text-xs font-medium text-foreground-500">URL *</label>
                                @{
                                    PageData["id"]          = "newBtnUrl_" + catId;
                                    PageData["name"]        = "url";
                                    PageData["type"]        = "text";
                                    PageData["value"]       = "";
                                    PageData["placeholder"] = "/" + communitySlug + "/...";
                                    PageData["required"]    = true;
                                }
                                @RenderPage("Shared/Components/_Input.cshtml")
                            </div>

                            <label class="sm:col-span-1 flex items-center gap-1.5 pb-2">
                                <input type="checkbox" name="isVisible" value="1" checked class="size-4 accent-primary" />
                                <span class="text-xs text-foreground-700">zicht.</span>
                            </label>

                            <div class="sm:col-span-1">
                                <button type="submit"
                                        class="w-full inline-flex items-center justify-center gap-1 px-2 py-2 rounded-lg bg-primary text-white text-xs font-semibold hover:bg-primary/90 transition">
                                    <i data-lucide="plus" class="size-4"></i>
                                    <span>Toev.</span>
                                </button>
                            </div>
                        </form>
                    </details>
                </div>
            </details>
        </div>
    }

    @if (categories.Count > 0) {
        @Html.Raw("</div>")
    }
</section>

<style>
    .dt-sort-ghost   { opacity: .4; }
    .dt-sort-chosen  { box-shadow: 0 0 0 2px var(--color-primary, #2563eb); }
    .dt-sort-saving  { opacity: .85; }
    .dt-sort-saved   { box-shadow: inset 0 0 0 2px rgba(16,185,129,.5); }
    .dt-sort-error   { box-shadow: inset 0 0 0 2px rgba(239,68,68,.6); }
</style>

