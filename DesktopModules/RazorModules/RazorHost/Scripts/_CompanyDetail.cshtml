@using DZP.CommunityAuth
@using DotNetNuke.Entities.Users
@using DotNetNuke.Entities.Portals
@using System.Web
@using System.Linq
@*
    Company detail page.
    Owns all data parsing (companyInfo JSON, opening-hours grouping, manager
    lookup, edit-permission check) and exposes the result via PageData so
    the section partials in Shared/CompanyDetail/ stay markup-only.
*@
@{
    var rc       = CommunityAuth.Current;
    var user     = Dnn.User;
    var portalId = PortalSettings.Current != null ? PortalSettings.Current.PortalId : 0;

    var communityName = rc != null ? rc.CommunityName : "Community";
    var communitySlug = rc != null ? rc.CommunitySlug : "";
    var companySlug   = rc != null ? rc.CompanySlug   : "";
    var companyName   = rc != null ? rc.CompanyName   : "";
    var companyId     = rc != null ? rc.CompanyId     : 0;
    var ownerId       = rc != null ? rc.CompanyOwnerId : 0;
    var companyInfo   = rc != null ? rc.CompanyInfoJson ?? "" : "";

    var about       = "";
    var address     = "";
    var mapsUrl     = "";
    var phone       = "";
    var email       = "";
    var website     = "";
    var bannerImage = "https://picsum.photos/seed/" + companySlug + "/1200/400";

    /* ── Opening hours ── */
    var dayOrder = new[] { "mon", "tue", "wed", "thu", "fri", "sat", "sun" };
    var dayToNl = new Dictionary<string, string> {
        { "mon", "Ma" }, { "tue", "Di" }, { "wed", "Wo" },
        { "thu", "Do" }, { "fri", "Vr" }, { "sat", "Za" }, { "sun", "Zo" }
    };
    var hoursMap = new Dictionary<string, string[]>();          // day -> [open, close]; missing = closed
    var hoursDisplay = new List<Dictionary<string, object>>();  // grouped rows for display
    var isOpen = false;

    /* ── Parse companyInfo JSON ── */
    if (companyId > 0 && !string.IsNullOrEmpty(companyInfo)) {
        try {
            var serializer = new System.Web.Script.Serialization.JavaScriptSerializer();
            var root = serializer.Deserialize<Dictionary<string, object>>(companyInfo);
            if (root != null) {
                Func<string, string> str = key => root.ContainsKey(key) && root[key] != null ? root[key].ToString() : "";
                about   = str("about")   != "" ? str("about")   : str("description");
                address = str("address");
                mapsUrl = str("mapsUrl") != "" ? str("mapsUrl") : (str("googleMaps") != "" ? str("googleMaps") : str("maps"));
                phone   = str("phone")   != "" ? str("phone")   : str("telefoon");
                email   = str("email");
                website = str("website") != "" ? str("website") : str("url");
                if (root.ContainsKey("banner") && root["banner"] != null) { bannerImage = root["banner"].ToString(); }

                if (root.ContainsKey("openingHours") && root["openingHours"] is Dictionary<string, object> hoursObj) {
                    foreach (var day in dayOrder) {
                        if (hoursObj.ContainsKey(day) && hoursObj[day] is System.Collections.ArrayList arr && arr.Count == 2) {
                            hoursMap[day] = new[] { arr[0].ToString(), arr[1].ToString() };
                        }
                    }

                    /* Group consecutive days with the same hours */
                    var i = 0;
                    while (i < dayOrder.Length) {
                        var day = dayOrder[i];
                        var hasTimes = hoursMap.ContainsKey(day);
                        var times = hasTimes ? hoursMap[day] : null;
                        var rangeStart = i;
                        while (i + 1 < dayOrder.Length) {
                            var nextDay = dayOrder[i + 1];
                            var nextHas = hoursMap.ContainsKey(nextDay);
                            var nextTimes = nextHas ? hoursMap[nextDay] : null;
                            if (hasTimes == nextHas && (times == null && nextTimes == null
                                || times != null && nextTimes != null && times[0] == nextTimes[0] && times[1] == nextTimes[1])) {
                                i++;
                            } else {
                                break;
                            }
                        }
                        var nlStart = dayToNl[dayOrder[rangeStart]];
                        var nlEnd   = dayToNl[dayOrder[i]];
                        var label   = rangeStart == i ? nlStart : nlStart + " - " + nlEnd;
                        hoursDisplay.Add(new Dictionary<string, object> {
                            { "Days",     label },
                            { "Hours",    hasTimes ? times[0] + " - " + times[1] : "Gesloten" },
                            { "IsClosed", !hasTimes }
                        });
                        i++;
                    }

                    /* Determine open/closed right now */
                    var dayOfWeekMap = new Dictionary<DayOfWeek, string> {
                        { DayOfWeek.Monday, "mon" }, { DayOfWeek.Tuesday, "tue" }, { DayOfWeek.Wednesday, "wed" },
                        { DayOfWeek.Thursday, "thu" }, { DayOfWeek.Friday, "fri" }, { DayOfWeek.Saturday, "sat" },
                        { DayOfWeek.Sunday, "sun" }
                    };
                    var now = DateTime.Now;
                    var todayKey = dayOfWeekMap[now.DayOfWeek];
                    if (hoursMap.ContainsKey(todayKey)) {
                        TimeSpan openTime, closeTime;
                        if (TimeSpan.TryParse(hoursMap[todayKey][0], out openTime)
                            && TimeSpan.TryParse(hoursMap[todayKey][1], out closeTime)) {
                            var nowTime = now.TimeOfDay;
                            isOpen = closeTime < openTime
                                ? nowTime >= openTime || nowTime <= closeTime
                                : nowTime >= openTime && nowTime <= closeTime;
                        }
                    }
                }
            }
        } catch {
            about = companyInfo;
        }
    }

    /* Generate Google Maps link from address if none provided */
    if (string.IsNullOrEmpty(mapsUrl) && !string.IsNullOrEmpty(address)) {
        mapsUrl = "https://www.google.com/maps/search/?api=1&query=" + HttpUtility.UrlEncode(address);
    }

    /* ── Managers / team ── */
    var managers = new List<Dictionary<string, object>>();
    if (companyId > 0) {
        var userIds = CommunityAuth.GetCompanyTeamUserIds(companyId);
        foreach (var uid in userIds) {
            var u = UserController.Instance.GetUserById(portalId, uid);
            if (u != null) {
                managers.Add(new Dictionary<string, object> {
                    { "Name",  u.DisplayName },
                    { "Email", u.Email ?? "" },
                    { "Image", "/DnnImageHandler.ashx?mode=profilepic&userId=" + u.UserID + "&w=80&h=80" }
                });
            }
        }
    }

    /* ── Edit permission ──
       Driven by dbo.RolePermissions: any role granted "company:edit" can
       manage every company in the community. The legacy owner-based check
       is kept as a fallback so a company owner without an explicit role
       permission can still edit their own page. */
    var canEdit = false;
    if (user != null && companyId > 0) {
        var adminRoleName = PortalSettings.Current != null ? PortalSettings.Current.AdministratorRoleName : "Administrators";
        var isAdministrator = !string.IsNullOrEmpty(adminRoleName) && user.IsInRole(adminRoleName);
        canEdit = user.IsSuperUser
               || isAdministrator
               || (rc != null && rc.HasPermission("company:edit"))
               || (ownerId > 0 && user.UserID == ownerId);
    }

    /* ── Publish to PageData ── */
    PageData["communityName"] = communityName;
    PageData["communitySlug"] = communitySlug;
    PageData["companyName"]   = companyName;
    PageData["companySlug"]   = companySlug;
    PageData["bannerImage"]   = bannerImage;
    PageData["about"]         = about;
    PageData["address"]       = address;
    PageData["mapsUrl"]       = mapsUrl;
    PageData["phone"]         = phone;
    PageData["email"]         = email;
    PageData["website"]       = website;
    PageData["hoursDisplay"]  = hoursDisplay;
    PageData["isOpen"]        = isOpen;
    PageData["managers"]      = managers;
    PageData["canEdit"]       = canEdit;
}

<main class="max-w-7xl w-full m-auto">
    @RenderPage("Shared/CompanyDetail/_Breadcrumb.cshtml")
    @RenderPage("Shared/CompanyDetail/_Banner.cshtml")
    @RenderPage("Shared/CompanyDetail/_About.cshtml")
    @RenderPage("Shared/CompanyDetail/_Map.cshtml")
    @RenderPage("Shared/CompanyDetail/_Team.cshtml")
    @RenderPage("Shared/CompanyDetail/_BackLink.cshtml")
</main>
