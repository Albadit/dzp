@using DZP.CommunityAuth
@using DotNetNuke.Entities.Users
@using DotNetNuke.Entities.Portals
@using System.Web
@using System.Data.SqlClient
@using System.Configuration
@using System.Linq
@*
    Company edit page.
    The orchestrator owns:
      - authorization (owner / admin / superuser)
      - parsing the existing CompanyInfo JSON
      - all POST handlers (save-info, add-member, remove-member, toggle-team)
      - the AJAX JSON response branch (early-out)
      - reloading members + community-user list for the picker
    Section partials in Shared/CompanyEdit/ stay markup-only.
*@
@{
    var rc       = CommunityAuth.Current;
    var user     = Dnn.User;
    var portalId = PortalSettings.Current != null ? PortalSettings.Current.PortalId : 0;

    var communityName = rc != null ? rc.CommunityName : "Community";
    var communitySlug = rc != null ? rc.CommunitySlug : "";
    var communityId   = rc != null ? rc.CommunityId   : 0;
    var companySlug   = rc != null ? rc.CompanySlug   : "";
    var companyName   = rc != null ? rc.CompanyName   : "";
    var companyId     = rc != null ? rc.CompanyId     : 0;
    var ownerId       = rc != null ? rc.CompanyOwnerId : 0;
    var companyInfo   = rc != null ? rc.CompanyInfoJson ?? "" : "";

    var cs      = ConfigurationManager.ConnectionStrings["SiteSqlServer"];
    var connStr = cs != null ? cs.ConnectionString : "";

    var about       = "";
    var address     = "";
    var phone       = "";
    var email       = "";
    var website     = "";
    var bannerImage = "";

    var dayOrder   = new[] { "mon", "tue", "wed", "thu", "fri", "sat", "sun" };
    var hoursOpen  = new Dictionary<string, string>();
    var hoursClose = new Dictionary<string, string>();

    var isManager       = false;
    var isSuperUser     = user != null && user.IsSuperUser;
    var adminRoleName   = PortalSettings.Current != null ? PortalSettings.Current.AdministratorRoleName : "Administrators";
    var isAdministrator = user != null && !string.IsNullOrEmpty(adminRoleName) && user.IsInRole(adminRoleName);
    var isElevated      = isSuperUser || isAdministrator;
    var saveSuccess     = false;
    var saveError       = "";
    var memberMsg       = "";
    var memberError     = "";

    var members  = new List<Dictionary<string, object>>();
    var allUsers = new List<Dictionary<string, object>>();

    if (companyId > 0) {
        if (user != null) {
            isManager = isElevated || (ownerId > 0 && user.UserID == ownerId);
        }

        /* ── Parse existing CompanyInfo JSON ── */
        if (!string.IsNullOrEmpty(companyInfo)) {
            try {
                var serializer = new System.Web.Script.Serialization.JavaScriptSerializer();
                var root = serializer.Deserialize<Dictionary<string, object>>(companyInfo);
                if (root != null) {
                    Func<string, string> str = key => root.ContainsKey(key) && root[key] != null ? root[key].ToString() : "";
                    about       = str("about");
                    address     = str("address");
                    phone       = str("phone");
                    email       = str("email");
                    website     = str("website");
                    bannerImage = str("banner");

                    if (root.ContainsKey("openingHours") && root["openingHours"] is Dictionary<string, object> hoursObj) {
                        foreach (var day in dayOrder) {
                            if (hoursObj.ContainsKey(day) && hoursObj[day] is System.Collections.ArrayList arr && arr.Count == 2) {
                                hoursOpen[day]  = arr[0].ToString();
                                hoursClose[day] = arr[1].ToString();
                            }
                        }
                    }
                }
            } catch { }
        }

        /* ── POST handling ── */
        var isAjax = string.Equals(Request.Headers["X-Requested-With"], "fetch", StringComparison.OrdinalIgnoreCase)
                  || Request.Headers["X-Requested-With"] == "XMLHttpRequest"
                  || Request["ajax"] == "1";
        if (IsPost && isManager) {
            var action = (Request["formAction"] ?? "").Trim();

            if (action == "add-member") {
                var addUserId = 0;
                int.TryParse(Request["addUserId"], out addUserId);
                if (addUserId > 0) {
                    try {
                        /* Verify the target user is a member of THIS community.
                           Reject silently-with-error if not, so outsiders can't
                           be added by crafting a request. */
                        var isCommunityMember = false;
                        using (var conn = new SqlConnection(connStr)) {
                        using (var chk = new SqlCommand(
                            "SELECT 1 FROM UserCommunity WHERE UserId = @uid AND CommunityId = @commId", conn)) {
                            chk.Parameters.AddWithValue("@uid", addUserId);
                            chk.Parameters.AddWithValue("@commId", communityId);
                            conn.Open();
                            isCommunityMember = chk.ExecuteScalar() != null;
                        }
                        }

                        if (!isCommunityMember) {
                            memberError = "Deze gebruiker is geen lid van de community.";
                        } else {
                            using (var conn = new SqlConnection(connStr)) {
                            using (var cmd = new SqlCommand(
                                "IF NOT EXISTS (SELECT 1 FROM UserCompany WHERE UserId = @uid AND CompanyId = @cid) INSERT INTO UserCompany (UserId, CompanyId) VALUES (@uid, @cid)", conn)) {
                                cmd.Parameters.AddWithValue("@uid", addUserId);
                                cmd.Parameters.AddWithValue("@cid", companyId);
                                conn.Open();
                                cmd.ExecuteNonQuery();
                            }
                            }
                            memberMsg = "Lid toegevoegd.";
                        }
                    } catch (Exception ex) {
                        memberError = "Fout: " + ex.Message;
                    }
                }
            } else if (action == "remove-member") {
                var removeId = 0;
                int.TryParse(Request["removeMemberId"], out removeId);
                if (removeId > 0) {
                    /* Block removal of the owner */
                    var isOwnerRow = false;
                    using (var conn = new SqlConnection(connStr)) {
                    using (var cmd = new SqlCommand(
                        "SELECT UserId FROM UserCompany WHERE Id = @id AND CompanyId = @cid", conn)) {
                        cmd.Parameters.AddWithValue("@id", removeId);
                        cmd.Parameters.AddWithValue("@cid", companyId);
                        conn.Open();
                        var result = cmd.ExecuteScalar();
                        if (result != null && (int)result == ownerId) { isOwnerRow = true; }
                    }
                    }
                    if (isOwnerRow) {
                        memberError = "De eigenaar kan niet worden verwijderd.";
                    } else {
                        try {
                            using (var conn = new SqlConnection(connStr)) {
                            using (var cmd = new SqlCommand(
                                "DELETE FROM UserCompany WHERE Id = @id AND CompanyId = @cid", conn)) {
                                cmd.Parameters.AddWithValue("@id", removeId);
                                cmd.Parameters.AddWithValue("@cid", companyId);
                                conn.Open();
                                cmd.ExecuteNonQuery();
                            }
                            }
                            memberMsg = "Lid verwijderd.";
                        } catch (Exception ex) {
                            memberError = "Fout: " + ex.Message;
                        }
                    }
                }
            } else if (action == "toggle-team") {
                /* Owner can toggle ShowInTeam for any member in their company */
                var toggleUserId = 0;
                int.TryParse(Request["toggleUserId"], out toggleUserId);
                if (toggleUserId > 0) {
                    try {
                        using (var conn = new SqlConnection(connStr)) {
                        using (var cmd = new SqlCommand(
                            "UPDATE UserCompany SET ShowInTeam = CASE WHEN ShowInTeam = 1 THEN 0 ELSE 1 END WHERE UserId = @uid AND CompanyId = @cid", conn)) {
                            cmd.Parameters.AddWithValue("@uid", toggleUserId);
                            cmd.Parameters.AddWithValue("@cid", companyId);
                            conn.Open();
                            cmd.ExecuteNonQuery();
                        }
                        }
                        memberMsg = "Teamzichtbaarheid bijgewerkt.";
                    } catch (Exception ex) {
                        memberError = "Fout: " + ex.Message;
                    }
                }
            } else {
                /* ── Save company info ── */
                companyName = (Request["companyName"] ?? "").Trim();
                about       = (Request["about"]       ?? "").Trim();
                address     = (Request["address"]     ?? "").Trim();
                phone       = (Request["phone"]       ?? "").Trim();
                email       = (Request["email"]       ?? "").Trim();
                website     = (Request["website"]     ?? "").Trim();
                bannerImage = (Request["banner"]      ?? "").Trim();

                hoursOpen.Clear();
                hoursClose.Clear();
                foreach (var day in dayOrder) {
                    var open  = (Request["hours_open_"  + day] ?? "").Trim();
                    var close = (Request["hours_close_" + day] ?? "").Trim();
                    if (!string.IsNullOrEmpty(open) && !string.IsNullOrEmpty(close)) {
                        hoursOpen[day]  = open;
                        hoursClose[day] = close;
                    }
                }

                var serializer = new System.Web.Script.Serialization.JavaScriptSerializer();
                var data = new Dictionary<string, object> {
                    { "about",   about },
                    { "address", address },
                    { "phone",   phone },
                    { "email",   email },
                    { "website", website }
                };
                if (!string.IsNullOrEmpty(bannerImage)) { data["banner"] = bannerImage; }

                var hours = new Dictionary<string, object>();
                foreach (var day in dayOrder) {
                    hours[day] = (hoursOpen.ContainsKey(day) && hoursClose.ContainsKey(day))
                                    ? (object)new[] { hoursOpen[day], hoursClose[day] }
                                    : null;
                }
                data["openingHours"] = hours;

                var json = serializer.Serialize(data);

                if (string.IsNullOrEmpty(companyName)) {
                    saveError = "Bedrijfsnaam is verplicht.";
                } else {
                    try {
                        using (var conn = new SqlConnection(connStr)) {
                        using (var cmd = new SqlCommand(
                            "UPDATE Company SET Name = @name, CompanyInfo = @info WHERE Id = @id", conn)) {
                            cmd.Parameters.AddWithValue("@name", companyName);
                            cmd.Parameters.AddWithValue("@info", json);
                            cmd.Parameters.AddWithValue("@id",   companyId);
                            conn.Open();
                            cmd.ExecuteNonQuery();
                        }
                        }
                        saveSuccess = true;
                    } catch (Exception ex) {
                        saveError = "Fout bij opslaan: " + ex.Message;
                    }
                }
            }
        }

        /* ── AJAX: return JSON and stop rendering ── */
        if (IsPost && isAjax && isManager) {
            var ok  = string.IsNullOrEmpty(saveError) && string.IsNullOrEmpty(memberError);
            var msg = !string.IsNullOrEmpty(memberMsg)
                          ? memberMsg
                          : (!string.IsNullOrEmpty(saveError)
                                 ? saveError
                                 : (!string.IsNullOrEmpty(memberError)
                                        ? memberError
                                        : (saveSuccess ? "Opgeslagen!" : "")));

            /* Reload members for the response */
            var ajaxMembers = new List<Dictionary<string, object>>();
            using (var conn = new SqlConnection(connStr)) {
            using (var cmd = new SqlCommand(
                "SELECT uc.Id, uc.UserId, u.DisplayName, u.Email, uc.ShowInTeam FROM UserCompany uc INNER JOIN Users u ON u.UserID = uc.UserId WHERE uc.CompanyId = @cid ORDER BY u.DisplayName", conn)) {
                cmd.Parameters.AddWithValue("@cid", companyId);
                conn.Open();
                using (var reader = cmd.ExecuteReader()) {
                    while (reader.Read()) {
                        ajaxMembers.Add(new Dictionary<string, object> {
                            { "id",          reader.GetInt32(0) },
                            { "userId",      reader.GetInt32(1) },
                            { "displayName", reader.GetString(2) },
                            { "email",       reader.IsDBNull(3) ? "" : reader.GetString(3) },
                            { "showInTeam",  reader.GetBoolean(4) }
                        });
                    }
                }
            }
            }
            var jss = new System.Web.Script.Serialization.JavaScriptSerializer();
            Response.Clear();
            Response.ContentType = "application/json";
            Response.Write(jss.Serialize(new Dictionary<string, object> {
                { "ok",      ok },
                { "message", msg },
                { "members", ajaxMembers },
                { "ownerId", ownerId }
            }));
            Response.Flush();
            Response.SuppressContent = true;
            HttpContext.Current.ApplicationInstance.CompleteRequest();
            return;
        }

        /* ── Load current members ── */
        if (isManager && companyId > 0) {
            using (var conn = new SqlConnection(connStr)) {
            using (var cmd = new SqlCommand(
                "SELECT uc.Id, uc.UserId, u.DisplayName, u.Email, uc.ShowInTeam FROM UserCompany uc INNER JOIN Users u ON u.UserID = uc.UserId WHERE uc.CompanyId = @cid ORDER BY u.DisplayName", conn)) {
                cmd.Parameters.AddWithValue("@cid", companyId);
                conn.Open();
                using (var reader = cmd.ExecuteReader()) {
                    while (reader.Read()) {
                        members.Add(new Dictionary<string, object> {
                            { "Id",          reader.GetInt32(0) },
                            { "UserId",      reader.GetInt32(1) },
                            { "DisplayName", reader.GetString(2) },
                            { "Email",       reader.IsDBNull(3) ? "" : reader.GetString(3) },
                            { "ShowInTeam",  reader.GetBoolean(4) }
                        });
                    }
                }
            }
            }

            /* Load community members for add-member dropdown.
               Restrict to users that belong to THIS community via UserCommunity. */
            using (var conn = new SqlConnection(connStr)) {
            using (var cmd = new SqlCommand(
                "SELECT u.UserID, u.DisplayName FROM Users u " +
                "INNER JOIN UserPortals up ON up.UserId = u.UserID " +
                "INNER JOIN UserCommunity uc ON uc.UserId = u.UserID " +
                "WHERE up.PortalId = @pid AND uc.CommunityId = @cid AND u.IsSuperUser = 0 " +
                "ORDER BY u.DisplayName", conn)) {
                cmd.Parameters.AddWithValue("@pid", portalId);
                cmd.Parameters.AddWithValue("@cid", communityId);
                conn.Open();
                using (var reader = cmd.ExecuteReader()) {
                    while (reader.Read()) {
                        allUsers.Add(new Dictionary<string, object> {
                            { "UserId",      reader.GetInt32(0) },
                            { "DisplayName", reader.GetString(1) }
                        });
                    }
                }
            }
            }
        }
    }

    /* ── Publish to PageData ── */
    PageData["communityName"] = communityName;
    PageData["communitySlug"] = communitySlug;
    PageData["companyName"]   = companyName;
    PageData["companySlug"]   = companySlug;
    PageData["ownerId"]       = ownerId;
    PageData["about"]         = about;
    PageData["address"]       = address;
    PageData["phone"]         = phone;
    PageData["email"]         = email;
    PageData["website"]       = website;
    PageData["bannerImage"]   = bannerImage;
    PageData["hoursOpen"]     = hoursOpen;
    PageData["hoursClose"]    = hoursClose;
    PageData["saveSuccess"]   = saveSuccess;
    PageData["saveError"]     = saveError;
    PageData["members"]       = members;
    PageData["allUsers"]      = allUsers;
}

<main class="max-w-4xl w-full m-auto">
    @RenderPage("Shared/CompanyEdit/_Breadcrumb.cshtml")

    @if (!isManager) {
        @RenderPage("Shared/CompanyEdit/_AccessDenied.cshtml")
    } else {
        <section class="flex flex-col gap-6 w-full px-4 sm:px-6 lg:px-8 py-6 sm:py-8"
                 data-module-id="@Dnn.Module.ModuleID" data-tab-id="@Dnn.Tab.TabID">
            @RenderPage("Shared/CompanyEdit/_FormHeader.cshtml")
            @RenderPage("Shared/CompanyEdit/_SaveAlerts.cshtml")

            <form method="post" id="ce-save-form" class="flex flex-col gap-6">
                <input type="hidden" name="formAction" value="save-info" />
                @RenderPage("Shared/CompanyEdit/_GeneralInfo.cshtml")
                @RenderPage("Shared/CompanyEdit/_ContactInfo.cshtml")
                @RenderPage("Shared/CompanyEdit/_OpeningHours.cshtml")
                @RenderPage("Shared/CompanyEdit/_SubmitButtons.cshtml")
            </form>

            @RenderPage("Shared/CompanyEdit/_MembersList.cshtml")
        </section>
    }
</main>

@if (isManager) {
    @RenderPage("Shared/CompanyEdit/_Scripts.cshtml")
}
