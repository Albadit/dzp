@using DZP.CommunityAuth
@using DotNetNuke.Entities.Users
@using DotNetNuke.Entities.Portals
@using System.Web
@using System.Data.SqlClient
@using System.Configuration
@using System.Linq
@{
    var rc = CommunityAuth.Current;
    var user = Dnn.User;
    var portalId = PortalSettings.Current != null ? PortalSettings.Current.PortalId : 0;

    var communityName = rc != null ? rc.CommunityName : "Community";
    var communitySlug = rc != null ? rc.CommunitySlug : "";
    var communityId   = rc != null ? rc.CommunityId : 0;
    var companySlug   = rc != null ? rc.CompanySlug : "";
    var companyName   = rc != null ? rc.CompanyName : "";
    var companyId     = rc != null ? rc.CompanyId : 0;
    var ownerId       = rc != null ? rc.CompanyOwnerId : 0;
    var companyInfo   = rc != null ? rc.CompanyInfoJson ?? "" : "";

    var cs = ConfigurationManager.ConnectionStrings["SiteSqlServer"];
    var connStr = cs != null ? cs.ConnectionString : "";

    var about       = "";
    var address     = "";
    var phone       = "";
    var email       = "";
    var website     = "";
    var bannerImage = "";

    var dayOrder = new[] { "mon", "tue", "wed", "thu", "fri", "sat", "sun" };
    var dayToNl = new Dictionary<string, string> {
        { "mon", "Ma" }, { "tue", "Di" }, { "wed", "Wo" },
        { "thu", "Do" }, { "fri", "Vr" }, { "sat", "Za" }, { "sun", "Zo" }
    };
    var hoursOpen  = new Dictionary<string, string>();
    var hoursClose = new Dictionary<string, string>();

    var isManager  = false;
    var isSuperUser = user != null && user.IsSuperUser;
    var saveSuccess = false;
    var saveError   = "";
    var memberMsg   = "";
    var memberError = "";
    var members     = new List<dynamic>();
    var allUsers    = new List<dynamic>();

    if (companyId > 0)
    {
        /* ── Check authorization: owner or SuperUser ── */
        if (user != null)
        {
            isManager = isSuperUser || (ownerId > 0 && user.UserID == ownerId);
        }

        /* ── Parse existing CompanyInfo JSON ── */
        if (!string.IsNullOrEmpty(companyInfo))
        {
            try
            {
                var serializer = new System.Web.Script.Serialization.JavaScriptSerializer();
                var root = serializer.Deserialize<Dictionary<string, object>>(companyInfo);
                if (root != null)
                {
                    Func<string, string> str = key => root.ContainsKey(key) && root[key] != null ? root[key].ToString() : "";
                    about       = str("about");
                    address     = str("address");
                    phone       = str("phone");
                    email       = str("email");
                    website     = str("website");
                    bannerImage = str("banner");

                    if (root.ContainsKey("openingHours") && root["openingHours"] is Dictionary<string, object> hoursObj)
                    {
                        foreach (var day in dayOrder)
                        {
                            if (hoursObj.ContainsKey(day) && hoursObj[day] is System.Collections.ArrayList arr && arr.Count == 2)
                            {
                                hoursOpen[day]  = arr[0].ToString();
                                hoursClose[day] = arr[1].ToString();
                            }
                        }
                    }
                }
            }
            catch { }
        }

        /* ── Handle POST: save updated data ── */
        var isAjax = Request.Headers["X-Requested-With"] == "XMLHttpRequest";
        if (IsPost && isManager)
        {
            var action = (Request["formAction"] ?? "").Trim();

            if (action == "add-member")
            {
                var addUserId = 0;
                int.TryParse(Request["addUserId"], out addUserId);
                if (addUserId > 0)
                {
                    try
                    {
                        using (var conn = new SqlConnection(connStr))
                        {
                        using (var cmd = new SqlCommand(
                            "IF NOT EXISTS (SELECT 1 FROM UserCommunity WHERE UserId = @uid AND CommunityId = @commId) INSERT INTO UserCommunity (UserId, CommunityId) VALUES (@uid, @commId); IF NOT EXISTS (SELECT 1 FROM UserCompany WHERE UserId = @uid AND CompanyId = @cid) INSERT INTO UserCompany (UserId, CompanyId) VALUES (@uid, @cid)", conn))
                        {
                            cmd.Parameters.AddWithValue("@uid", addUserId);
                            cmd.Parameters.AddWithValue("@commId", communityId);
                            cmd.Parameters.AddWithValue("@cid", companyId);
                            conn.Open();
                            cmd.ExecuteNonQuery();
                        }
                        }
                        memberMsg = "Lid toegevoegd.";
                    }
                    catch (Exception ex)
                    {
                        memberError = "Fout: " + ex.Message;
                    }
                }
            }
            else if (action == "remove-member")
            {
                var removeId = 0;
                int.TryParse(Request["removeMemberId"], out removeId);
                if (removeId > 0)
                {
                    /* ── Block removal of the owner ── */
                    var isOwnerRow = false;
                    using (var conn = new SqlConnection(connStr))
                    {
                    using (var cmd = new SqlCommand(
                        "SELECT UserId FROM UserCompany WHERE Id = @id AND CompanyId = @cid", conn))
                    {
                        cmd.Parameters.AddWithValue("@id", removeId);
                        cmd.Parameters.AddWithValue("@cid", companyId);
                        conn.Open();
                        var result = cmd.ExecuteScalar();
                        if (result != null && (int)result == ownerId) { isOwnerRow = true; }
                    }
                    }
                    if (isOwnerRow)
                    {
                        memberError = "De eigenaar kan niet worden verwijderd.";
                    }
                    else
                    {
                    try
                    {
                        using (var conn = new SqlConnection(connStr))
                        {
                        using (var cmd = new SqlCommand(
                            "DELETE FROM UserCompany WHERE Id = @id AND CompanyId = @cid", conn))
                        {
                            cmd.Parameters.AddWithValue("@id", removeId);
                            cmd.Parameters.AddWithValue("@cid", companyId);
                            conn.Open();
                            cmd.ExecuteNonQuery();
                        }
                        }
                        memberMsg = "Lid verwijderd.";
                    }
                    catch (Exception ex)
                    {
                        memberError = "Fout: " + ex.Message;
                    }
                    } /* end else not-owner */
                }
            }
            else if (action == "toggle-team")
            {
                /* Owner can toggle ShowInTeam for any member in their company */
                var toggleUserId = 0;
                int.TryParse(Request["toggleUserId"], out toggleUserId);
                if (toggleUserId > 0)
                {
                try
                {
                    using (var conn = new SqlConnection(connStr))
                    {
                    using (var cmd = new SqlCommand(
                        "UPDATE UserCompany SET ShowInTeam = CASE WHEN ShowInTeam = 1 THEN 0 ELSE 1 END WHERE UserId = @uid AND CompanyId = @cid", conn))
                    {
                        cmd.Parameters.AddWithValue("@uid", toggleUserId);
                        cmd.Parameters.AddWithValue("@cid", companyId);
                        conn.Open();
                        cmd.ExecuteNonQuery();
                    }
                    }
                    memberMsg = "Teamzichtbaarheid bijgewerkt.";
                }
                catch (Exception ex)
                {
                    memberError = "Fout: " + ex.Message;
                }
                }
            }
            else
            {
            /* ── Save company info ── */
            companyName = (Request["companyName"] ?? "").Trim();
            about       = (Request["about"] ?? "").Trim();
            address     = (Request["address"] ?? "").Trim();
            phone       = (Request["phone"] ?? "").Trim();
            email       = (Request["email"] ?? "").Trim();
            website     = (Request["website"] ?? "").Trim();
            bannerImage = (Request["banner"] ?? "").Trim();

            /* Build openingHours dict */
            hoursOpen.Clear();
            hoursClose.Clear();
            foreach (var day in dayOrder)
            {
                var open  = (Request["hours_open_" + day] ?? "").Trim();
                var close = (Request["hours_close_" + day] ?? "").Trim();
                if (!string.IsNullOrEmpty(open) && !string.IsNullOrEmpty(close))
                {
                    hoursOpen[day]  = open;
                    hoursClose[day] = close;
                }
            }

            /* Build JSON */
            var serializer = new System.Web.Script.Serialization.JavaScriptSerializer();
            var data = new Dictionary<string, object>();
            data["about"]   = about;
            data["address"] = address;
            data["phone"]   = phone;
            data["email"]   = email;
            data["website"] = website;
            if (!string.IsNullOrEmpty(bannerImage)) { data["banner"] = bannerImage; }

            var hours = new Dictionary<string, object>();
            foreach (var day in dayOrder)
            {
                if (hoursOpen.ContainsKey(day) && hoursClose.ContainsKey(day))
                {
                    hours[day] = new[] { hoursOpen[day], hoursClose[day] };
                }
                else
                {
                    hours[day] = null;
                }
            }
            data["openingHours"] = hours;

            var json = serializer.Serialize(data);

            /* Validate */
            if (string.IsNullOrEmpty(companyName))
            {
                saveError = "Bedrijfsnaam is verplicht.";
            }
            else
            {
                /* Save to DB */
                try
                {
                    using (var conn = new SqlConnection(connStr))
                    {
                    using (var cmd = new SqlCommand(
                        "UPDATE Company SET Name = @name, CompanyInfo = @info WHERE Id = @id", conn))
                    {
                        cmd.Parameters.AddWithValue("@name", companyName);
                        cmd.Parameters.AddWithValue("@info", json);
                        cmd.Parameters.AddWithValue("@id", companyId);
                        conn.Open();
                        cmd.ExecuteNonQuery();
                    }
                    }
                    saveSuccess = true;
                }
                catch (Exception ex)
                {
                    saveError = "Fout bij opslaan: " + ex.Message;
                }
            }
            } /* end else save-info */
        }

        /* ── AJAX: return JSON and stop rendering ── */
        if (IsPost && isAjax && isManager)
        {
            var ok = string.IsNullOrEmpty(saveError) && string.IsNullOrEmpty(memberError);
            var msg = !string.IsNullOrEmpty(memberMsg) ? memberMsg : (!string.IsNullOrEmpty(saveError) ? saveError : (!string.IsNullOrEmpty(memberError) ? memberError : (saveSuccess ? "Opgeslagen!" : "")));
            /* Reload members for the response */
            var ajaxMembers = new List<Dictionary<string, object>>();
            using (var conn = new SqlConnection(connStr))
            {
            using (var cmd = new SqlCommand(
                "SELECT uc.Id, uc.UserId, u.DisplayName, u.Email, uc.ShowInTeam FROM UserCompany uc INNER JOIN Users u ON u.UserID = uc.UserId WHERE uc.CompanyId = @cid ORDER BY u.DisplayName", conn))
            {
                cmd.Parameters.AddWithValue("@cid", companyId);
                conn.Open();
                using (var reader = cmd.ExecuteReader())
                {
                    while (reader.Read())
                    {
                        var d = new Dictionary<string, object>();
                        d["id"] = reader.GetInt32(0);
                        d["userId"] = reader.GetInt32(1);
                        d["displayName"] = reader.GetString(2);
                        d["email"] = reader.IsDBNull(3) ? "" : reader.GetString(3);
                        d["showInTeam"] = reader.GetBoolean(4);
                        ajaxMembers.Add(d);
                    }
                }
            }
            }
            var jss = new System.Web.Script.Serialization.JavaScriptSerializer();
            Response.Clear();
            Response.ContentType = "application/json";
            Response.Write(jss.Serialize(new Dictionary<string, object> {
                { "ok", ok }, { "message", msg }, { "members", ajaxMembers }, { "ownerId", ownerId }
            }));
            Response.Flush();
            Response.SuppressContent = true;
            HttpContext.Current.ApplicationInstance.CompleteRequest();
            return;
        }

        /* ── Load current members ── */
        if (isManager && companyId > 0)
        {
            using (var conn = new SqlConnection(connStr))
            {
            using (var cmd = new SqlCommand(
                "SELECT uc.Id, uc.UserId, u.DisplayName, u.Email, uc.ShowInTeam FROM UserCompany uc INNER JOIN Users u ON u.UserID = uc.UserId WHERE uc.CompanyId = @cid ORDER BY u.DisplayName", conn))
            {
                cmd.Parameters.AddWithValue("@cid", companyId);
                conn.Open();
                using (var reader = cmd.ExecuteReader())
                {
                    while (reader.Read())
                    {
                        var mUserId = reader.GetInt32(1);
                        var showInTeam = reader.GetBoolean(4);
                        members.Add(new {
                            Id          = reader.GetInt32(0),
                            UserId      = mUserId,
                            DisplayName = reader.GetString(2),
                            Email       = reader.IsDBNull(3) ? "" : reader.GetString(3),
                            ShowInTeam  = showInTeam
                        });
                    }
                }
            }
            }

            /* ── Load all portal users for add-member dropdown ── */
            using (var conn = new SqlConnection(connStr))
            {
            using (var cmd = new SqlCommand(
                "SELECT u.UserID, u.DisplayName FROM Users u INNER JOIN UserPortals up ON up.UserId = u.UserID WHERE up.PortalId = @pid AND u.IsSuperUser = 0 ORDER BY u.DisplayName", conn))
            {
                cmd.Parameters.AddWithValue("@pid", portalId);
                conn.Open();
                using (var reader = cmd.ExecuteReader())
                {
                    while (reader.Read())
                    {
                        allUsers.Add(new {
                            UserId      = reader.GetInt32(0),
                            DisplayName = reader.GetString(1)
                        });
                    }
                }
            }
            }
        }
    }
}

<main class="max-w-4xl w-full">
    <!-- ============================================ -->
    <!-- BREADCRUMB                                     -->
    <!-- ============================================ -->
    <section class="w-full">
        <div class="w-full px-4 sm:px-6 lg:px-8 pt-4 sm:pt-6">
            <nav class="flex items-center gap-1.5 text-sm text-foreground-400">
                <a href="/@communitySlug/home" class="hover:text-primary transition">@communityName</a>
                <i data-lucide="chevron-right" class="size-3.5"></i>
                <a href="/@communitySlug/companies" class="hover:text-primary transition">Bedrijven</a>
                <i data-lucide="chevron-right" class="size-3.5"></i>
                <a href="/@communitySlug/companies/@companySlug" class="hover:text-primary transition truncate max-w-32">@companyName</a>
                <i data-lucide="chevron-right" class="size-3.5"></i>
                <span class="text-foreground-700 font-medium">Bewerken</span>
            </nav>
        </div>
    </section>

    @if (!isManager)
    {
    <!-- ============================================ -->
    <!-- ACCESS DENIED                                  -->
    <!-- ============================================ -->
    <section class="w-full">
        <div class="w-full px-4 sm:px-6 lg:px-8 py-12">
            <div class="flex flex-col items-center gap-4 text-center">
                <div class="flex items-center justify-center size-16 rounded-full bg-danger-100">
                    <i data-lucide="shield-x" class="size-8 text-danger"></i>
                </div>
                <h1 class="text-xl font-bold text-foreground-900">Geen toegang</h1>
                <p class="text-sm text-foreground-500 max-w-md">Je hebt geen rechten om dit bedrijf te bewerken. Alleen gekoppelde teamleden kunnen wijzigingen aanbrengen.</p>
                <a href="/@communitySlug/companies/@companySlug"
                   class="mt-2 inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline">
                    <i data-lucide="arrow-left" class="size-4"></i>
                    Terug naar bedrijfspagina
                </a>
            </div>
        </div>
    </section>
    }
    else
    {
    <!-- ============================================ -->
    <!-- EDIT FORM                                      -->
    <!-- ============================================ -->
    <section class="flex flex-col gap-6  w-full px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
        <div class="flex items-center justify-between">
            <h1 class="text-xl sm:text-2xl font-bold text-foreground-900">Bedrijf bewerken</h1>
            <a href="/@communitySlug/companies/@companySlug"
                class="inline-flex items-center gap-1.5 text-sm text-foreground-500 hover:text-primary transition">
                <i data-lucide="x" class="size-4"></i>
                Annuleren
            </a>
        </div>

        @if (saveSuccess)
        {
            <div class="flex items-center gap-3 p-4 rounded-xl border border-success-200 bg-success-50">
                <i data-lucide="check-circle-2" class="size-5 text-success shrink-0"></i>
                <div class="flex flex-col gap-0.5">
                    <span class="text-sm font-medium text-success-800">Opgeslagen!</span>
                    <span class="text-xs text-success-800">De bedrijfsgegevens zijn bijgewerkt.
                        <a href="/@communitySlug/companies/@companySlug" class="underline font-medium">Bekijk bedrijfspagina</a>
                    </span>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(saveError))
        {
            <div class="flex items-center gap-3 p-4 rounded-xl border border-danger-200 bg-danger-50">
                <i data-lucide="alert-circle" class="size-5 text-danger shrink-0"></i>
                <span class="text-sm text-danger-800">@saveError</span>
            </div>
        }

        <form method="post" id="ce-save-form" class="flex flex-col gap-6">
            <input type="hidden" name="formAction" value="save-info" />
            <!-- ── General Info ── -->
            <div class="flex flex-col gap-4 bg-content1 rounded-xl border border-divider p-5 sm:p-6">
                <h2 class="text-base font-semibold text-foreground-900">Algemene informatie</h2>

                <div class="flex flex-col gap-1.5">
                    <label for="companyName" class="text-sm font-medium text-foreground-700">Bedrijfsnaam <span class="text-danger">*</span></label>
                    <input type="text" id="companyName" name="companyName" value="@companyName" required
                            class="w-full px-3 py-2 rounded-lg border border-divider bg-background text-sm text-foreground-900 placeholder:text-foreground-300 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
                </div>

                <div class="flex flex-col gap-1.5">
                    <label for="about" class="text-sm font-medium text-foreground-700">Over het bedrijf</label>
                    <textarea id="about" name="about" rows="4"
                              class="w-full px-3 py-2 rounded-lg border border-divider bg-background text-sm text-foreground-900 placeholder:text-foreground-300 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition resize-y"
                              placeholder="Beschrijf het bedrijf...">@about</textarea>
                </div>

                <div class="flex flex-col gap-1.5">
                    <label for="banner" class="text-sm font-medium text-foreground-700">Banner afbeelding URL</label>
                    <input type="url" id="banner" name="banner" value="@bannerImage"
                            placeholder="https://example.com/banner.jpg"
                            class="w-full px-3 py-2 rounded-lg border border-divider bg-background text-sm text-foreground-900 placeholder:text-foreground-300 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
                </div>
            </div>

            <!-- ── Contact Info ── -->
            <div class="flex flex-col gap-4 bg-content1 rounded-xl border border-divider p-5 sm:p-6">
                <h2 class="text-base font-semibold text-foreground-900">Contactgegevens</h2>

                <div class="flex flex-col gap-1.5">
                    <label for="address" class="text-sm font-medium text-foreground-700">Adres</label>
                    <input type="text" id="address" name="address" value="@address"
                            placeholder="Straat 1, 1234 AB Plaats"
                            class="w-full px-3 py-2 rounded-lg border border-divider bg-background text-sm text-foreground-900 placeholder:text-foreground-300 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="flex flex-col gap-1.5">
                        <label for="phone" class="text-sm font-medium text-foreground-700">Telefoon</label>
                        <input type="tel" id="phone" name="phone" value="@phone"
                                placeholder="+31 6 12345678"
                                class="w-full px-3 py-2 rounded-lg border border-divider bg-background text-sm text-foreground-900 placeholder:text-foreground-300 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label for="email" class="text-sm font-medium text-foreground-700">E-mail</label>
                        <input type="email" id="email" name="email" value="@email"
                                placeholder="info@bedrijf.nl"
                                class="w-full px-3 py-2 rounded-lg border border-divider bg-background text-sm text-foreground-900 placeholder:text-foreground-300 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
                    </div>
                </div>

                <div class="flex flex-col gap-1.5">
                    <label for="website" class="text-sm font-medium text-foreground-700">Website</label>
                    <input type="url" id="website" name="website" value="@website"
                            placeholder="https://bedrijf.nl"
                            class="w-full px-3 py-2 rounded-lg border border-divider bg-background text-sm text-foreground-900 placeholder:text-foreground-300 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
                </div>
            </div>

            <!-- ── Opening Hours ── -->
            <div class="flex flex-col gap-4 bg-content1 rounded-xl border border-divider p-5 sm:p-6">
                <div class="flex flex-col gap-1">
                    <h2 class="text-base font-semibold text-foreground-900">Openingstijden</h2>
                    <p class="text-xs text-foreground-400">Laat beide velden leeg als het bedrijf die dag gesloten is.</p>
                </div>

                <div class="flex flex-col gap-3">
                    @foreach (var day in dayOrder)
                    {
                        var openVal  = hoursOpen.ContainsKey(day) ? hoursOpen[day] : "";
                        var closeVal = hoursClose.ContainsKey(day) ? hoursClose[day] : "";
                        <div class="grid grid-cols-[80px_1fr_1fr] sm:grid-cols-[100px_1fr_1fr] items-center gap-3">
                            <span class="text-sm font-medium text-foreground-700">@dayToNl[day]</span>
                            <input type="time" name="hours_open_@day" value="@openVal"
                                    class="w-full px-3 py-2 rounded-lg border border-divider bg-background text-sm text-foreground-900 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
                            <input type="time" name="hours_close_@day" value="@closeVal"
                                    class="w-full px-3 py-2 rounded-lg border border-divider bg-background text-sm text-foreground-900 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
                        </div>
                    }
                </div>
            </div>

            <!-- ── Submit ── -->
            <div class="flex items-center gap-3 pt-2">
                <button type="submit"
                        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary/30 transition">
                    <i data-lucide="save" class="size-4"></i>
                    Opslaan
                </button>
                <a href="/@communitySlug/companies/@companySlug"
                    class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-divider text-sm font-medium text-foreground-600 hover:bg-content1 transition">
                    Annuleren
                </a>
            </div>
        </form>

        <!-- ============================================ -->
        <!-- TEAM MEMBERS MANAGEMENT                       -->
        <!-- ============================================ -->
        <div class="flex flex-col gap-4 bg-content1 rounded-xl border border-divider p-5 sm:p-6">
            <h2 class="text-base font-semibold text-foreground-900">Teamleden</h2>

            <!-- Add member form -->
            <div id="ce-add-form" class="flex items-end gap-3">
                <div class="flex flex-col gap-1.5 flex-1">
                    <label class="text-sm font-medium text-foreground-700">Lid toevoegen</label>
                    <div id="ce-add-user-select"></div>
                </div>
                <button type="button" id="ce-add-btn"
                        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary/30 transition shrink-0">
                    <i data-lucide="user-plus" class="size-4"></i>
                    Toevoegen
                </button>
            </div>

            <!-- Current members list -->
            <div id="ce-members">
            @if (members.Count == 0)
            {
                <p class="text-sm text-foreground-400 py-2">Er zijn nog geen teamleden gekoppeld.</p>
            }
            else
            {
                <div class="flex flex-col divide-y divide-divider">
                    @foreach (var m in members)
                    {
                        <div class="flex items-center justify-between gap-4 py-3">
                            <div class="flex items-center gap-3 min-w-0">
                                <button type="button" data-toggle-user="@m.UserId" title="@((bool)m.ShowInTeam ? "Verbergen in team" : "Tonen in team")"
                                        class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors shrink-0 @((bool)m.ShowInTeam ? "bg-primary" : "bg-foreground-200")">
                                    <span class="inline-block size-4 rounded-full bg-white shadow-sm transition-transform @((bool)m.ShowInTeam ? "translate-x-6" : "translate-x-1")"></span>
                                </button>
                                <div class="size-10 rounded-full overflow-hidden border-2 border-divider shrink-0">
                                    <img src="/DnnImageHandler.ashx?mode=profilepic&userId=@m.UserId&w=80&h=80" alt="@m.DisplayName" class="w-full h-full object-cover rounded-full" />
                                </div>
                                <div class="flex flex-col min-w-0">
                                    <span class="text-sm font-medium text-foreground-900 truncate">@m.DisplayName</span>
                                    @if (!string.IsNullOrEmpty((string)m.Email))
                                    {
                                        <span class="text-xs text-foreground-400 truncate">@m.Email</span>
                                    }
                                </div>
                            </div>
                            <div class="flex items-center gap-2 shrink-0">
                                @if ((int)m.UserId == ownerId) {
                                <span class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg border border-primary/20 bg-primary/5 text-xs font-medium text-primary">
                                    <i data-lucide="crown" class="size-3.5"></i>
                                    Eigenaar
                                </span>
                                } else {
                                <button type="button" data-remove-id="@m.Id"
                                        class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg border border-divider text-xs font-medium text-danger hover:bg-danger-50 hover:border-danger/30 transition">
                                    <i data-lucide="user-minus" class="size-3.5"></i>
                                    Verwijderen
                                </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            </div>
        </div>
    </section>
    }
</main>

@if (isManager)
{
<script src="/DesktopModules/MVC/Dnn.Modules.TableDZP/Resources/js/select.js"></script>
<script>
var CE_USERS = @(new HtmlString(new System.Web.Script.Serialization.JavaScriptSerializer().Serialize(allUsers.Select(u => new { value = u.UserId.ToString(), label = (string)u.DisplayName }))));
var CE_MEMBER_IDS = [@foreach (var m in members) {<text>@m.UserId,</text>}];
</script>
<script src="/DesktopModules/RazorModules/RazorHost/Scripts/Resources/js/company-edit.js"></script>
}

