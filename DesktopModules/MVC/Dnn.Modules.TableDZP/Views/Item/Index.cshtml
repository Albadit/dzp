@model Dnn.Modules.TableDZP.Models.DataTableViewModel
@functions{
    // Localization helper — pulls strings from SharedResources.resx so the
    // module respects the user's portal language (English / Dutch).
    static string L(string key) {
        var v = DotNetNuke.Services.Localization.Localization.GetString(
            key, "/DesktopModules/MVC/Dnn.Modules.TableDZP/App_LocalResources/SharedResources.resx");
        return string.IsNullOrEmpty(v) ? key : v;
    }
}
@{
    var config = Model.Config;
    var tid = Model.TableId;

    // Auto-disable actions when their query is empty
    if (config.IsSql)
    {
        if (string.IsNullOrEmpty(config.QueryInsert)) { config.AllowCreate = false; }
        if (string.IsNullOrEmpty(config.QueryUpdate)) { config.AllowEdit = false; }
        if (string.IsNullOrEmpty(config.QueryDelete)) { config.AllowDelete = false; }
        if (string.IsNullOrEmpty(config.QueryBulkDelete)) { config.AllowBulkDelete = false; }
    }

    // Table columns: exclude hidden, and select/multiselect only if they are the primary key
    var pk = config.PrimaryKey ?? "";
    var tableColumns = (config.Columns ?? new Dnn.Modules.TableDZP.Models.DataTableColumn[0])
        .Where(c => c.Type != "hidden" && !((c.Type == "select" || c.Type == "multiselect") && c.Key == pk)).ToArray();

    // Recalculate grid cols for table display
    var gridParts = new List<string>();
    if (config.AllowBulkDelete) { gridParts.Add("2.5rem"); }
    foreach (var tc in tableColumns) { gridParts.Add(tc.Type == "readonly" || tc.Type == "image" ? "auto" : "1fr"); }
    if (config.AllowEdit || config.AllowDelete) { gridParts.Add("6rem"); }
    var gridCols = string.Join(" ", gridParts);

    // ── Lookup execution (perf): collect every distinct select/multiselect
    //    column once, then run all of their queries against a SINGLE pooled
    //    SqlConnection. We also build a key→label dictionary per column so
    //    that rendering each cell becomes O(1) instead of O(options).
    var lookups   = new Dictionary<string, List<KeyValuePair<string, string>>>();
    var lookupMap = new Dictionary<string, Dictionary<string, string>>();
    var selectCols = new List<Dnn.Modules.TableDZP.Models.DataTableColumn>();
    var seenCols   = new HashSet<string>();
    var candidateCols = new List<Dnn.Modules.TableDZP.Models.DataTableColumn>();
    if (Model.EditableColumns != null) { candidateCols.AddRange(Model.EditableColumns); }
    if (Model.VisibleColumns  != null) { candidateCols.AddRange(Model.VisibleColumns); }
    foreach (var c in candidateCols)
    {
        if (c == null || string.IsNullOrEmpty(c.Pattern)) { continue; }
        if (c.Type != "select" && c.Type != "multiselect") { continue; }
        if (!seenCols.Add(c.Key)) { continue; }
        selectCols.Add(c);
    }

    if (selectCols.Count > 0)
    {
        try
        {
            var connStr = System.Configuration.ConfigurationManager.ConnectionStrings["SiteSqlServer"].ConnectionString;
            using (var conn = new System.Data.SqlClient.SqlConnection(connStr))
            {
                conn.Open();
                var rc = DZP.CommunityAuth.CommunityAuth.Current;
                foreach (var col in selectCols)
                {
                    var opts = new List<KeyValuePair<string, string>>();
                    var optMap = new Dictionary<string, string>(StringComparer.Ordinal);
                    try
                    {
                        using (var cmd = conn.CreateCommand())
                        {
                            cmd.CommandText    = col.Pattern;
                            cmd.CommandTimeout = 15;
                            if (rc != null)
                            {
                                if (col.Pattern.Contains("@rc_CommunityId"))   { cmd.Parameters.AddWithValue("@rc_CommunityId", rc.CommunityId); }
                                if (col.Pattern.Contains("@rc_CommunitySlug")) { cmd.Parameters.AddWithValue("@rc_CommunitySlug", (object)rc.CommunitySlug ?? System.DBNull.Value); }
                                if (col.Pattern.Contains("@rc_CommunityName")) { cmd.Parameters.AddWithValue("@rc_CommunityName", (object)rc.CommunityName ?? System.DBNull.Value); }
                                if (col.Pattern.Contains("@rc_CompanySlug"))   { cmd.Parameters.AddWithValue("@rc_CompanySlug", (object)rc.CompanySlug ?? System.DBNull.Value); }
                                if (col.Pattern.Contains("@rc_CompanyName"))   { cmd.Parameters.AddWithValue("@rc_CompanyName", (object)rc.CompanyName ?? System.DBNull.Value); }
                            }
                            using (var rdr = cmd.ExecuteReader())
                            {
                                while (rdr.Read())
                                {
                                    var val = rdr[0] != null ? rdr[0].ToString() : "";
                                    var lbl = rdr.FieldCount > 1 && rdr[1] != null ? rdr[1].ToString() : val;
                                    opts.Add(new KeyValuePair<string, string>(val, lbl));
                                    if (!optMap.ContainsKey(val)) { optMap[val] = lbl; }
                                }
                            }
                        }
                    }
                    catch { /* one bad lookup query shouldn't kill the page */ }
                    lookups[col.Key]   = opts;
                    lookupMap[col.Key] = optMap;
                }
            }
        }
        catch { }
    }

    // Upload endpoint for image-typed columns. Matches TableServiceRouteMapper
    // which registers route name "TableService" under module folder
    // "Dnn.Modules.TableDZP".
    var appBase   = (Request.ApplicationPath ?? "").TrimEnd('/');
    var uploadUrl = appBase + "/DesktopModules/Dnn.Modules.TableDZP/API/TableService/UploadImage";

    var alertMsg  = !string.IsNullOrEmpty(Model.SuccessMsg) ? Model.SuccessMsg : Model.ErrorMsg;
    var isSuccess = !string.IsNullOrEmpty(Model.SuccessMsg);

    // Bag of values shared with all child partials.
    var sharedVD = new ViewDataDictionary {
        { "tid",          tid },
        { "pk",           pk },
        { "tableColumns", tableColumns },
        { "gridCols",     gridCols },
        { "lookups",      lookups },
        { "lookupMap",    lookupMap },
        { "uploadUrl",    uploadUrl }
    };
}

<link rel="stylesheet" href="/DesktopModules/MVC/Dnn.Modules.TableDZP/Resources/css/module.css" />
@Html.Partial("~/DesktopModules/MVC/Dnn.Modules.TableDZP/Views/Shared/_Select.cshtml")

<div id="@tid" class="w-full max-w-7xl mx-auto flex flex-col gap-4 py-6" data-page-size="10" data-total="@Model.TotalRows" data-module-id="@Dnn.ModuleContext.ModuleId" data-tab-id="@Dnn.ModuleContext.TabId">

    @if (!string.IsNullOrEmpty(config.Title))
    {
        <h2 class="text-2xl font-bold text-foreground-900">@config.Title</h2>
    }

    @Html.Partial("~/DesktopModules/MVC/Dnn.Modules.TableDZP/Views/Shared/_Alert.cshtml", null, new ViewDataDictionary {
        { "alert-message", alertMsg },
        { "alert-success", isSuccess ? "true" : "" },
        { "alert-dismiss", "5000" }
    })

    @Html.Partial("~/DesktopModules/MVC/Dnn.Modules.TableDZP/Views/Item/_Toolbar.cshtml",    Model, sharedVD)
    @Html.Partial("~/DesktopModules/MVC/Dnn.Modules.TableDZP/Views/Item/_Table.cshtml",      Model, sharedVD)
    @Html.Partial("~/DesktopModules/MVC/Dnn.Modules.TableDZP/Views/Item/_Pagination.cshtml", Model, sharedVD)

</div>

@Html.Partial("~/DesktopModules/MVC/Dnn.Modules.TableDZP/Views/Item/_EditModal.cshtml", Model, sharedVD)
@if (config.AllowCreate)
{
    @Html.Partial("~/DesktopModules/MVC/Dnn.Modules.TableDZP/Views/Item/_CreateModal.cshtml", Model, sharedVD)
}
@Html.Partial("~/DesktopModules/MVC/Dnn.Modules.TableDZP/Views/Item/_DeleteModal.cshtml", Model, sharedVD)

<script>
    window['__dtLookups_@(tid)'] = {};
    @foreach (var kv in lookups)
    {
        var jsItems = new List<string>();
        foreach (var o in kv.Value) {
            var jv = o.Key.Replace("\\", "\\\\").Replace("'", "\\'").Replace("\r", "").Replace("\n", "\\n");
            var jl = o.Value.Replace("\\", "\\\\").Replace("'", "\\'").Replace("\r", "").Replace("\n", "\\n");
            jsItems.Add("{value:'" + jv + "',label:'" + jl + "'}");
        }
        @:window['__dtLookups_@(tid)']['@kv.Key'] = [@Html.Raw(string.Join(",", jsItems))]; 
    }
</script>
<script src="/DesktopModules/MVC/Dnn.Modules.TableDZP/Resources/js/dropzone.js"></script>
<script src="/DesktopModules/MVC/Dnn.Modules.TableDZP/Resources/js/module.js"></script>
<script>initDataTable('@tid')</script>
