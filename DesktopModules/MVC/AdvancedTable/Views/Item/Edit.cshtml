@model AdvancedTable.Models.DataTableConfig

@using DotNetNuke.Web.Mvc.Helpers
@using Newtonsoft.Json
@using System.Linq
@using System.Collections.Generic

@* // -- Config --
{
TableId     = "dt-communities",
Title       = "Communities",
AllowCreate   = true,
AllowEdit     = true,
AllowDelete   = true,
AllowBulkDelete = true,
SqlSelect     = "SELECT * FROM Community ORDER BY CommunityID",
SqlInsert     = "INSERT INTO Community (Name, Slug) VALUES (@Name, @Slug)",
SqlUpdate     = "UPDATE Community SET Name = @Name, Slug = @Slug WHERE CommunityID = @pk",
SqlDelete     = "DELETE FROM Community WHERE CommunityID = @pk",
SqlBulkDelete = "DELETE FROM Community WHERE CommunityID IN ({ids})",
}; *@

<link rel="stylesheet" href="/DesktopModules/MVC/AdvancedTable/Resources/css/edit.css" />
@Html.Partial("_Select")

<div id="EditConfig-@Dnn.ModuleContext.ModuleId">
    <div class="at-edit" id="editForm">
        <div class="at-collapse-toggle"><a href="#">Collapse All</a></div>

        <h2 class="at-section-head">
            <a href="#" class="at-expanded">Configure Data Table</a>
        </h2>
        <fieldset>
            <div class="at-field">
                <label for="Title">Title</label>
                @Html.TextBoxFor(m => m.Title, new { maxlength = "256", placeholder = "Table title" })
            </div>

            <div class="at-field">
                <label for="Mode">Data Source</label>
                <div id="modeSelect" data-selected="@(Model.Mode != "api" ? "sql" : "api")"></div>
                <input type="hidden" name="Mode" id="modeValue" value="@(Model.Mode != "api" ? "sql" : "api")" />
            </div>

            <!-- SQL Fields -->
            <div id="sqlFields" style="@(Model.Mode == "api" ? "display:none;" : "")">
                <div class="at-field">
                    <label for="QuerySelect">Query Select</label>
                    @Html.TextAreaFor(m => m.QuerySelect, new { rows = 1, placeholder = "SELECT * FROM MyTable", @class = "edit-code-area" })
                </div>

                <div class="at-field">
                    <label for="QueryInsert">Query Insert</label>
                    @Html.TextAreaFor(m => m.QueryInsert, new { rows = 1, placeholder = "INSERT INTO MyTable (Col1, Col2) VALUES (@@Col1, @@Col2)", @class = "edit-code-area" })
                </div>

                <div class="at-field">
                    <label for="QueryUpdate">Query Update</label>
                    @Html.TextAreaFor(m => m.QueryUpdate, new { rows = 1, placeholder = "UPDATE MyTable SET Col1=@@Col1 WHERE Id=@@pk", @class = "edit-code-area" })
                </div>

                <div class="at-field">
                    <label for="QueryDelete">Query Delete</label>
                    @Html.TextAreaFor(m => m.QueryDelete, new { rows = 2, placeholder = "DELETE FROM MyTable WHERE Id=@@pk", @class = "edit-code-area" })
                </div>

                <div class="at-field">
                    <label for="QueryBulkDelete">Query Bulk Delete</label>
                    @Html.TextAreaFor(m => m.QueryBulkDelete, new { rows = 2, placeholder = "DELETE FROM MyTable WHERE Id IN ({ids})", @class = "edit-code-area" })
                </div>
            </div>

            <!-- API Fields -->
            <div id="apiFields" style="@(Model.Mode != "api" ? "display:none;" : "")">
                <div class="at-field">
                    <label for="ApiBaseUrl">API Base URL</label>
                    @Html.TextBoxFor(m => m.ApiBaseUrl, new { placeholder = "https://api.example.com", @class = "edit-wide-input" })
                </div>

                <div class="at-field">
                    <label for="ApiHeaders">Headers <small class="edit-hint">(one per line: Key: Value)</small></label>
                    @Html.TextAreaFor(m => m.ApiHeaders, new { rows = 1, placeholder = "Authorization: Bearer YOUR_TOKEN\nContent-Type: application/json", @class = "edit-code-area" })
                </div>

                <div class="at-method-grid">
                    <div class="at-field">
                        <label for="ApiSelectMethod">Select Method</label>
                        <div class="api-method-ms" data-name="ApiSelectMethod" data-selected="@(Model.ApiSelectMethod ?? "GET")" data-options='[{"value":"GET","label":"GET"},{"value":"POST","label":"POST"}]'></div>
                        <input type="hidden" name="ApiSelectMethod" value="@(Model.ApiSelectMethod ?? "GET")" />
                    </div>
                    <div class="at-field">
                        <label for="ApiSelectPath">Select Path</label>
                        @Html.TextBoxFor(m => m.ApiSelectPath, new { placeholder = "/items", @class = "edit-path-input" })
                    </div>
                    <div class="at-field">
                        <label for="ApiInsertMethod">Insert Method</label>
                        <div class="api-method-ms" data-name="ApiInsertMethod" data-selected="@(Model.ApiInsertMethod ?? "POST")" data-options='[{"value":"POST","label":"POST"},{"value":"PUT","label":"PUT"}]'></div>
                        <input type="hidden" name="ApiInsertMethod" value="@(Model.ApiInsertMethod ?? "POST")" />
                    </div>
                    <div class="at-field">
                        <label for="ApiInsertPath">Insert Path</label>
                        @Html.TextBoxFor(m => m.ApiInsertPath, new { placeholder = "/items", @class = "edit-path-input" })
                    </div>
                    <div class="at-field">
                        <label for="ApiUpdateMethod">Update Method</label>
                        <div class="api-method-ms" data-name="ApiUpdateMethod" data-selected="@(Model.ApiUpdateMethod ?? "PUT")" data-options='[{"value":"PUT","label":"PUT"},{"value":"PATCH","label":"PATCH"},{"value":"POST","label":"POST"}]'></div>
                        <input type="hidden" name="ApiUpdateMethod" value="@(Model.ApiUpdateMethod ?? "PUT")" />
                    </div>
                    <div class="at-field">
                        <label for="ApiUpdatePath">Update Path <small class="edit-hint">({pk} = primary key)</small></label>
                        @Html.TextBoxFor(m => m.ApiUpdatePath, new { placeholder = "/items/{pk}", @class = "edit-path-input" })
                    </div>
                    <div class="at-field">
                        <label for="ApiDeleteMethod">Delete Method</label>
                        <div class="api-method-ms" data-name="ApiDeleteMethod" data-selected="@(Model.ApiDeleteMethod ?? "DELETE")" data-options='[{"value":"DELETE","label":"DELETE"},{"value":"POST","label":"POST"}]'></div>
                        <input type="hidden" name="ApiDeleteMethod" value="@(Model.ApiDeleteMethod ?? "DELETE")" />
                    </div>
                    <div class="at-field">
                        <label for="ApiDeletePath">Delete Path <small class="edit-hint">({pk} = primary key)</small></label>
                        @Html.TextBoxFor(m => m.ApiDeletePath, new { placeholder = "/items/{pk}", @class = "edit-path-input" })
                    </div>
                </div>
            </div>

            <h2 class="at-section-head">
                <a href="#" class="at-expanded">Permissions <small class="edit-hint">(leave empty to allow all)</small></a>
            </h2>
            <fieldset>
                <div class="edit-perm-info">
                    Each rule grants permissions to one or more roles/users.
                </div>
                <div id="permissionsContainer">
                    @if (Model.Permissions != null)
                    {
                        var grouped = Model.Permissions
                            .GroupBy(p => new { p.Type, p.AllowCreate, p.AllowEdit, p.AllowDelete, p.AllowBulkDelete })
                            .Select(g => new { g.Key.Type, Names = g.Select(p => p.Name).ToList(), g.Key.AllowCreate, g.Key.AllowEdit, g.Key.AllowDelete, g.Key.AllowBulkDelete });
                        foreach (var perm in grouped)
                        {
                            <div class="perm-row">
                                <div class="perm-type-ms" data-selected="@perm.Type"></div>
                                <div class="perm-name-ms" data-type="@perm.Type" data-selected="@Html.Raw(JsonConvert.SerializeObject(perm.Names))"></div>
                                <div class="perm-checks">
                                    <label><input type="checkbox" class="perm-create" @(perm.AllowCreate ? "checked" : "") /> Create</label>
                                    <label><input type="checkbox" class="perm-edit" @(perm.AllowEdit ? "checked" : "") /> Edit</label>
                                    <label><input type="checkbox" class="perm-delete" @(perm.AllowDelete ? "checked" : "") /> Delete</label>
                                    <label><input type="checkbox" class="perm-bulk" @(perm.AllowBulkDelete ? "checked" : "") /> Bulk Delete</label>
                                </div>
                                <button type="button" class="remove-perm"><i data-lucide="circle-x"></i></button>
                            </div>
                        }
                    }
                </div>
                <button type="button" id="addPermission" class="at-add-btn">+ Add Permission Rule</button>
            </fieldset>

            <h2 class="at-section-head">
                <a href="#" class="at-expanded">Columns <small class="edit-hint">(leave empty to auto-detect)</small></a>
            </h2>
            <fieldset>
                <div id="columnsContainer">
                    @if (Model.Columns != null)
                    {
                        foreach (var col in Model.Columns)
                        {
                            <div class="column-row">
                                <input type="text" class="col-key" value="@col.Key" placeholder="Column Key" />
                                <input type="text" class="col-label" value="@col.Label" placeholder="Display Label" />
                                <div class="col-type-ms" data-selected="@col.Type"></div>
                                @if ((col.Type == "select" || col.Type == "multiselect") && !string.IsNullOrEmpty(col.Pattern))
                                {
                                    <div class="col-query-wrap">
                                        <textarea class="col-query edit-code-area" rows="1" placeholder="SELECT value, label FROM ...">@col.Pattern</textarea>
                                    </div>
                                }
                                <button type="button" class="remove-col"><i data-lucide="circle-x"></i></button>
                            </div>
                        }
                    }
                </div>
                <button type="button" id="addColumn" class="at-add-btn">+ Add Column</button>
            </fieldset>

            <input type="hidden" name="ColumnsJson" id="columnsJson" />
            <input type="hidden" name="PermissionsJson" id="permissionsJson" />
        </fieldset>
    </div>
    <div class="at-actions">
        <button type="submit" class="at-btn-primary" id="btnSave">Save</button>
        <a id="cancelEdit" href="#" class="at-btn-secondary">Cancel</a>
    </div>
</div>

<script type="text/javascript">
    window.__dnnPermData = {
        roles: @Html.Raw(JsonConvert.SerializeObject((List<string>)ViewBag.DnnRoles)),
        users: @Html.Raw(JsonConvert.SerializeObject((List<string>)ViewBag.DnnUsers))
    };
</script>
<script type="text/javascript" src="/DesktopModules/MVC/AdvancedTable/Resources/js/edit.js"></script>
