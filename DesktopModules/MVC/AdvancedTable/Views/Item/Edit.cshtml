@model AdvancedTable.Models.DataTableConfig

@using DotNetNuke.Web.Mvc.Helpers
@using Newtonsoft.Json
@using System.Linq
@using System.Collections.Generic

@* // ── Config ────────────────────────────────────────────────────
var cfg = new DataTableConfig
{
TableId     = "dt-communities",
Title       = "Communities",
AllowCreate   = true,
AllowEdit     = true,
AllowDelete   = true,
AllowBulkDelete = true,
SqlSelect     = "SELECT * FROM Community ORDER BY CommunityID",
SqlInsert     = "INSERT INTO Community (Name, Slug) VALUES (@Name, @Slug)",
SqlUpdate     = "UPDATE Community SET Name = @Name, Slug = @Slug WHERE CommunityID = @pk",
SqlDelete     = "DELETE FROM Community WHERE CommunityID = @pk",
SqlBulkDelete = "DELETE FROM Community WHERE CommunityID IN ({ids})",
}; *@

<link rel="stylesheet" href="/DesktopModules/MVC/AdvancedTable/Resources/css/edit.css" />

<div id="EditConfig-@Dnn.ModuleContext.ModuleId">
    <div class="dnnForm dnnEditBasicSettings" id="dnnEditBasicSettings">
        <div class="dnnFormExpandContent dnnRight"><a href="#">Expand All</a></div>

        <h2 id="dnnSitePanel-BasicSettings" class="dnnFormSectionHead dnnClear">
            <a href="#" class="dnnSectionExpanded">Configure Data Table</a>
        </h2>
        <fieldset>
            <div class="dnnFormItem">
                <div><label for="Title">Title</label></div>
                @Html.TextBoxFor(m => m.Title, new { maxlength = "256", placeholder = "Table title" })
            </div>

            <div class="dnnFormItem">
                <div><label for="Mode">Data Source</label></div>
                <select name="Mode" id="modeSelect">
                    <option value="sql" @(Model.Mode != "api" ? "selected" : "")>SQL</option>
                    <option value="api" @(Model.Mode == "api" ? "selected" : "")>API</option>
                </select>
            </div>

            <!-- SQL Fields -->
            <div id="sqlFields" style="@(Model.Mode == "api" ? "display:none;" : "")">
                <div class="dnnFormItem">
                    <div><label for="QuerySelect">Query Select</label></div>
                    @Html.TextAreaFor(m => m.QuerySelect, new { rows = 4, placeholder = "SELECT * FROM MyTable", @class = "edit-code-area" })
                </div>

                <div class="dnnFormItem">
                    <div><label for="QueryInsert">Query Insert</label></div>
                    @Html.TextAreaFor(m => m.QueryInsert, new { rows = 3, placeholder = "INSERT INTO MyTable (Col1, Col2) VALUES (@@Col1, @@Col2)", @class = "edit-code-area" })
                </div>

                <div class="dnnFormItem">
                    <div><label for="QueryUpdate">Query Update</label></div>
                    @Html.TextAreaFor(m => m.QueryUpdate, new { rows = 3, placeholder = "UPDATE MyTable SET Col1=@@Col1 WHERE Id=@@pk", @class = "edit-code-area" })
                </div>

                <div class="dnnFormItem">
                    <div><label for="QueryDelete">Query Delete</label></div>
                    @Html.TextAreaFor(m => m.QueryDelete, new { rows = 2, placeholder = "DELETE FROM MyTable WHERE Id=@@pk", @class = "edit-code-area" })
                </div>

                <div class="dnnFormItem">
                    <div><label for="QueryBulkDelete">Query Bulk Delete</label></div>
                    @Html.TextAreaFor(m => m.QueryBulkDelete, new { rows = 2, placeholder = "DELETE FROM MyTable WHERE Id IN ({ids})", @class = "edit-code-area" })
                </div>
            </div>

            <!-- API Fields -->
            <div id="apiFields" style="@(Model.Mode != "api" ? "display:none;" : "")">
                <div class="dnnFormItem">
                    <div><label for="ApiBaseUrl">API Base URL</label></div>
                    @Html.TextBoxFor(m => m.ApiBaseUrl, new { placeholder = "https://api.example.com", @class = "edit-wide-input" })
                </div>

                <div class="dnnFormItem">
                    <div><label for="ApiHeaders">Headers <small class="edit-hint">(one per line: Key: Value)</small></label></div>
                    @Html.TextAreaFor(m => m.ApiHeaders, new { rows = 3, placeholder = "Authorization: Bearer YOUR_TOKEN\nContent-Type: application/json", @class = "edit-code-area" })
                </div>

                <div class="dnnFormItem edit-method-row">
                    <div>
                        <div><label for="ApiSelectMethod">Select Method</label></div>
                        <select name="ApiSelectMethod">
                            <option value="GET" @(Model.ApiSelectMethod == "GET" ? "selected" : "")>GET</option>
                            <option value="POST" @(Model.ApiSelectMethod == "POST" ? "selected" : "")>POST</option>
                        </select>
                    </div>
                    <div>
                        <div><label for="ApiSelectPath">Select Path</label></div>
                        @Html.TextBoxFor(m => m.ApiSelectPath, new { placeholder = "/items", @class = "edit-path-input" })
                    </div>
                </div>

                <div class="dnnFormItem edit-method-row">
                    <div>
                        <div><label for="ApiInsertMethod">Insert Method</label></div>
                        <select name="ApiInsertMethod">
                            <option value="POST" @(Model.ApiInsertMethod == "POST" ? "selected" : "")>POST</option>
                            <option value="PUT" @(Model.ApiInsertMethod == "PUT" ? "selected" : "")>PUT</option>
                        </select>
                    </div>
                    <div>
                        <div><label for="ApiInsertPath">Insert Path</label></div>
                        @Html.TextBoxFor(m => m.ApiInsertPath, new { placeholder = "/items", @class = "edit-path-input" })
                    </div>
                </div>

                <div class="dnnFormItem edit-method-row">
                    <div>
                        <div><label for="ApiUpdateMethod">Update Method</label></div>
                        <select name="ApiUpdateMethod">
                            <option value="PUT" @(Model.ApiUpdateMethod == "PUT" ? "selected" : "")>PUT</option>
                            <option value="PATCH" @(Model.ApiUpdateMethod == "PATCH" ? "selected" : "")>PATCH</option>
                            <option value="POST" @(Model.ApiUpdateMethod == "POST" ? "selected" : "")>POST</option>
                        </select>
                    </div>
                    <div>
                        <div><label for="ApiUpdatePath">Update Path <small class="edit-hint">({pk} = primary key)</small></label></div>
                        @Html.TextBoxFor(m => m.ApiUpdatePath, new { placeholder = "/items/{pk}", @class = "edit-path-input" })
                    </div>
                </div>

                <div class="dnnFormItem edit-method-row">
                    <div>
                        <div><label for="ApiDeleteMethod">Delete Method</label></div>
                        <select name="ApiDeleteMethod">
                            <option value="DELETE" @(Model.ApiDeleteMethod == "DELETE" ? "selected" : "")>DELETE</option>
                            <option value="POST" @(Model.ApiDeleteMethod == "POST" ? "selected" : "")>POST</option>
                        </select>
                    </div>
                    <div>
                        <div><label for="ApiDeletePath">Delete Path <small class="edit-hint">({pk} = primary key)</small></label></div>
                        @Html.TextBoxFor(m => m.ApiDeletePath, new { placeholder = "/items/{pk}", @class = "edit-path-input" })
                    </div>
                </div>
            </div>

            <div class="dnnFormItem">
                <label class="edit-check-label">
                    @Html.CheckBoxFor(m => m.AllowCreate) Allow Create
                </label>
            </div>
            <div class="dnnFormItem">
                <label class="edit-check-label">
                    @Html.CheckBoxFor(m => m.AllowEdit) Allow Edit
                </label>
            </div>
            <div class="dnnFormItem">
                <label class="edit-check-label">
                    @Html.CheckBoxFor(m => m.AllowDelete) Allow Delete
                </label>
            </div>
            <div class="dnnFormItem">
                <label class="edit-check-label">
                    @Html.CheckBoxFor(m => m.AllowBulkDelete) Allow Bulk Delete
                </label>
            </div>

            <h2 id="dnnSitePanel-Permissions" class="dnnFormSectionHead dnnClear edit-section-head">
                <a href="#" class="dnnSectionExpanded">Permissions <small class="edit-hint">(leave empty to use global Allow flags above)</small></a>
            </h2>
            <fieldset>
                <div class="edit-perm-info">
                    When permission rules are defined, the Allow checkboxes above become defaults for users who match no rule.
                    Each rule grants permissions to a specific role or user.
                </div>
                <div id="permissionsContainer">
                    @if (Model.Permissions != null)
                    {
                        foreach (var perm in Model.Permissions)
                        {
                            <div class="perm-row">
                                <select class="perm-type">
                                    <option value="">-- Type --</option>
                                    <option value="role" @(perm.Type == "role" ? "selected" : "")>Role</option>
                                    <option value="user" @(perm.Type == "user" ? "selected" : "")>User</option>
                                </select>
                                <select class="perm-name">
                                    <option value="">-- Select --</option>
                                    @if (perm.Type == "role")
                                    {
                                        foreach (var role in (List<string>)ViewBag.DnnRoles)
                                        {
                                            <option value="@role" @(perm.Name == role ? "selected" : "")>@role</option>
                                        }
                                    }
                                    @if (perm.Type == "user")
                                    {
                                        foreach (var user in (List<string>)ViewBag.DnnUsers)
                                        {
                                            <option value="@user" @(perm.Name == user ? "selected" : "")>@user</option>
                                        }
                                    }
                                </select>
                                <label>
                                    <input type="checkbox" class="perm-create" @(perm.AllowCreate ? "checked" : "") /> Create
                                </label>
                                <label>
                                    <input type="checkbox" class="perm-edit" @(perm.AllowEdit ? "checked" : "") /> Edit
                                </label>
                                <label>
                                    <input type="checkbox" class="perm-delete" @(perm.AllowDelete ? "checked" : "") /> Delete
                                </label>
                                <label>
                                    <input type="checkbox" class="perm-bulk" @(perm.AllowBulkDelete ? "checked" : "") /> Bulk Delete
                                </label>
                                <button type="button" class="remove-perm dnnSecondaryAction">&#10005;</button>
                            </div>
                        }
                    }
                </div>
                <button type="button" id="addPermission" class="dnnSecondaryAction edit-add-btn">+ Add Permission Rule</button>
            </fieldset>

            <h2 id="dnnSitePanel-Columns" class="dnnFormSectionHead dnnClear edit-section-head">
                <a href="#" class="dnnSectionExpanded">Columns <small class="edit-hint">(leave empty to auto-detect)</small></a>
            </h2>
            <fieldset>
                <div id="columnsContainer">
                    @if (Model.Columns != null)
                    {
                        foreach (var col in Model.Columns)
                        {
                            <div class="column-row">
                                <input type="text" class="col-key" value="@col.Key" placeholder="Column Key" />
                                <input type="text" class="col-label" value="@col.Label" placeholder="Display Label" />
                                <select class="col-type">
                                    <option value="text" @(col.Type == "text" ? "selected" : "")>Text</option>
                                    <option value="readonly" @(col.Type == "readonly" ? "selected" : "")>Read Only</option>
                                    <option value="hidden" @(col.Type == "hidden" ? "selected" : "")>Hidden</option>
                                    <option value="number" @(col.Type == "number" ? "selected" : "")>Number</option>
                                    <option value="email" @(col.Type == "email" ? "selected" : "")>Email</option>
                                    <option value="url" @(col.Type == "url" ? "selected" : "")>URL</option>
                                </select>
                                <button type="button" class="remove-col dnnSecondaryAction">&#10005;</button>
                            </div>
                        }
                    }
                </div>
                <button type="button" id="addColumn" class="dnnSecondaryAction edit-add-btn">+ Add Column</button>
            </fieldset>

            <input type="hidden" name="ColumnsJson" id="columnsJson" />
            <input type="hidden" name="PermissionsJson" id="permissionsJson" />
        </fieldset>
    </div>
    <div class="edit-actions">
        <button type="submit" class="dnnPrimaryAction" id="btnSave">Save</button>
        <a id="cancelEdit" href="#" class="dnnSecondaryAction">Cancel</a>
    </div>
</div>

<script type="text/javascript">
    window.__dnnPermData = {
        roles: @Html.Raw(JsonConvert.SerializeObject((List<string>)ViewBag.DnnRoles)),
        users: @Html.Raw(JsonConvert.SerializeObject((List<string>)ViewBag.DnnUsers))
    };
</script>
<script type="text/javascript" src="/DesktopModules/MVC/AdvancedTable/Resources/js/edit.js"></script>
