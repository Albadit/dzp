        display: inline-flex; align-items: center; gap: var(--rmh-space-2);
    }
    .rmh-edit__btn-ghost:hover  { color: var(--rmh-color-text); background: var(--rmh-color-surface-2); border-color: var(--rmh-color-border); }
    .rmh-edit__btn-ghost:active { transform: translateY(1px); }
    .rmh-edit__btn-ghost svg    { width: var(--rmh-icon-sm); height: var(--rmh-icon-sm); stroke: currentColor; }

    .rmh-edit__count { margin-left: auto; font-size: var(--rmh-font-xs); color: var(--rmh-color-text-muted); }

    .rmh-edit__editor-wrap { margin-top: var(--rmh-space-7); }
    .rmh-edit__editor-bar { display: flex; align-items: center; gap: var(--rmh-space-2); padding: var(--rmh-space-3) var(--rmh-space-4); background: var(--rmh-color-surface-dark); color: var(--rmh-color-text-invert); border: 1px solid var(--rmh-color-surface-dark); border-bottom: 0; border-radius: var(--rmh-radius-md) var(--rmh-radius-md) 0 0; font-size: var(--rmh-font-xs); }
    .rmh-edit__editor-bar svg { width: var(--rmh-icon-sm); height: var(--rmh-icon-sm); stroke: var(--rmh-color-primary-soft); }
    .rmh-edit__editor-bar code { background: rgba(255,255,255,0.08); color: var(--rmh-color-text-invert); padding: 1px var(--rmh-space-2); border-radius: var(--rmh-radius-sm); font-size: var(--rmh-font-xs); }
    .rmh-edit__editor-bar .rmh-edit__lines { margin-left: auto; opacity: .7; }
    .rmh-edit__textarea {
        display: block; width: 100%; min-height: 360px; resize: vertical;
        padding: var(--rmh-space-5);
        font-family: var(--rmh-font-mono); font-size: var(--rmh-font-mono-size); line-height: 1.55; color: var(--rmh-color-text-invert);
        background: var(--rmh-color-surface-darker); border: 1px solid var(--rmh-color-surface-dark); border-top: 0;
        border-radius: 0 0 var(--rmh-radius-md) var(--rmh-radius-md); outline: none;
        tab-size: 4; -moz-tab-size: 4;
        white-space: pre; overflow: auto;
