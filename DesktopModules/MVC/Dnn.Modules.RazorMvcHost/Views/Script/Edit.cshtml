    .rmh-edit__textarea:focus { box-shadow: inset 0 0 0 1px var(--rmh-color-primary); }

    /* ---- mobile / tablet responsive ---- */
    @@media (max-width: 768px) {
        .rmh-edit { padding: var(--rmh-space-4); }
        .rmh-edit__card { padding: var(--rmh-space-6); border-radius: var(--rmh-radius-lg); }
        .rmh-edit__header { gap: var(--rmh-space-4); margin-bottom: var(--rmh-space-6); }
        .rmh-edit__icon-wrap { width: 36px; height: 36px; flex: 0 0 36px; }
        .rmh-edit__title { font-size: 16px; }
        .rmh-edit__subtitle { font-size: var(--rmh-font-xs); }
        .rmh-edit__select { padding: var(--rmh-space-3) 32px var(--rmh-space-3) var(--rmh-space-4); font-size: var(--rmh-font-sm); }
        .rmh-edit__textarea { min-height: 280px; padding: var(--rmh-space-4); font-size: 12px; }
        .rmh-edit__editor-bar { flex-wrap: wrap; }
        .rmh-edit__editor-bar .rmh-edit__lines { margin-left: 0; flex-basis: 100%; }
        .rmh-edit__actions { flex-wrap: wrap; gap: var(--rmh-space-2); }
        .rmh-edit__btn-primary, .rmh-edit__btn-secondary { flex: 1 1 auto; justify-content: center; padding: var(--rmh-space-4) var(--rmh-space-5); }
        .rmh-edit__btn-ghost { flex: 1 1 100%; justify-content: center; padding: var(--rmh-space-4) var(--rmh-space-5); }
        .rmh-edit__count { flex-basis: 100%; margin-left: 0; text-align: center; margin-top: var(--rmh-space-2); }
        .rmh-edit__active-row { font-size: 11px; gap: var(--rmh-space-2); }
        .rmh-edit__active-sep { display: none; }
    }

    @@media (max-width: 480px) {
        .rmh-edit { padding: var(--rmh-space-3); }
        .rmh-edit__card { padding: var(--rmh-space-5); }
        .rmh-edit__header { flex-direction: column; align-items: flex-start; }
        .rmh-edit__textarea { min-height: 220px; }
        .rmh-edit__actions { flex-direction: column; align-items: stretch; }
        .rmh-edit__btn-primary, .rmh-edit__btn-secondary { width: 100%; }
        .rmh-edit__btn-ghost { width: 100%; }
    }
</style>

<div class="rmh-edit">

    <div class="rmh-edit__header">
        <span class="rmh-edit__icon-wrap" aria-hidden="true">
            @* file-code icon *@
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <path d="m9 18-3-3 3-3"/>
                <path d="m15 12 3 3-3 3"/>
            </svg>
        </span>
        <div>
            <h2 class="rmh-edit__title">Razor MVC Host</h2>
            <p class="rmh-edit__subtitle">Pick a Razor view to render in this module instance.</p>
        </div>
    </div>

    <form method="post" action="@postUrl" class="rmh-edit__card" data-current-active="@selected">

        <div class="rmh-edit__field">
            <div class="rmh-edit__label-row">
                <label for="scriptPath" class="rmh-edit__label">Script file</label>
                <span class="rmh-edit__label-hint">resolved relative to <code>Views/Scripts/</code></span>
            </div>

            @if (available.Count == 0)
            {
                <div class="rmh-edit__empty">
                    No <code>.cshtml</code> files were found under
                    <code>~/DesktopModules/MVC/Dnn.Modules.RazorMvcHost/Views/Scripts/</code>.
                    Drop one in and reload this page.
                </div>
                <input type="hidden" name="scriptPath" value="" />
            }
            else
            {
                <div class="rmh-edit__select-wrap">
                    <select id="scriptPath" name="scriptPath" class="rmh-edit__select">
                        <option value="">— None (module shows placeholder) —</option>
                        @foreach (var path in available)
                        {
                            if (string.Equals(path, selected, System.StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@path" selected="selected">@path</option>
                            }
                            else
                            {
                                <option value="@path">@path</option>
                            }
                        }
                    </select>
                    @* chevron *@
                    <svg class="rmh-edit__chev" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </div>
            }
        </div>

        <div class="rmh-edit__editor-wrap" style="@(hasSelected ? "" : "display:none")">
            <label for="scriptContent" class="rmh-edit__label">Script source</label>
            <div class="rmh-edit__editor-bar">
                @* code icon *@
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                <code>@selected</code>
                <span class="rmh-edit__lines">@(content == null ? 0 : content.Split('\n').Length) lines &middot; @(content == null ? 0 : content.Length) chars</span>
            </div>
            <textarea id="scriptContent" name="scriptContent" class="rmh-edit__textarea" spellcheck="false" wrap="off">@content</textarea>
            <p class="rmh-edit__hint">Edits are saved to <code>~/DesktopModules/MVC/Dnn.Modules.RazorMvcHost/Views/Scripts/<span class="rmh-edit__hint-path">@selected</span></code> when you click Save.</p>
            <div class="rmh-edit__active-row">
                <label class="rmh-edit__active-toggle">
                    <input type="checkbox" id="setActive" name="setActive" value="1" @(hasSelected ? "checked=\"checked\"" : "") />
                    Set as <strong>active</strong>
                </label>
                <span class="rmh-edit__active-sep">|</span>
                <span>
                    Currently active:
                    @if (hasSelected)
                    {
                        <code class="rmh-edit__active-name">@selected</code>
                    }
                    else
                    {
                        <em>none</em>
                    }
                </span>
            </div>
        </div>

        <div class="rmh-edit__actions">
            <button type="submit" name="submitAction" value="save" class="rmh-edit__btn-secondary" title="Save and keep editing">
                @* save-only icon (disk) *@
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                    <polyline points="17 21 17 13 7 13 7 21"/>
                </svg>
                Save
            </button>
            <button type="submit" name="submitAction" value="saveReturn" class="rmh-edit__btn-primary" title="Save and close the edit screen">
                @* save + arrow icon *@
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                    <polyline points="17 21 17 13 7 13 7 21"/>
                    <polyline points="7 3 7 8 15 8"/>
                </svg>
                Save &amp; Return
            </button>
            <button type="submit" name="submitAction" value="return" class="rmh-edit__btn-ghost" title="Discard and go back without saving" formnovalidate="formnovalidate">
                @* arrow-left icon *@
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="19" y1="12" x2="5" y2="12"/>
                    <polyline points="12 19 5 12 12 5"/>
                </svg>
                Return
            </button>
            <span class="rmh-edit__count">@available.Count script@(available.Count == 1 ? "" : "s") available</span>
        </div>

    </form>
</div>

<script>
    (function () {
        var allContents = @Html.Raw(allContentsJson);
        var sel = document.getElementById('scriptPath');
        if (!sel) { return; }
        var form          = sel.closest('form');
        var currentActive = form ? (form.getAttribute('data-current-active') || '') : '';
        var ta            = document.getElementById('scriptContent');
        var editorWrap    = document.querySelector('.rmh-edit__editor-wrap');
        var bar           = editorWrap ? editorWrap.querySelector('.rmh-edit__editor-bar') : null;
        var barCode       = bar ? bar.querySelector('code') : null;
        var barLines      = bar ? bar.querySelector('.rmh-edit__lines') : null;
        var hintPath      = document.querySelector('.rmh-edit__hint-path');
        var setActive     = document.getElementById('setActive');

        // Per-path user overrides for the "set active" checkbox. If the user
        // explicitly toggles the checkbox while a given file is selected, we
        // remember that choice so coming back to the same file in this session
        // restores it instead of snapping back to the auto default.
        var overrides = {};

        function defaultChecked(path, hasSel) {
            if (!hasSel) { return false; }
            // If a script is currently active on disk, only auto-check when the
            // dropdown matches it. Otherwise (no active yet) auto-check, since
            // picking any file is most likely a "make this the one" action.
            if (currentActive && currentActive.length > 0) {
                return path === currentActive;
            }
            return true;
        }

        function update() {
            var path   = sel.value || '';
            var hasSel = path.length > 0;
            var text   = hasSel && allContents.hasOwnProperty(path) ? allContents[path] : '';

            if (editorWrap) { editorWrap.style.display = hasSel ? '' : 'none'; }
            if (ta)         { ta.value = text; }
            if (barCode)    { barCode.textContent = path; }
            if (barLines)   { barLines.textContent = text.split('\n').length + ' lines \u00b7 ' + text.length + ' chars'; }
            if (hintPath)   { hintPath.textContent = path; }

            if (setActive) {
                setActive.checked = overrides.hasOwnProperty(path)
                    ? overrides[path]
                    : defaultChecked(path, hasSel);
            }
        }

        sel.addEventListener('change', update);
        if (setActive) {
            setActive.addEventListener('change', function () {
                var path = sel.value || '';
                if (path.length > 0) { overrides[path] = setActive.checked; }
            });
        }
    })();
