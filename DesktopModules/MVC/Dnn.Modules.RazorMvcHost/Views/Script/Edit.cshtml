@*
    Edit screen — pick which .cshtml under /Views/Scripts/ to render for
    this module instance. Selection is persisted in module settings.

    NOTE: DNN MVC's `DnnHtmlHelper<T>` does NOT expose `Html.BeginForm`
    or `Html.AntiForgeryToken`, so we emit a plain HTML form and rely on
    DNN's own moduleId routing to deliver the POST to ScriptController.Edit.

    Self-contained styling — does not assume Tailwind/Bootstrap is loaded
    in the host page (DNN edit dialog).
*@
@{
    Layout = null;
    var available = ViewBag.AvailableScripts as System.Collections.Generic.List<string>
                    ?? new System.Collections.Generic.List<string>();
    var selected  = ViewBag.Selected as string ?? string.Empty;
    var content   = ViewBag.ScriptContent as string ?? string.Empty;
    var allContents = ViewBag.AllContents as System.Collections.Generic.Dictionary<string, string>
                      ?? new System.Collections.Generic.Dictionary<string, string>();
    var postUrl   = Url.Action("Edit", "Script");
    var hasSelected = !string.IsNullOrEmpty(selected);
    var allContentsJson = Newtonsoft.Json.JsonConvert.SerializeObject(allContents);
}

<style>
    .rmh-edit {
        /* ---- design tokens (DRY) ---- */
        --rmh-color-text:        #111827;
        --rmh-color-text-soft:   #374151;
        --rmh-color-text-muted:  #6b7280;
        --rmh-color-text-invert: #e5e7eb;

        --rmh-color-surface:     #ffffff;
        --rmh-color-surface-2:   #f9fafb;
        --rmh-color-surface-3:   #f3f4f6;
        --rmh-color-surface-dark: #1f2937;
        --rmh-color-surface-darker: #111827;

        --rmh-color-border:      #e5e7eb;
        --rmh-color-border-2:    #d1d5db;
        --rmh-color-border-soft: #f3f4f6;

        --rmh-color-primary:        #3b82f6;
        --rmh-color-primary-strong: #6366f1;
        --rmh-color-primary-ring:   rgba(59,130,246,0.25);
        --rmh-color-primary-glow:   rgba(59,130,246,0.4);
        --rmh-color-primary-soft:   #93c5fd;

        --rmh-color-success-bg:     #ecfdf5;
        --rmh-color-success-border: #a7f3d0;
        --rmh-color-success-text:   #065f46;
        --rmh-color-success-icon:   #059669;

        --rmh-color-warn-bg:     #fffbeb;
        --rmh-color-warn-border: #fde68a;
        --rmh-color-warn-text:   #92400e;
        --rmh-color-warn-icon:   #d97706;

        --rmh-color-empty-bg:     #fef3c7;
        --rmh-color-empty-border: #fcd34d;

        --rmh-gradient-primary: linear-gradient(135deg, var(--rmh-color-primary), var(--rmh-color-primary-strong));

        --rmh-radius-sm: 3px;
        --rmh-radius-md: 8px;
        --rmh-radius-lg: 10px;
        --rmh-radius-xl: 12px;
        --rmh-radius-pill: 999px;

        --rmh-space-1: 4px;
        --rmh-space-2: 6px;
        --rmh-space-3: 8px;
        --rmh-space-4: 10px;
        --rmh-space-5: 12px;
        --rmh-space-6: 16px;
        --rmh-space-7: 18px;
        --rmh-space-8: 20px;

        --rmh-font-stack:    -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        --rmh-font-mono:     ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;
        --rmh-font-xs: 12px;
        --rmh-font-sm: 13px;
        --rmh-font-md: 14px;
        --rmh-font-lg: 18px;
        --rmh-font-mono-size: 12.5px;

        --rmh-icon-sm: 14px;
        --rmh-icon-md: 16px;
        --rmh-icon-lg: 22px;

        --rmh-shadow-card:   0 1px 2px rgba(0,0,0,0.04);
        --rmh-shadow-btn:    0 1px 2px var(--rmh-color-primary-glow);
        --rmh-shadow-btn-hv: 0 4px 12px var(--rmh-color-primary-glow);
        --rmh-transition:    border-color .15s, box-shadow .15s, background .15s;

        /* ---- container ---- */
        width: 100%; max-width: 1280px; margin: 0 auto;
        padding: var(--rmh-space-6);
        font-family: var(--rmh-font-stack); color: var(--rmh-color-text);
    }
    .rmh-edit * { box-sizing: border-box; }

    .rmh-edit__header { display: flex; align-items: center; gap: var(--rmh-space-5); margin-bottom: var(--rmh-space-7); }
    .rmh-edit__icon-wrap { width: 40px; height: 40px; flex: 0 0 40px; border-radius: var(--rmh-radius-lg); background: var(--rmh-gradient-primary); display: inline-flex; align-items: center; justify-content: center; }
    .rmh-edit__icon-wrap svg { width: var(--rmh-icon-lg); height: var(--rmh-icon-lg); stroke: #fff; }
    .rmh-edit__title { margin: 0; font-size: var(--rmh-font-lg); font-weight: 600; line-height: 1.2; }
    .rmh-edit__subtitle { margin: 2px 0 0 0; font-size: var(--rmh-font-sm); color: var(--rmh-color-text-muted); line-height: 1.3; }

    .rmh-edit__card { background: var(--rmh-color-surface); border: 1px solid var(--rmh-color-border); border-radius: var(--rmh-radius-xl); padding: var(--rmh-space-8); box-shadow: var(--rmh-shadow-card); }

    .rmh-edit__field { margin-bottom: var(--rmh-space-6); }
    .rmh-edit__label { display: block; font-size: var(--rmh-font-sm); font-weight: 600; color: var(--rmh-color-text-soft); margin-bottom: var(--rmh-space-2); }
    .rmh-edit__label-row { display: flex; align-items: baseline; justify-content: space-between; gap: var(--rmh-space-3); flex-wrap: wrap; margin-bottom: var(--rmh-space-2); }
    .rmh-edit__label-row .rmh-edit__label { margin-bottom: 0; }
    .rmh-edit__label-hint { font-size: var(--rmh-font-xs); color: var(--rmh-color-text-muted); font-weight: 400; }
    .rmh-edit__label-hint code { background: var(--rmh-color-surface-2); padding: 1px var(--rmh-space-2); border-radius: var(--rmh-radius-sm); font-family: var(--rmh-font-mono); font-size: 0.85em; }
    .rmh-edit__hint  { font-size: var(--rmh-font-xs); color: var(--rmh-color-text-muted); margin: var(--rmh-space-1) 0 0 0; }

    .rmh-edit__select-wrap { position: relative; }
    .rmh-edit__select {
        appearance: none; -webkit-appearance: none; -moz-appearance: none;
        width: 100%; padding: var(--rmh-space-4) 36px var(--rmh-space-4) var(--rmh-space-5);
        font: inherit; font-size: var(--rmh-font-md); color: var(--rmh-color-text);
        background: var(--rmh-color-surface-2); border: 1px solid var(--rmh-color-border-2); border-radius: var(--rmh-radius-md);
        cursor: pointer; outline: none;
        transition: var(--rmh-transition);
    }
    .rmh-edit__select:hover { background: var(--rmh-color-surface-3); }
    .rmh-edit__select:focus-visible { border-color: var(--rmh-color-primary); box-shadow: 0 0 0 3px var(--rmh-color-primary-ring); background: var(--rmh-color-surface); }
    .rmh-edit__chev { position: absolute; right: var(--rmh-space-5); top: 50%; transform: translateY(-50%); pointer-events: none; width: var(--rmh-icon-md); height: var(--rmh-icon-md); stroke: var(--rmh-color-text-muted); }

    /* active-script toggle (compact, inline) */
    .rmh-edit__active-row { display: flex; flex-wrap: wrap; align-items: center; gap: var(--rmh-space-3); margin-top: var(--rmh-space-2); font-size: var(--rmh-font-xs); color: var(--rmh-color-text-muted); }
    .rmh-edit__active-toggle { display: inline-flex; align-items: center; gap: var(--rmh-space-2); cursor: pointer; user-select: none; color: var(--rmh-color-text-soft); }
    .rmh-edit__active-toggle input[type="checkbox"] { width: 14px; height: 14px; accent-color: var(--rmh-color-primary); cursor: pointer; margin: 0; }
    .rmh-edit__active-toggle strong { color: var(--rmh-color-text); }
    .rmh-edit__active-sep { color: var(--rmh-color-border-2); }
    .rmh-edit__active-name { background: rgba(59,130,246,0.10); color: var(--rmh-color-primary); padding: 0 var(--rmh-space-2); border-radius: var(--rmh-radius-sm); font-size: var(--rmh-font-xs); font-family: var(--rmh-font-mono); }

    .rmh-edit__empty { padding: var(--rmh-space-6); background: var(--rmh-color-empty-bg); border: 1px solid var(--rmh-color-empty-border); border-radius: var(--rmh-radius-md); color: var(--rmh-color-warn-text); font-size: var(--rmh-font-sm); line-height: 1.45; }
    .rmh-edit__empty code { background: rgba(120,53,15,0.10); padding: 1px 5px; border-radius: var(--rmh-radius-sm); font-size: var(--rmh-font-xs); }

    .rmh-edit__actions { display: flex; gap: var(--rmh-space-3); align-items: center; margin-top: var(--rmh-space-7); padding-top: var(--rmh-space-6); border-top: 1px solid var(--rmh-color-border-soft); }
    .rmh-edit__btn-primary {
        appearance: none; border: 0; cursor: pointer;
        padding: 9px 18px; font: inherit; font-size: var(--rmh-font-md); font-weight: 600;
        color: #fff; background: var(--rmh-gradient-primary);
        border-radius: var(--rmh-radius-md); box-shadow: var(--rmh-shadow-btn);
        transition: transform .1s, box-shadow .15s, opacity .15s;
        display: inline-flex; align-items: center; gap: var(--rmh-space-2);
    }
    .rmh-edit__btn-primary:hover  { box-shadow: var(--rmh-shadow-btn-hv); }
    .rmh-edit__btn-primary:active { transform: translateY(1px); }
    .rmh-edit__btn-primary svg    { width: var(--rmh-icon-sm); height: var(--rmh-icon-sm); stroke: #fff; }

    .rmh-edit__btn-secondary {
        appearance: none; cursor: pointer;
        padding: 9px 16px; font: inherit; font-size: var(--rmh-font-md); font-weight: 600;
        color: var(--rmh-color-primary); background: var(--rmh-color-surface);
        border: 1px solid var(--rmh-color-border-2);
        border-radius: var(--rmh-radius-md);
        transition: var(--rmh-transition);
        display: inline-flex; align-items: center; gap: var(--rmh-space-2);
    }
    .rmh-edit__btn-secondary:hover  { border-color: var(--rmh-color-primary); background: var(--rmh-color-surface-2); }
    .rmh-edit__btn-secondary:active { transform: translateY(1px); }
    .rmh-edit__btn-secondary svg    { width: var(--rmh-icon-sm); height: var(--rmh-icon-sm); stroke: var(--rmh-color-primary); }

    .rmh-edit__btn-ghost {
        appearance: none; cursor: pointer;
        padding: 9px 16px; font: inherit; font-size: var(--rmh-font-md); font-weight: 500;
