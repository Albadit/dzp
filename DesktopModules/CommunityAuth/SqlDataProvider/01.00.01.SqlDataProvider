--  Schema: RolePermissions
--  â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
--  Maps DNN roles to scoped permission strings (e.g. "blog:read",
--  "blog:manage", "table:edit", "company:edit"). Loaded by
--  CommunityAuth.HasPermission() per request and ORed across all
--  roles a user holds (DNN roles + community roles).
--
--  Permissions are free-form strings; no enforced enum. Convention:
--  "<area>:<action>" â€” area is the module/feature, action is one of
--  read|create|edit|delete|manage|access (or anything else).
-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'RolePermissions' AND schema_id = SCHEMA_ID('dbo'))
CREATE TABLE [dbo].[RolePermissions] (
    [Id]         INT            IDENTITY(1,1) NOT NULL,
    [RoleID]     INT            NOT NULL,
    [Permission] NVARCHAR(128)  NOT NULL,
    [CreatedOn]  DATETIME2      NOT NULL CONSTRAINT [DF_RolePermissions_CreatedOn] DEFAULT (GETUTCDATE()),
    CONSTRAINT [PK_RolePermissions]        PRIMARY KEY ([Id]),
    CONSTRAINT [UQ_RolePermissions]        UNIQUE ([RoleID], [Permission]),
    CONSTRAINT [FK_RolePermissions_Roles]  FOREIGN KEY ([RoleID])
        REFERENCES [dbo].[Roles]([RoleID]) ON DELETE CASCADE
);

IF NOT EXISTS (SELECT * FROM sys.indexes WHERE name = 'IX_RolePermissions_Permission' AND object_id = OBJECT_ID('dbo.RolePermissions'))
CREATE INDEX [IX_RolePermissions_Permission]
    ON [dbo].[RolePermissions] ([Permission]);

