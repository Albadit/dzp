--  Seed: predefined permissions for known roles
--  â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
--  Catalog (free-form, but conventional):
--    blog:read       blog:create     blog:manage
--    table:read      table:create    table:edit       table:delete    table:manage
--    company:read    company:edit
--
--  Mapping (idempotent â€” only inserts missing rows):
--    Community beheerder (RoleID 100): all manage + edit perms
--    Algemeen bestuur    (RoleID  99): blog:manage, table:edit, company:edit
--    Directeur           (RoleID  97): company:edit
--    Bedrijfseigenaar    (RoleID  94): company:edit
--    Bedrijfsmanager     (RoleID  93): company:edit
--    Lid                 (RoleID  91): blog:read, table:read, company:read
-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

;WITH SeedPerms ([RoleID], [Permission]) AS (
    -- Community beheerder
    SELECT 100, N'blog:read'      UNION ALL
    SELECT 100, N'blog:create'    UNION ALL
    SELECT 100, N'blog:manage'    UNION ALL
    SELECT 100, N'table:read'     UNION ALL
    SELECT 100, N'table:create'   UNION ALL
    SELECT 100, N'table:edit'     UNION ALL
    SELECT 100, N'table:delete'   UNION ALL
    SELECT 100, N'table:manage'   UNION ALL
    SELECT 100, N'company:read'   UNION ALL
    SELECT 100, N'company:edit'   UNION ALL
    SELECT 100, N'community:manage' UNION ALL
    -- Algemeen bestuur
    SELECT  99, N'blog:read'      UNION ALL
    SELECT  99, N'blog:create'    UNION ALL
    SELECT  99, N'blog:manage'    UNION ALL
    SELECT  99, N'table:read'     UNION ALL
    SELECT  99, N'table:edit'     UNION ALL
    SELECT  99, N'company:read'   UNION ALL
    SELECT  99, N'company:edit'   UNION ALL
    SELECT  99, N'community:manage' UNION ALL
    -- Directeur
    SELECT  97, N'blog:read'      UNION ALL
    SELECT  97, N'table:read'     UNION ALL
    SELECT  97, N'company:read'   UNION ALL
    SELECT  97, N'company:edit'   UNION ALL
    -- Bedrijfseigenaar
    SELECT  94, N'blog:read'      UNION ALL
    SELECT  94, N'table:read'     UNION ALL
    SELECT  94, N'company:read'   UNION ALL
    SELECT  94, N'company:edit'   UNION ALL
    -- Bedrijfsmanager
    SELECT  93, N'blog:read'      UNION ALL
    SELECT  93, N'table:read'     UNION ALL
    SELECT  93, N'company:read'   UNION ALL
    SELECT  93, N'company:edit'   UNION ALL
    -- Lid
    SELECT  91, N'blog:read'      UNION ALL
    SELECT  91, N'table:read'     UNION ALL
    SELECT  91, N'company:read'
)
INSERT INTO [dbo].[RolePermissions] ([RoleID], [Permission])
SELECT s.[RoleID], s.[Permission]
FROM SeedPerms s
INNER JOIN [dbo].[Roles] r ON r.[RoleID] = s.[RoleID]
WHERE NOT EXISTS (
    SELECT 1 FROM [dbo].[RolePermissions] rp
    WHERE rp.[RoleID] = s.[RoleID] AND rp.[Permission] = s.[Permission]
);