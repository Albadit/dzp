{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-debug",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "debug.csproj",
        "--configuration",
        "Debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "recycle-dnn",
      "detail": "Restart IIS so w3wp picks up the latest DLL+PDB",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "Start-Process -FilePath 'iisreset' -ArgumentList '/restart' -Verb RunAs -Wait"
      ],
      "presentation": {
        "reveal": "always",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "build-and-recycle",
      "detail": "Build debug DLL then recycle IIS app pool",
      "dependsOn": ["build-debug", "recycle-dnn"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
