@inherits DotNetNuke.Web.Razor.DotNetNukeWebPage<dynamic>
@{
    // --- Load and cache HeaderRoute.json (across requests, auto-invalidates on file change) ---
    const string cacheKey = "dzp:headerRoute";
    var appCache = System.Web.HttpRuntime.Cache;
    var config   = appCache[cacheKey] as Dictionary<string, object>;
    if (config == null)
    {
        var jsonPath = Server.MapPath("~/Portals/_default/Skins/TailwindDNN/menus/header/HeaderRoute.json");
        var json = System.IO.File.ReadAllText(jsonPath);
        var jss  = new System.Web.Script.Serialization.JavaScriptSerializer();
        config   = jss.Deserialize<Dictionary<string, object>>(json);
        appCache.Insert(cacheKey, config,
            new System.Web.Caching.CacheDependency(jsonPath),
            System.Web.Caching.Cache.NoAbsoluteExpiration,
            System.Web.Caching.Cache.NoSlidingExpiration);
    }

    var contexts   = config["contexts"] as Dictionary<string, object>;
    var popupLinks = config["popupLinks"] as System.Collections.ArrayList;

    // --- Route context (validated community/company, cached per request) ---
    var rc = DZP.CommunityAuth.CommunityAuth.Current;

    // --- URL state ---
    var rawUrl = HttpContext.Current.Request.RawUrl;
    var qIdx   = rawUrl.IndexOf('?');
    var path   = qIdx >= 0 ? rawUrl.Substring(0, qIdx) : rawUrl;
    var segs   = path.Split(new[] { '/' }, StringSplitOptions.RemoveEmptyEntries);
    var seg0   = segs.Length > 0 ? segs[0] : "";
    var auth   = HttpContext.Current.Request.IsAuthenticated;

    // Derive context from JSON mapping
    string ctx = "";
    object ctxVal;
    if (seg0.Length > 0 && contexts.TryGetValue(seg0, out ctxVal))
    {
        ctx = (string)ctxVal;
    }
    else if (seg0.Length > 0)
    {
        foreach (var kv in contexts)
        {
            if (seg0.Equals(kv.Key, StringComparison.OrdinalIgnoreCase))
            {
                ctx = (string)kv.Value;
                break;
            }
        }
    }

    // Community from CommunityAuth (already validated + membership checked)
    var hasCommunity = rc != null && !string.IsNullOrEmpty(rc.CommunitySlug);
    var communityName = hasCommunity ? rc.CommunityName : "";
    var slug          = hasCommunity ? rc.CommunitySlug : "";

    // Lookup Community.ImageUrl (cached per request to avoid repeat queries)
    string communityImg = "";
    if (hasCommunity)
    {
        var imgItemKey = "dzp:communityImg:" + slug;
        var cached = HttpContext.Current.Items[imgItemKey] as string;
        if (cached != null)
        {
            communityImg = cached;
        }
        else
        {
            var imgConn = System.Configuration.ConfigurationManager.ConnectionStrings["SiteSqlServer"];
            if (imgConn != null && !string.IsNullOrEmpty(imgConn.ConnectionString))
            {
                using (var c = new System.Data.SqlClient.SqlConnection(imgConn.ConnectionString))
                {
                    using (var cm = new System.Data.SqlClient.SqlCommand("SELECT ImageUrl FROM Community WHERE Id = @cid", c))
                    {
                        cm.Parameters.AddWithValue("@cid", rc.CommunityId);
                        c.Open();
                        var r = cm.ExecuteScalar();
                        if (r != null && r != DBNull.Value) { communityImg = (string)r; }
                    }
                }
            }
            HttpContext.Current.Items[imgItemKey] = communityImg ?? "";
        }
        if (string.IsNullOrEmpty(communityImg))
        {
            communityImg = "https://picsum.photos/seed/" + slug + "/64/64";
        }
    }
    if (hasCommunity) { ctx = "community"; }

    // --- Portal / user info ---
    var ps          = DotNetNuke.Entities.Portals.PortalSettings.Current;
    var user        = ps != null ? ps.UserInfo : null;
    var logoUrl     = (ps != null && !string.IsNullOrEmpty(ps.LogoFile)) ? ps.HomeDirectory + ps.LogoFile : "";
    var profileImg  = (user != null && user.UserID > 0) ? "/DnnImageHandler.ashx?mode=profilepic&userId=" + user.UserID + "&h=64&w=64" : "";
    var displayName = user != null ? (user.DisplayName ?? "") : "";
    var email       = user != null ? (user.Email ?? "") : "";
    var portalName  = ps != null ? ps.PortalName : "";
    var skinPath    = (ps != null && ps.ActiveTab != null && !string.IsNullOrEmpty(ps.ActiveTab.SkinPath))
                      ? ps.ActiveTab.SkinPath : "/Portals/_default/Skins/TailwindDNN/";
    var userRole = "";
    if (user != null && user.UserID > 0)
    {
        if (user.IsSuperUser) { userRole = "Super User"; }
        else if (user.IsInRole("Administrators")) { userRole = "Administrators"; }
        else if (hasCommunity && rc.CommunityRoleNames != null && rc.CommunityRoleNames.Count > 0)
        {
            userRole = string.Join(", ", rc.CommunityRoleNames);
        }
    }
}

<div class="sticky top-0 z-50 bg-background flex h-17.5 p-3 border-b border-divider">
    <div class="lg:w-[250px] mr-4 flex gap-2.5 shrink-0 items-center">
        <!-- Mobile hamburger -->
        <button type="button" id="sidebar-toggle" class="lg:hidden p-1.5 rounded-md hover:bg-default-100 transition-colors" aria-label="Toggle sidebar">
            <i data-lucide="menu" class="size-5"></i>
        </button>
        <!-- Logo -->
        <a href="/" class="lg:block hidden self-stretch">
            <img src="@logoUrl" alt="@portalName" class="h-full"/>
        </a>
    </div>
    <div class="w-full flex justify-between">
        <div class="flex gap-2.5 @(string.IsNullOrEmpty(communityName) ? "invisible" : "")">
            <img src="@communityImg" alt="@communityName" class="sm:flex hidden h-full aspect-square object-cover rounded-sm bg-default-200" />
            <div class="lg:w-80 w-45 flex flex-col lg:justify-between justify-center">
                <span class="lg:text-base text-sm font-bold w-full text-ellipsis overflow-hidden whitespace-nowrap">@communityName</span>
                <div class="flex gap-2 items-center">
                    <i data-lucide="coffee" class="size-3 shrink-0"></i>
                    <span class="lg:text-base w-full text-xs text-ellipsis overflow-hidden whitespace-nowrap">@userRole</span>
                </div>
            </div>
        </div>
        <div class="flex gap-8 items-center">
            <i data-lucide="bell" class="lg:block hidden size-5.5 shrink-0"></i>
            <i data-lucide="search" class="lg:block hidden size-5.5 shrink-0"></i>
            <div id="user-menu-trigger" class="flex gap-2.5 items-center self-stretch relative cursor-pointer">
                <img src="@profileImg" alt="@displayName" class="h-full shrink-0 aspect-square object-cover rounded-full">
                <div class="lg:flex hidden flex-col max-w-32 leading-none">
                    <span class="w-full font-bold text-ellipsis overflow-hidden whitespace-nowrap">@displayName</span>
                    <span class="w-full text-sm text-ellipsis overflow-hidden whitespace-nowrap">@email</span>
                </div>

                <!-- User Popup -->
                <div id="user-popup" class="hidden absolute top-full right-0 mt-2 w-64 bg-background rounded-lg shadow-card border border-divider z-50 py-2">
                    <ul class="flex flex-col">
                    @foreach (Dictionary<string, object> link in popupLinks)
                    {
                        object linkVal;
                        var ctxList = link.TryGetValue("context", out linkVal) && linkVal != null ? linkVal as System.Collections.ArrayList : null;
                        if (ctxList != null && ctxList.Count > 0)
                        {
                            bool show = false;
                            foreach (string rule in ctxList)
                            {
                                if (rule[0] == '!')
                                {
                                    if (ctx.Equals(rule.Substring(1), StringComparison.OrdinalIgnoreCase)) { show = false; break; }
                                    show = true;
                                }
                                else if (ctx.Equals(rule, StringComparison.OrdinalIgnoreCase)) { show = true; break; }
                            }
                            if (!show) { continue; }
                        }

                        var hrefRaw   = link.TryGetValue("href", out linkVal) && linkVal != null ? (string)linkVal : "";
                        var label     = link.TryGetValue("label", out linkVal) && linkVal != null ? (string)linkVal : "";
                        var css       = link.TryGetValue("css", out linkVal) && linkVal != null ? (string)linkVal : "text-foreground-700";
                        var separator = link.TryGetValue("separator", out linkVal) && linkVal != null ? (string)linkVal : "";

                        string href;
                        if (hrefRaw.Length > 12 && hrefRaw[0] == '[' && hrefRaw.StartsWith("[community]", StringComparison.OrdinalIgnoreCase))
                        {
                            if (!hasCommunity) { continue; }
                            href = "/" + slug + hrefRaw.Substring(11);
                        }
                        else
                        {
                            href = "/" + hrefRaw;
                        }

                        <li class="@separator"><a href="@href" class="block px-4 py-2 text-sm @css hover:bg-default-100">@label</a></li>
                    }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="@(skinPath)resources/js/header.js"></script>
