@using System.IO
@using System.Web.Script.Serialization
@inherits DotNetNuke.Web.Razor.DotNetNukeWebPage<dynamic>

@{
    // --- Load and cache _routeFilter.json ---
    const string cacheKey = "dzp:headerRoute";
    var config = HttpContext.Current.Items[cacheKey] as Dictionary<string, object>;
    if (config == null)
    {
        var jsonPath = Server.MapPath("~/Portals/_default/Skins/TailwindDNN/menus/header/_routeFilter.json");
        var json = File.ReadAllText(jsonPath);
        var jss = new JavaScriptSerializer();
        config = jss.Deserialize<Dictionary<string, object>>(json);
        HttpContext.Current.Items[cacheKey] = config;
    }

    var contexts   = config["contexts"] as Dictionary<string, object>;
    var popupLinks = config["popupLinks"] as System.Collections.ArrayList;

    // --- URL state ---
    var req  = HttpContext.Current.Request;
    var segs = req.RawUrl.Split('?')[0].Trim('/').Split(new[] { '/' }, StringSplitOptions.RemoveEmptyEntries);
    var seg0 = segs.Length > 0 ? segs[0] : "";

    // Derive context from JSON mapping
    string ctx = "";
    bool knownSegment = false;
    foreach (var kv in contexts)
    {
        if (seg0.Equals(kv.Key, StringComparison.OrdinalIgnoreCase))
        {
            ctx = (string)kv.Value;
            knownSegment = true;
            break;
        }
    }

    var slug         = (segs.Length >= 2 && !knownSegment) ? seg0 : "";
    var hasCommunity = !string.IsNullOrEmpty(slug)
                       && HttpContext.Current.Items.Contains("dzp:CommunityValid")
                       && (bool)HttpContext.Current.Items["dzp:CommunityValid"];
    if (hasCommunity) { ctx = "community"; }
}

<ul class="flex flex-col">
@foreach (Dictionary<string, object> link in popupLinks)
{
    // --- Context filter ---
    var ctxList = link.ContainsKey("context") && link["context"] != null ? link["context"] as System.Collections.ArrayList : null;
    if (ctxList != null && ctxList.Count > 0)
    {
        bool show = false;
        foreach (string rule in ctxList)
        {
            if (rule.StartsWith("!"))
            {
                if (!ctx.Equals(rule.Substring(1), StringComparison.OrdinalIgnoreCase)) { show = true; }
                else { show = false; break; }
            }
            else
            {
                if (ctx.Equals(rule, StringComparison.OrdinalIgnoreCase)) { show = true; break; }
            }
        }
        if (!show) { continue; }
    }

    var hrefRaw   = link.ContainsKey("href") && link["href"] != null ? (string)link["href"] : "";
    var label     = link.ContainsKey("label") && link["label"] != null ? (string)link["label"] : "";
    var css       = link.ContainsKey("css") && link["css"] != null ? (string)link["css"] : "text-gray-700";
    var separator = link.ContainsKey("separator") && link["separator"] != null ? (string)link["separator"] : "";

    // Resolve [community] placeholder
    string href;
    if (hrefRaw.StartsWith("[community]", StringComparison.OrdinalIgnoreCase))
    {
        if (!hasCommunity) { continue; }
        href = "/" + slug + hrefRaw.Substring("[community]".Length);
    }
    else
    {
        href = "/" + hrefRaw;
    }

    <li class="@separator"><a href="@href" class="block px-4 py-2 text-sm @css hover:bg-gray-100">@label</a></li>
}
</ul>
