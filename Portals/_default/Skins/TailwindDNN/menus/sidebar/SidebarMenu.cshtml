@inherits DotNetNuke.Web.Razor.DotNetNukeWebPage<dynamic>

@helper RenderTreeItems(System.Collections.ArrayList nodes, string currentPath) {
    foreach (object[] node in nodes) {
        var href     = (string)node[0];
        var icon     = (string)node[1];
        var text     = (string)node[2];
        var children = (System.Collections.ArrayList)node[3];
        var hasSub   = children != null && children.Count > 0;

        bool active      = currentPath.Equals(href.TrimEnd('/'), StringComparison.OrdinalIgnoreCase);
        bool childActive = !active && currentPath.StartsWith(href.TrimEnd('/') + "/", StringComparison.OrdinalIgnoreCase);
        bool expanded    = childActive;
        string cls = (active || childActive)
            ? "bg-primary-50 text-primary-700 font-semibold"
            : "text-foreground-600 hover:bg-default-100 hover:text-foreground-900";

        if (hasSub) {
            var ariaExp  = expanded ? "true" : "false";
            var gridRows = expanded ? "1fr" : "0fr";
            var chevCls  = expanded ? "size-4 transition-transform rotate-90" : "size-4 transition-transform";

            <li>
                <div data-submenu-parent aria-expanded="@ariaExp" class="flex items-center rounded-lg text-sm transition-colors @cls">
                    <a href="@href" class="flex-1 flex items-center gap-3 px-3 py-2.5 min-w-0">
                        @if (!string.IsNullOrEmpty(icon)) { <i data-lucide="@icon" class="size-5 shrink-0"></i> }
                        <span class="truncate">@text</span>
                    </a>
                    <button type="button" class="sidebar-submenu-toggle px-2 py-2.5 shrink-0" aria-label="Expand">
                        <i data-lucide="chevron-right" class="@chevCls"></i>
                    </button>
                </div>
                <div style="display:grid; grid-template-rows: @gridRows;" class="transition-[grid-template-rows] duration-200">
                    <ul class="overflow-hidden flex flex-col gap-1 pl-4">
                        @RenderTreeItems(children, currentPath)
                    </ul>
                </div>
            </li>
        } else {
            <li>
                <a href="@href" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors @cls">
                    @if (!string.IsNullOrEmpty(icon)) { <i data-lucide="@icon" class="size-5 shrink-0"></i> }
                    <span>@text</span>
                </a>
            </li>
        }
    }
}

@{
    // --- Load and cache SidebarRoute.json (across requests, auto-invalidates on file change) ---
    const string cacheKey = "dzp:sidebarRoute";
    var cache  = System.Web.HttpRuntime.Cache;
    var config = cache[cacheKey] as Dictionary<string, object>;
    if (config == null)
    {
        var jsonPath = Server.MapPath("~/Portals/_default/Skins/TailwindDNN/menus/sidebar/SidebarRoute.json");
        var json = System.IO.File.ReadAllText(jsonPath);
        var jss  = new System.Web.Script.Serialization.JavaScriptSerializer();
        config   = jss.Deserialize<Dictionary<string, object>>(json);
        cache.Insert(cacheKey, config,
            new System.Web.Caching.CacheDependency(jsonPath),
            System.Web.Caching.Cache.NoAbsoluteExpiration,
            System.Web.Caching.Cache.NoSlidingExpiration);
    }

    var contexts = config["contexts"] as Dictionary<string, object>;
    var sections = config["sections"] as System.Collections.ArrayList;

    // --- URL state ---
    var rawUrl      = HttpContext.Current.Request.RawUrl;
    var qIdx        = rawUrl.IndexOf('?');
    var currentPath = (qIdx >= 0 ? rawUrl.Substring(0, qIdx) : rawUrl).TrimEnd('/');
    var segs        = currentPath.Split(new[] { '/' }, StringSplitOptions.RemoveEmptyEntries);
    var seg0        = segs.Length > 0 ? segs[0] : "";

    // Derive context from JSON mapping
    string ctx = "";
    object ctxVal;
    if (seg0.Length > 0 && contexts.TryGetValue(seg0, out ctxVal))
    {
        ctx = (string)ctxVal;
    }
    else if (seg0.Length > 0)
    {
        foreach (var kv in contexts)
        {
            if (seg0.Equals(kv.Key, StringComparison.OrdinalIgnoreCase))
            {
                ctx = (string)kv.Value;
                break;
            }
        }
    }

    // Community from RouteContext (already validated + membership checked)
    var rc           = DZP.RouteContext.RouteContext.Current;
    var hasCommunity = rc != null && !string.IsNullOrEmpty(rc.CommunitySlug);
    var slug         = hasCommunity ? rc.CommunitySlug : "";
    if (hasCommunity) { ctx = "community"; }

    // Hide dashboard link when user belongs to exactly one community
    var userComms    = DZP.RouteContext.RouteContext.GetUserCommunities(
                           DotNetNuke.Entities.Portals.PortalSettings.Current?.UserInfo);

    // --- Portal / user info for shell ---
    var ps       = DotNetNuke.Entities.Portals.PortalSettings.Current;
    var isSuperUser = ps != null && ps.UserInfo != null && ps.UserInfo.IsSuperUser;

    var hideDashboard = !isSuperUser && userComms != null && userComms.Count == 1;

    // --- Build role set from RouteContext (no extra SQL needed) ---
    var freshRoles = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    freshRoles.Add("All Users");
    if (ps != null && ps.UserInfo != null && ps.UserInfo.UserID > 0)
    {
        freshRoles.Add("Registered Users");
        if (hasCommunity && !string.IsNullOrEmpty(rc.CommunityRoleName))
        {
            freshRoles.Add(rc.CommunityRoleName);
        }
    }
    var logoUrl  = (ps != null && !string.IsNullOrEmpty(ps.LogoFile)) ? ps.HomeDirectory + ps.LogoFile : "";
    var logoHref = hasCommunity ? "/" + slug + "/home" : "/dashboard";
    var skinPath = (ps != null && ps.ActiveTab != null && !string.IsNullOrEmpty(ps.ActiveTab.SkinPath))
                   ? ps.ActiveTab.SkinPath : "/Portals/_default/Skins/TailwindDNN/";

    // Build lookups from DNN tabs in a single pass:
    //   tabsByPath        — normalized TabPath → TabInfo (for permission checks)
    //   childrenByParent  — ParentId → sorted List<TabInfo> (for BFS tree building)
    var portalId = ps != null ? ps.PortalId : 0;
    var tabsByPath = new Dictionary<string, DotNetNuke.Entities.Tabs.TabInfo>(StringComparer.OrdinalIgnoreCase);
    var childrenByParent = new Dictionary<int, List<DotNetNuke.Entities.Tabs.TabInfo>>();
    var tabCollection = DotNetNuke.Entities.Tabs.TabController.Instance.GetTabsByPortal(portalId);
    if (tabCollection != null)
    {
        foreach (DotNetNuke.Entities.Tabs.TabInfo t in tabCollection.Values)
        {
            // tabsByPath
            if (!string.IsNullOrEmpty(t.TabPath))
            {
                var tp = t.TabPath.Replace("//", "/").TrimStart('/');
                if (tp.Length > 0 && !tabsByPath.ContainsKey(tp))
                {
                    tabsByPath[tp] = t;
                }
            }

            // childrenByParent (skip deleted, insert sorted by TabOrder)
            if (!t.IsDeleted)
            {
                List<DotNetNuke.Entities.Tabs.TabInfo> siblings;
                if (!childrenByParent.TryGetValue(t.ParentId, out siblings))
                {
                    siblings = new List<DotNetNuke.Entities.Tabs.TabInfo>();
                    childrenByParent[t.ParentId] = siblings;
                }
                int pos = siblings.Count;
                for (int idx = 0; idx < siblings.Count; idx++)
                {
                    if (t.TabOrder < siblings[idx].TabOrder) { pos = idx; break; }
                }
                siblings.Insert(pos, t);
            }
        }
    }
}

<!-- Overlay for mobile -->
<div id="sidebar-overlay" class="hidden fixed inset-0 z-30 bg-overlay lg:hidden"></div>

<!-- Sidebar -->
<aside id="sidebar" class="fixed top-0 lg:sticky lg:top-[70px] z-40 h-dvh lg:h-[calc(100dvh-70px)] w-[250px] -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out bg-background border-r border-divider flex flex-col">

    <!-- Header (mobile only) -->
    <div class="h-17.5 flex items-center justify-between px-4 py-3 border-b border-divider lg:hidden shrink-0">
        <a href="@logoHref" class="self-stretch">
            <img src="@logoUrl" alt="@(ps != null ? ps.PortalName : "")" class="h-full"/>
        </a>
        <button type="button" id="sidebar-close" class="p-1 rounded-md hover:bg-default-100 transition-colors" aria-label="Close sidebar">
            <i data-lucide="x" class="size-5 text-foreground-500"></i>
        </button>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 overflow-y-auto px-3 py-4 flex flex-col gap-6 min-w-[250px]">
    @foreach (var section in sections)
    {
        var sec = (Dictionary<string, object>)section;

        // --- Context filter ---
        object ctxRaw;
        var ctxList = sec.TryGetValue("context", out ctxRaw) && ctxRaw != null ? ctxRaw as System.Collections.ArrayList : null;
        if (ctxList != null && ctxList.Count > 0)
        {
            bool show = false;
            foreach (string rule in ctxList)
            {
                if (rule[0] == '!')
                {
                    if (ctx.Equals(rule.Substring(1), StringComparison.OrdinalIgnoreCase)) { show = false; break; }
                    show = true;
                }
                else if (ctx.Equals(rule, StringComparison.OrdinalIgnoreCase)) { show = true; break; }
            }
            if (!show) { continue; }
        }

        // --- Dynamic (parent) or static (pages) ---
        object parentRaw;
        var parentPath = sec.TryGetValue("parent", out parentRaw) && parentRaw != null ? (string)parentRaw : null;

        object pagesRaw;
        var pagesObj = sec.TryGetValue("pages", out pagesRaw) && pagesRaw != null ? pagesRaw as System.Collections.ArrayList : null;

        // Must have either parent or pages
        if (parentPath == null && (pagesObj == null || pagesObj.Count == 0)) { continue; }

        // --- Icons map (for dynamic sections) ---
        object iconsRaw;
        var iconMap = sec.TryGetValue("icons", out iconsRaw) && iconsRaw != null ? iconsRaw as Dictionary<string, object> : null;

        // --- Ignore list (for dynamic sections) ---
        object ignoreRaw;
        var ignoreList = sec.TryGetValue("ignore", out ignoreRaw) && ignoreRaw != null ? ignoreRaw as System.Collections.ArrayList : null;
        var ignoreSet = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        if (ignoreList != null)
        {
            foreach (string ign in ignoreList) { ignoreSet.Add(ign); }
        }

        // --- Level (0 = unlimited depth, 1 = direct children only, 2 = children+grandchildren, etc.) ---
        object levelRaw;
        var maxLevel = sec.TryGetValue("level", out levelRaw) && levelRaw != null ? Convert.ToInt32(levelRaw) : 1;

        // --- Label ---
        object labelRaw;
        var label = sec.TryGetValue("label", out labelRaw) && labelRaw != null ? (string)labelRaw : null;

        // Resolve items — tree nodes: object[] { href, icon, text, childrenArrayList }
        var items = new System.Collections.ArrayList();
        var nodeMap = new Dictionary<int, object[]>();
        bool skipSection = false;

        if (parentPath != null)
        {
            // --- DYNAMIC: pull child tabs from DNN ---
            var isCommunityParent = parentPath.StartsWith("[community]", StringComparison.OrdinalIgnoreCase);
            if (isCommunityParent && !hasCommunity) { skipSection = true; }

            // Check the parent tab itself first
            DotNetNuke.Entities.Tabs.TabInfo parentTab = null;
            var parentFound = tabsByPath.TryGetValue(parentPath, out parentTab);
            if (!skipSection && parentFound)
            {
                {
                    var canView = isSuperUser;
                    if (!canView && parentTab.TabPermissions != null)
                    {
                        bool hasAllow = false;
                        foreach (DotNetNuke.Security.Permissions.TabPermissionInfo perm in parentTab.TabPermissions)
                        {
                            if (perm.PermissionKey == "VIEW" && perm.AllowAccess)
                            {
                                if (isCommunityParent
                                    ? (rc != null && string.Equals(perm.RoleName, rc.CommunityRoleName, StringComparison.OrdinalIgnoreCase))
                                    : freshRoles.Contains(perm.RoleName))
                                {
                                    hasAllow = true;
                                }
                            }
                        }
                        canView = hasAllow;
                    }
                    if (!canView) { skipSection = true; }
                }
                if (!parentTab.IsVisible
                    || (parentTab.StartDate != DateTime.MinValue && parentTab.StartDate > DateTime.Now)
                    || (parentTab.EndDate != DateTime.MinValue && parentTab.EndDate < DateTime.Now))
                {
                    skipSection = true;
                }
            }

            if (!skipSection && parentTab != null)
            {
                // BFS to build tree of descendants up to maxLevel depth (0 = unlimited)
                var queue = new List<object[]>();
                queue.Add(new object[] { parentTab, 0 });
                int qi = 0;

                while (qi < queue.Count)
                {
                    var entry = queue[qi];
                    qi++;
                    var qTab = (DotNetNuke.Entities.Tabs.TabInfo)entry[0];
                    var qDepth = (int)entry[1];

                    // Look up pre-sorted children (O(1) instead of scanning all tabs)
                    List<DotNetNuke.Entities.Tabs.TabInfo> children;
                    if (!childrenByParent.TryGetValue(qTab.TabID, out children))
                    {
                        children = new List<DotNetNuke.Entities.Tabs.TabInfo>();
                    }

                    foreach (var child in children)
                    {
                        var childName = child.TabName.ToLower();

                        // Skip ignored pages
                        if (ignoreSet.Contains(childName)) { continue; }

                        var childCanView = isSuperUser;
                        if (!childCanView && child.TabPermissions != null)
                        {
                            bool chAllow = false;
                            foreach (DotNetNuke.Security.Permissions.TabPermissionInfo perm in child.TabPermissions)
                            {
                                if (perm.PermissionKey == "VIEW" && perm.AllowAccess)
                                {
                                    if (isCommunityParent
                                        ? (rc != null && string.Equals(perm.RoleName, rc.CommunityRoleName, StringComparison.OrdinalIgnoreCase))
                                        : freshRoles.Contains(perm.RoleName))
                                    {
                                        chAllow = true;
                                    }
                                }
                            }
                            childCanView = chAllow;
                        }

                        var childOk = child.IsVisible
                            && childCanView
                            && (child.StartDate == DateTime.MinValue || child.StartDate <= DateTime.Now)
                            && (child.EndDate == DateTime.MinValue || child.EndDate >= DateTime.Now);

                        if (childOk)
                        {
                            string href;
                            if (isCommunityParent)
                            {
                                var childPath = child.TabPath.Replace("//", "/").TrimStart('/');
                                // Extract [community] token from parentPath dynamically
                                var tokenEnd = parentPath.IndexOf(']');
                                var communityToken = parentPath.Substring(0, tokenEnd + 1);
                                if (childPath.StartsWith(communityToken, StringComparison.OrdinalIgnoreCase))
                                {
                                    href = "/" + slug + childPath.Substring(communityToken.Length);
                                }
                                else
                                {
                                    href = "/" + slug + "/" + childName;
                                }
                            }
                            else
                            {
                                var childPath = child.TabPath.Replace("//", "/").TrimStart('/');
                                href = "/" + childPath;
                            }

                            object iconVal;
                            var icon = (iconMap != null && iconMap.TryGetValue(childName, out iconVal) && iconVal != null)
                                ? (string)iconVal : "";
                            var displayName = !string.IsNullOrEmpty(child.Title) ? child.Title : child.TabName;
                            var text = char.ToUpper(displayName[0]) + displayName.Substring(1);

                            // Build tree node with children list
                            var childrenList = new System.Collections.ArrayList();
                            var treeNode = new object[] { href, icon, text, childrenList };

                            // Attach to parent node or to section roots
                            object[] parentNode;
                            if (qTab.TabID == parentTab.TabID)
                            {
                                items.Add(treeNode);
                            }
                            else if (nodeMap.TryGetValue(qTab.TabID, out parentNode))
                            {
                                ((System.Collections.ArrayList)parentNode[3]).Add(treeNode);
                            }
                            nodeMap[child.TabID] = treeNode;

                            // Enqueue for deeper traversal if level allows
                            var nextDepth = qDepth + 1;
                            if (maxLevel == 0 || nextDepth < maxLevel)
                            {
                                queue.Add(new object[] { child, nextDepth });
                            }
                        }
                    }
                }
            }
        }
        else
        {
            // --- STATIC: resolve pages from JSON ---
            foreach (Dictionary<string, object> entry in pagesObj)
            {
                object val;
                var p    = entry.TryGetValue("page", out val) && val != null ? (string)val : "";
                var icon = entry.TryGetValue("icon", out val) && val != null ? (string)val : "";
                var text = entry.TryGetValue("text", out val) && val != null ? (string)val : null;

                var skipEntry = hideDashboard && p.Equals("dashboard", StringComparison.OrdinalIgnoreCase);

                string href = "";
                if (!skipEntry)
                {
                    if (p.Length > 12 && p[0] == '[' && p.StartsWith("[community]", StringComparison.OrdinalIgnoreCase))
                    {
                        if (!hasCommunity) { skipSection = true; break; }
                        href = "/" + slug + p.Substring(11);
                    }
                    else
                    {
                        href = "/" + p;
                    }

                    // Check DNN tab permissions (and all ancestors)
                    var isCommunityPage = p.StartsWith("[community]", StringComparison.OrdinalIgnoreCase);
                    var pathToCheck = p;
                    while (pathToCheck.Length > 0 && !skipEntry)
                    {
                        DotNetNuke.Entities.Tabs.TabInfo tab;
                        if (tabsByPath.TryGetValue(pathToCheck, out tab))
                        {
                            var tabCanView = isSuperUser;
                            if (!tabCanView && tab.TabPermissions != null)
                            {
                                bool stAllow = false;
                                foreach (DotNetNuke.Security.Permissions.TabPermissionInfo perm in tab.TabPermissions)
                                {
                                    if (perm.PermissionKey == "VIEW" && perm.AllowAccess)
                                    {
                                        if (isCommunityPage
                                            ? (rc != null && string.Equals(perm.RoleName, rc.CommunityRoleName, StringComparison.OrdinalIgnoreCase))
                                            : freshRoles.Contains(perm.RoleName))
                                        {
                                            stAllow = true;
                                        }
                                    }
                                }
                                tabCanView = stAllow;
                            }
                            if (!tabCanView) { skipEntry = true; }
                            if (!tab.IsVisible
                                || (tab.StartDate != DateTime.MinValue && tab.StartDate > DateTime.Now)
                                || (tab.EndDate != DateTime.MinValue && tab.EndDate < DateTime.Now))
                            {
                                skipEntry = true;
                            }
                        }
                        var lastSlash = pathToCheck.LastIndexOf('/');
                        pathToCheck = lastSlash > 0 ? pathToCheck.Substring(0, lastSlash) : "";
                    }
                }
                
                if (skipEntry) { /* skip */ }
                else
                {
                    if (text == null)
                    {
                        var lastSlash = href.LastIndexOf('/');
                        var name = lastSlash >= 0 && lastSlash < href.Length - 1 ? href.Substring(lastSlash + 1) : href.TrimStart('/');
                        text = char.ToUpper(name[0]) + name.Substring(1);
                    }

                    items.Add(new object[] { href, icon, text, new System.Collections.ArrayList() });
                }
            }
        }
        if (!skipSection && items.Count > 0)
        {

        <div class="flex flex-col gap-2">
            @if (!string.IsNullOrEmpty(label))
            {
                <h3 class="px-3 text-xs font-semibold uppercase tracking-wider text-foreground-400">@label</h3>
            }
            <ul class="flex flex-col gap-1">
                @RenderTreeItems(items, currentPath)
            </ul>
        </div>
        }
    }
    </nav>

    <!-- Footer -->
    <div class="border-t border-divider px-3 py-4 shrink-0">
        <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-foreground-600 hover:bg-default-100 hover:text-foreground-900">
            <i data-lucide="help-circle" class="size-5 shrink-0"></i>
            <span>Help & Support</span>
        </a>
    </div>
</aside>

<script src="@(skinPath)resources/js/sidebar.js"></script>
