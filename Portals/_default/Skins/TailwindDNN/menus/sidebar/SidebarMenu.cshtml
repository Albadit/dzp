@using System.IO
@using System.Web.Script.Serialization
@inherits DotNetNuke.Web.Razor.DotNetNukeWebPage<dynamic>

@helper RenderLink(string href, string icon, string text, string currentPath) {
    bool active = currentPath.Equals(href.TrimEnd('/'), StringComparison.OrdinalIgnoreCase);
    string cls = active
        ? "bg-primary-50 text-primary-700 font-semibold"
        : "text-gray-600 hover:bg-gray-100 hover:text-gray-900";

    <li>
        <a href="@href" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors @cls">
            @if (!string.IsNullOrEmpty(icon)) { <i data-lucide="@icon" class="size-5 shrink-0"></i> }
            <span>@text</span>
        </a>
    </li>
}

@{
    // --- Load and cache _routeFilter.json ---
    const string cacheKey = "dzp:routeFilter";
    var config = HttpContext.Current.Items[cacheKey] as Dictionary<string, object>;
    if (config == null)
    {
        var jsonPath = Server.MapPath("~/Portals/_default/Skins/TailwindDNN/menus/sidebar/SidebarRoute.json");
        var json = File.ReadAllText(jsonPath);
        var jss = new JavaScriptSerializer();
        config = jss.Deserialize<Dictionary<string, object>>(json);
        HttpContext.Current.Items[cacheKey] = config;
    }

    var contexts = config["contexts"] as Dictionary<string, object>;
    var sections = config["sections"] as System.Collections.ArrayList;

    // --- URL state ---
    var req         = HttpContext.Current.Request;
    var currentPath = req.RawUrl.Split('?')[0].TrimEnd('/');
    var segs        = currentPath.Trim('/').Split(new[] { '/' }, StringSplitOptions.RemoveEmptyEntries);
    var seg0        = segs.Length > 0 ? segs[0] : "";

    // Derive context from JSON mapping
    string ctx = "";
    bool knownSegment = false;
    foreach (var kv in contexts)
    {
        if (seg0.Equals(kv.Key, StringComparison.OrdinalIgnoreCase))
        {
            ctx = (string)kv.Value;
            knownSegment = true;
            break;
        }
    }

    var slug         = (segs.Length >= 2 && !knownSegment) ? seg0 : "";
    var hasCommunity = !string.IsNullOrEmpty(slug)
                       && HttpContext.Current.Items.Contains("dzp:CommunityValid")
                       && (bool)HttpContext.Current.Items["dzp:CommunityValid"];
    if (hasCommunity) { ctx = "community"; }
}

@foreach (var section in sections)
{
    var sec = (Dictionary<string, object>)section;
    // --- Context filter ---
    // context is an array: ["admin", "dashboard"] = show on admin OR dashboard
    //                      ["!settings"]           = show everywhere EXCEPT settings
    var ctxList = sec.ContainsKey("context") && sec["context"] != null ? sec["context"] as System.Collections.ArrayList : null;
    if (ctxList != null && ctxList.Count > 0)
    {
        bool show = false;
        foreach (string rule in ctxList)
        {
            if (rule.StartsWith("!"))
            {
                // negation: show unless ctx matches
                if (!ctx.Equals(rule.Substring(1), StringComparison.OrdinalIgnoreCase)) { show = true; }
                else { show = false; break; }
            }
            else
            {
                if (ctx.Equals(rule, StringComparison.OrdinalIgnoreCase)) { show = true; break; }
            }
        }
        if (!show) { continue; }
    }

    // --- Pages ---
    var pagesObj = sec.ContainsKey("pages") && sec["pages"] != null ? sec["pages"] as System.Collections.ArrayList : null;

    // --- Label ---
    var label = sec.ContainsKey("label") && sec["label"] != null ? (string)sec["label"] : null;

    if (pagesObj == null || pagesObj.Count == 0) { continue; }

    // Resolve paths: replace [community] with actual slug
    var items = new List<string[]>(); // [href, icon, text]
    bool skipSection = false;
    foreach (Dictionary<string, object> entry in pagesObj)
    {
        var p    = entry.ContainsKey("page") && entry["page"] != null ? (string)entry["page"] : "";
        var icon = entry.ContainsKey("icon") && entry["icon"] != null ? (string)entry["icon"] : "";

        string href;
        if (p.StartsWith("[community]", StringComparison.OrdinalIgnoreCase))
        {
            if (!hasCommunity) { skipSection = true; break; }
            href = "/" + slug + p.Substring("[community]".Length);
        }
        else
        {
            href = "/" + p;
        }

        var parts = href.Trim('/').Split('/');
        var name  = parts[parts.Length - 1];
        var text  = char.ToUpper(name[0]) + name.Substring(1);

        items.Add(new[] { href, icon, text });
    }
    if (skipSection) { continue; }

    <div class="mb-6">
        @if (!string.IsNullOrEmpty(label))
        {
            <h3 class="px-3 mb-2 text-xs font-semibold uppercase tracking-wider text-gray-400">@label</h3>
        }
        <ul class="space-y-1">
            @foreach (var item in items)
            {
                @RenderLink(item[0], item[1], item[2], currentPath)
            }
        </ul>
    </div>
}
